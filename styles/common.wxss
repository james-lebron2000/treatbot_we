/** styles/common.wxss
 * 公共样式 —— upload 页 + 通用 step / preview / tips 等。
 * Q3 视觉对齐 §B.1（Plan web-h5-cozy-gizmo V2）：
 *   - 主色统一为 var(--brand)；删 Ant Design 青绿渐变 (#1890ff → #36cfc9)
 *   - 状态色用 *-text 深色文字 + *-soft 浅底（companion token 系统）
 *   - 卡片：实白 + 1px 细边 + 32rpx 圆角 + 默认无阴影
 *   - 颜色用 var()，尺寸用 rpx（CSS variable 中的 px 不随屏宽缩放） */

/* 上传页面样式 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;             /* --s-3 */
  margin-bottom: 16rpx;       /* --s-2 */
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: var(--bg-soft);
  color: var(--text-muted);
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.step.active .step-dot {
  background: var(--brand);
  color: #fff;
}

.step-text {
  font-size: 26rpx;
  color: var(--text-muted);
}

.step.active .step-text {
  color: var(--brand);
  font-weight: 600;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: var(--line);
  margin: 0 20rpx 40rpx;
  border-radius: 999rpx;
}

.step-line.active {
  background: var(--brand);
}

/* 上传区域 */
.upload-area {
  background: var(--bg);
  border: 4rpx dashed var(--line);
  border-radius: 32rpx;       /* --r-lg */
  padding: 64rpx 32rpx;       /* --s-8 / --s-4 */
  margin-bottom: 32rpx;
  text-align: center;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
  color: var(--brand);
}

.upload-text {
  display: block;
  font-size: 32rpx;
  color: var(--text);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.upload-hint {
  display: block;
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 图片预览 */
.image-preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.preview-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-item image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;       /* --r-sm */
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: var(--red);
  color: #fff;
  border-radius: 50%;
  font-size: 32rpx;
}

.add-more {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 4rpx dashed var(--line);
  border-radius: 16rpx;
  background: var(--bg-soft);
}

.add-icon {
  font-size: 48rpx;
  color: var(--text-muted);
  margin-bottom: 4rpx;
}

.add-text {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 类型选择 */
.record-type-section {
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 30rpx;           /* --fs-body */
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.type-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-option {
  padding: 14rpx 28rpx;
  background: var(--bg-soft);
  color: var(--text-dim);
  border-radius: 999rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: background 150ms ease, color 150ms ease, border-color 150ms ease;
}

.type-option.active {
  background: var(--brand-soft);
  color: var(--brand);
  border-color: var(--brand);
}

/* 备注 */
.remark-section {
  margin-bottom: 24rpx;
}

.remark-input {
  width: 100%;
  height: 200rpx;
  background: var(--bg-soft);
  color: var(--text);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.remark-count {
  text-align: right;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 处理中动画 */
.processing-section {
  text-align: center;
  padding: 48rpx 32rpx;
}

.processing-animation {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.animation-circle {
  width: 24rpx;
  height: 24rpx;
  background: var(--brand);
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite both;
}

.animation-circle:nth-child(1) { animation-delay: -0.32s; }
.animation-circle:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.processing-title {
  font-size: 34rpx;           /* --fs-subtitle */
  font-weight: 600;
  color: var(--text);
  margin-bottom: 12rpx;
}

.processing-desc {
  font-size: 28rpx;
  color: var(--text-dim);
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.progress-section {
  margin-bottom: 32rpx;
}

.progress-bar {
  height: 16rpx;
  background: var(--bg-soft);
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: var(--brand);
  border-radius: 999rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--brand);
}

.parse-steps {
  display: flex;
  justify-content: center;
  gap: 32rpx;
}

.parse-step {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--text-dim);
}

.parse-step.completed {
  color: var(--mint-text);
}

.parse-step.completed .step-icon {
  color: var(--mint-text);
}

/* 结果页面 */
.result-section {
  text-align: center;
  padding: 48rpx 32rpx;
}

.success-icon {
  width: 96rpx;
  height: 96rpx;
  line-height: 96rpx;
  background: var(--mint);
  color: #fff;
  border-radius: 50%;
  font-size: 56rpx;
  margin: 0 auto 24rpx;
}

.success-title {
  font-size: 44rpx;           /* --fs-title */
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12rpx;
}

.success-desc {
  font-size: 28rpx;
  color: var(--text-dim);
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.result-preview {
  background: var(--mint-soft);
  border-radius: 32rpx;       /* --r-lg */
  padding: 32rpx;
  margin-bottom: 32rpx;
  text-align: left;
}

.preview-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--mint-text);
  margin-bottom: 16rpx;
}

.preview-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.preview-item {
  display: flex;
}

.item-label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--text-dim);
}

.item-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
}

/* 提示 */
.tips-section {
  background: var(--brand-soft);
  border-radius: 24rpx;       /* --r-md */
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--brand);
  margin-bottom: 12rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tip-item {
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.55;
}

/* 操作栏 */
.action-bar {
  padding: 16rpx 0;
}

.action-bar .btn {
  margin-bottom: 16rpx;
}

.btn.disabled {
  opacity: 0.5;
}
