/**app.wxss**/
@import '/styles/tokens.wxss';
@import './styles/common.wxss';

page {
  font-family: 'SF Pro Display', 'SF Pro Text', 'PingFang SC', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
  background:
    radial-gradient(circle at top, rgba(255, 255, 255, 0.98) 0%, rgba(247, 250, 254, 0.98) 24%, rgba(238, 244, 251, 1) 100%);
  color: #12233d;
  font-size: 38rpx;
  line-height: 1.6;
}

.container {
  padding: 28rpx 26rpx 52rpx;
}

/* 卡片样式 */
.card {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(15, 43, 87, 0.08);
  box-shadow: 0 18rpx 42rpx rgba(15, 43, 87, 0.07);
  backdrop-filter: blur(12rpx);
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  border-radius: 999rpx;
  font-size: 39rpx;
  font-weight: 600;
  letter-spacing: 0.4rpx;
  /* Week 4 §F.4：全站微交互 —— 按下 0.98× + 100ms cubic-bezier */
  transition: background 150ms ease, transform 100ms cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-primary {
  background: var(--brand);
  color: #fff;
}

.btn-primary:active {
  transform: scale(0.98);
  background: var(--brand-hover);
}

.btn-default {
  background: var(--bg);
  color: var(--text);
  border: 1rpx solid var(--line);
}

.btn-default:active {
  transform: scale(0.98);
  background: var(--bg-soft);
}

/* 文本样式 */
.text-primary { color: #1f4d8f; }
.text-success { color: #15803d; }
.text-warning { color: #b45309; }
.text-error { color: #b91c1c; }
.text-muted { color: #6e809e; }

.text-lg { font-size: 46rpx; }
.text-md { font-size: 42rpx; }
.text-sm { font-size: 34rpx; }
.text-xs { font-size: 30rpx; }

.font-bold { font-weight: 700; }

/* 布局 */
.flex { display: flex; }
.flex-column { flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.flex-1 { flex: 1; }

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }

.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }

.mr-10 { margin-right: 10rpx; }
.mr-20 { margin-right: 20rpx; }

.ml-10 { margin-left: 10rpx; }
.ml-20 { margin-left: 20rpx; }

.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.2rpx;
}

.tag-primary {
  background: rgba(31, 77, 143, 0.1);
  color: #1f4d8f;
}

.tag-success {
  background: rgba(21, 128, 61, 0.1);
  color: #166534;
}

.tag-warning {
  background: rgba(180, 83, 9, 0.1);
  color: #b45309;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 110rpx 54rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(15, 43, 87, 0.05);
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

.empty-state text {
  color: #6e809e;
  font-size: 38rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading text {
  margin-left: 20rpx;
  color: #6e809e;
  font-size: 36rpx;
}
