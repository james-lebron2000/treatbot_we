{
  "openapi": "3.0.0",
  "info": {
    "title": "Treatbot API",
    "description": "临床试验匹配平台 API",
    "version": "1.0.0",
    "contact": {
      "name": "Support",
      "email": "support@treatbot.example.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "本地开发环境"
    },
    {
      "url": "https://api.treatbot.example.com/api",
      "description": "生产环境"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 400
          },
          "message": {
            "type": "string",
            "example": "请求参数错误"
          },
          "data": {
            "type": "object",
            "nullable": true
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "user_xxx"
          },
          "nickName": {
            "type": "string",
            "example": "张三"
          },
          "avatarUrl": {
            "type": "string",
            "example": "https://example.com/avatar.jpg"
          },
          "phone": {
            "type": "string",
            "example": "138****8888"
          }
        }
      },
      "MedicalRecord": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "出院小结",
              "病理报告",
              "影像报告",
              "基因检测",
              "诊断证明",
              "其他"
            ]
          },
          "diagnosis": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "running",
              "completed",
              "error"
            ]
          },
          "uploadTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Trial": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "example": "PD-1抑制剂治疗晚期肺癌II期临床试验"
          },
          "phase": {
            "type": "string",
            "enum": [
              "I期",
              "II期",
              "III期",
              "IV期"
            ]
          },
          "location": {
            "type": "string"
          },
          "institution": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "recruiting",
              "closed",
              "completed"
            ]
          }
        }
      },
      "Application": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "trialId": {
            "type": "string"
          },
          "trialName": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "contacted",
              "enrolled",
              "rejected",
              "cancelled"
            ]
          },
          "applyTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "健康检查",
        "description": "检查服务是否正常运行",
        "security": [],
        "responses": {
          "200": {
            "description": "服务正常",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "version": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/weapp-login": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "微信小程序登录",
        "description": "使用微信登录 code 换取用户Token",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "code": {
                    "type": "string",
                    "description": "微信登录 code"
                  }
                },
                "required": [
                  "code"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": {
                          "type": "string"
                        },
                        "refreshToken": {
                          "type": "string"
                        },
                        "expiresIn": {
                          "type": "integer"
                        },
                        "userInfo": {
                          "$ref": "#/components/schemas/User"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/user/profile": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "获取用户资料",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "data": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "User"
        ],
        "summary": "更新用户资料",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nickName": {
                    "type": "string"
                  },
                  "avatarUrl": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功"
          }
        }
      }
    },
    "/medical/upload": {
      "post": {
        "tags": [
          "Medical"
        ],
        "summary": "上传病历文件",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "支持 jpg/png/pdf"
                  },
                  "type": {
                    "type": "string"
                  },
                  "remark": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "上传成功"
          }
        }
      }
    },
    "/medical/records": {
      "get": {
        "tags": [
          "Medical"
        ],
        "summary": "获取病历列表",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "list": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/MedicalRecord"
                          }
                        },
                        "pagination": {
                          "type": "object"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/matches/search": {
      "get": {
        "tags": [
          "Match"
        ],
        "summary": "搜索试验",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "description": "搜索关键词",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "phase",
            "in": "query",
            "description": "试验阶段",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "location",
            "in": "query",
            "description": "所在地区",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "list": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Trial"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/applications": {
      "get": {
        "tags": [
          "Application"
        ],
        "summary": "获取报名列表",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "list": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Application"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Application"
        ],
        "summary": "提交报名",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "trialId": {
                    "type": "string"
                  },
                  "recordIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "remark": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "disease": {
                    "type": "string"
                  },
                  "phone": {
                    "type": "string"
                  },
                  "trialName": {
                    "type": "string"
                  },
                  "trial_name": {
                    "type": "string"
                  },
                  "location": {
                    "type": "string"
                  },
                  "source": {
                    "type": "string",
                    "example": "weapp"
                  }
                },
                "required": [
                  "trialId"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "报名成功"
          }
        }
      }
    },
    "/admin/dashboard": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "获取仪表盘统计",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "overview": {
                          "type": "object"
                        },
                        "recordStatus": {
                          "type": "array"
                        },
                        "applicationStatus": {
                          "type": "array"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/bind-phone": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "绑定手机号",
        "description": "兼容 encryptedData/iv 和 phoneNumber 明文模式",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "encryptedData": {
                    "type": "string"
                  },
                  "iv": {
                    "type": "string"
                  },
                  "phoneNumber": {
                    "type": "string",
                    "example": "13800138000"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "绑定成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "phone": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/profile": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "获取个人信息（兼容路由）",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "data": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/medical/records/{id}/enrich": {
      "patch": {
        "tags": [
          "Medical"
        ],
        "summary": "补全病历结构化信息",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "diagnosis": {
                    "type": "string"
                  },
                  "stage": {
                    "type": "string"
                  },
                  "geneMutation": {
                    "type": "string"
                  },
                  "gene_mutation": {
                    "type": "string"
                  },
                  "treatment": {
                    "type": "string"
                  },
                  "entities": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "补全成功"
          }
        }
      }
    },
    "/trials/matches/find": {
      "post": {
        "tags": [
          "Match"
        ],
        "summary": "按病历或条件匹配试验",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "recordId": {
                    "type": "string"
                  },
                  "disease": {
                    "type": "string"
                  },
                  "stage": {
                    "type": "string"
                  },
                  "city": {
                    "type": "string"
                  },
                  "gene_mutation": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Trial"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/trials": {
      "get": {
        "tags": [
          "Match"
        ],
        "summary": "获取试验列表（兼容路由）",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "phase",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "location",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    }
  }
}
