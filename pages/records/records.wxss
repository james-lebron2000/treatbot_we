/* records 页 —— Apple-cozy 重设计（Plan §E.4）
 * 实白卡 + 1rpx 边 + companion soft/text 状态 pill + Lucide 图标 */

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.page-title-group {
  flex: 1;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
  line-height: var(--lh-tight);
  letter-spacing: -0.01em;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: var(--lh-relaxed);
}

.add-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 22rpx;
  background: var(--bg);
  border: 2rpx solid var(--brand-soft);
  border-radius: var(--r-pill);
  color: var(--brand);
  font-size: 26rpx;
  font-weight: 600;
}

.add-btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--brand);
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.record-card {
  background: var(--bg);
  border-radius: 28rpx;
  padding: 24rpx;
  border: 2rpx solid var(--line);
  transition: transform 150ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 150ms;
}

.record-card:active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-1);
}

.record-card-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: var(--brand-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.record-body {
  flex: 1;
  min-width: 0;
}

.record-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.record-type {
  padding: 4rpx 12rpx;
  background: var(--brand-soft);
  color: var(--brand);
  border-radius: var(--r-pill);
  font-size: 22rpx;
  font-weight: 600;
}

/* 状态 pill —— 用 25% soft + 深色 text，不再是 8% 透明几乎看不见 */
.record-status {
  padding: 4rpx 12rpx;
  border-radius: var(--r-pill);
  background: var(--bg-soft);
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-dim);
}

.record-status.parsing,
.record-status.uploading {
  background: var(--amber-soft);
  color: var(--amber-text);
}

.record-status.parsed,
.record-status.completed {
  background: var(--mint-soft);
  color: var(--mint-text);
}

.record-status.failed,
.record-status.error {
  background: var(--red-soft);
  color: var(--red-text);
}

.record-diagnosis {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  line-height: var(--lh-normal);
  margin-bottom: 6rpx;
  letter-spacing: -0.01em;
}

.record-meta-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.record-meta {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.4;
}

.record-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--line);
}

.match-count {
  font-size: 26rpx;
  color: var(--brand);
  font-weight: 600;
}

.match-count.empty {
  color: var(--text-muted);
  font-weight: 400;
}

.gap-hint {
  font-size: 24rpx;
  color: var(--amber-text);
  font-weight: 600;
  padding: 4rpx 12rpx;
  background: var(--amber-soft);
  border-radius: var(--r-pill);
}

/* PRD-2026Q2 §P1-6：复购钩子条 —— 卡片内的「带行动」次级提示。
   icon + 文本一体；88rpx 触达高度（padding 16rpx 上下 + 文字行高 1.4 ≈ 56rpx 内容）。 */
.record-hook {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  background: var(--brand-soft);
  border-radius: 16rpx;
  transition: opacity 150ms ease-out;
}

.record-hook:active {
  opacity: 0.7;
}

.record-hook-text {
  font-size: 26rpx;
  color: var(--brand);
  font-weight: 600;
  line-height: 1.4;
  flex: 1;
}
