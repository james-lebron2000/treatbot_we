.page-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.page-title-group {
  flex: 1;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.page-subtitle {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

.add-btn {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 999rpx;
  color: #111827;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.05);
}

.add-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.record-card {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 30rpx;
  padding: 28rpx 26rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.05);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.record-type {
  padding: 10rpx 18rpx;
  background: rgba(37, 99, 235, 0.1);
  color: #1d4ed8;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.record-status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.06);
  font-size: 22rpx;
  font-weight: 600;
  color: #6b7280;
}

.record-status.parsing,
.record-status.uploading {
  background: rgba(217, 119, 6, 0.1);
  color: #b45309;
}

.record-status.parsed,
.record-status.completed {
  background: rgba(21, 128, 61, 0.1);
  color: #15803d;
}

.record-status.failed,
.record-status.error {
  background: rgba(185, 28, 28, 0.1);
  color: #b91c1c;
}

.record-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 18rpx;
}

.record-diagnosis {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.45;
}

.record-stage {
  font-size: 24rpx;
  color: #4b5563;
}

.record-date {
  font-size: 22rpx;
  color: #9ca3af;
}

.record-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(15, 23, 42, 0.06);
}

.record-footer-left {
  display: flex;
}

.match-count {
  font-size: 24rpx;
  color: #1d4ed8;
}

.gap-hint {
  font-size: 23rpx;
  color: #b45309;
  margin-left: 14rpx;
}

.arrow {
  font-size: 32rpx;
  color: #c0c6d0;
}
