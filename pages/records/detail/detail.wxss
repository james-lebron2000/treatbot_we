/* records/detail —— Plan §G token-swap polish
 * 「token 化但不重设计」：保留结构，仅替换硬编码颜色为 design tokens */

.container {
  padding: 24rpx 24rpx 160rpx;
}

.loading {
  padding: 80rpx 0;
  text-align: center;
  color: var(--text-dim);
  font-size: 30rpx;
}

/* 上传后的成功条 */
.upload-success-banner {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  background: var(--mint-soft);
  border: 2rpx solid var(--mint);
  border-radius: 24rpx;
  padding: 22rpx;
  margin-bottom: 24rpx;
}

.banner-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--mint);
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.banner-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.banner-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--mint-text);
}

.banner-subtitle {
  font-size: 26rpx;
  color: var(--mint-text);
  line-height: var(--lh-normal);
  opacity: 0.85;
}

/* 病情摘要卡 —— Landing 同款 .hero-shell radial 浅光替代 dark teal gradient */
.summary-card {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(ellipse 120% 80% at 20% 10%, var(--brand-soft) 0%, transparent 60%),
    radial-gradient(ellipse 80% 60% at 100% 100%, var(--mint-soft) 0%, transparent 50%),
    var(--bg);
  color: var(--text);
  border-radius: 28rpx;
  padding: 28rpx 26rpx;
  margin-bottom: 22rpx;
  border: 2rpx solid var(--line);
}

.summary-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
  position: relative;
  z-index: 1;
}

.summary-kicker {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 1rpx;
  font-weight: 600;
}

.summary-status {
  font-size: 22rpx;
  background: var(--bg-soft);
  color: var(--text-dim);
  border-radius: var(--r-pill);
  padding: 4rpx 14rpx;
  font-weight: 600;
}

.summary-status.parsed,
.summary-status.completed {
  background: var(--mint-soft);
  color: var(--mint-text);
}

.summary-status.parsing,
.summary-status.uploading {
  background: var(--amber-soft);
  color: var(--amber-text);
}

.summary-text {
  display: block;
  font-size: 30rpx;
  line-height: var(--lh-normal);
  font-weight: 600;
  color: var(--text);
  margin-bottom: 22rpx;
  position: relative;
  z-index: 1;
}

.completeness {
  display: flex;
  align-items: center;
  gap: 14rpx;
  position: relative;
  z-index: 1;
}

.completeness-label {
  font-size: 24rpx;
  color: var(--text-dim);
  flex-shrink: 0;
}

.completeness-bar {
  flex: 1;
  height: 10rpx;
  border-radius: var(--r-pill);
  background: var(--brand-soft);
  overflow: hidden;
}

.completeness-fill {
  height: 100%;
  background: var(--brand);
  border-radius: var(--r-pill);
  transition: width 0.4s ease-out;
}

.completeness-value {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--brand);
  flex-shrink: 0;
}

.missing-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 18rpx;
  padding: 14rpx 16rpx;
  background: var(--amber-soft);
  border-radius: 16rpx;
  position: relative;
  z-index: 1;
}

.missing-text {
  font-size: 26rpx;
  color: var(--amber-text);
  line-height: var(--lh-normal);
  flex: 1;
}

.missing-link {
  font-size: 26rpx;
  color: var(--amber-text);
  font-weight: 700;
  flex-shrink: 0;
}

/* 通用 record-section */
.record-section {
  background: var(--bg);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border: 2rpx solid var(--line);
}

.record-section-title {
  display: block;
  font-size: 26rpx;
  color: var(--text-dim);
  font-weight: 600;
  margin-bottom: 14rpx;
  letter-spacing: 0.5rpx;
}

.kv-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.kv {
  flex: 1 1 calc(50% - 7rpx);
  min-width: calc(50% - 7rpx);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 12rpx 16rpx;
  background: var(--bg-soft);
  border-radius: 14rpx;
}

.kv-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.kv-value {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
  line-height: var(--lh-normal);
}

.kv-value.highlight {
  color: var(--brand);
  font-weight: 700;
}

/* 基因 chip —— mint companion */
.gene-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.gene-chip {
  background: var(--mint-soft);
  border-radius: var(--r-pill);
  padding: 6rpx 18rpx;
}

.gene-chip-text {
  font-size: 24rpx;
  color: var(--mint-text);
  font-weight: 600;
}

/* 治疗 */
.treatment-summary {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.treatment-line,
.treatment-desc {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.treatment-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.treatment-value {
  font-size: 26rpx;
  color: var(--text);
  line-height: var(--lh-normal);
}

.treatment-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.treatment-chip {
  background: var(--lilac-soft);
  border-radius: var(--r-pill);
  padding: 6rpx 18rpx;
}

.treatment-chip text {
  font-size: 24rpx;
  color: var(--lilac-text);
  font-weight: 600;
}

/* 化验 */
.lab-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.lab-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  background: var(--bg-soft);
  border-radius: 14rpx;
}

.lab-name {
  font-size: 26rpx;
  color: var(--text-dim);
}

.lab-value-group {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.lab-value {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 700;
}

.lab-unit {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 匹配结果 */
.matches-section {
  background: var(--bg);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  border: 2rpx solid var(--line);
}

.matches-section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.matches-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.01em;
}

.matches-count {
  font-size: 22rpx;
  color: var(--brand);
  background: var(--brand-soft);
  padding: 4rpx 14rpx;
  border-radius: var(--r-pill);
  font-weight: 600;
}

.matches-count.loading-tag {
  background: var(--amber-soft);
  color: var(--amber-text);
}

.matches-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.match-card {
  background: var(--bg-soft);
  border-radius: 18rpx;
  padding: 18rpx;
  border: 2rpx solid var(--line);
}

.match-card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 10rpx;
}

.match-card-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.match-card-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  line-height: var(--lh-normal);
}

.match-card-code {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 600;
}

.match-score-badge {
  border-radius: 14rpx;
  padding: 6rpx 14rpx;
  text-align: center;
  background: var(--bg-soft);
  flex-shrink: 0;
}

.match-score-badge.level-high { background: var(--mint-soft); }
.match-score-badge.level-mid { background: var(--brand-soft); }
.match-score-badge.level-low { background: var(--amber-soft); }

.match-score-badge .score {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}

.match-score-badge.level-high .score { color: var(--mint-text); }
.match-score-badge.level-mid .score { color: var(--brand); }
.match-score-badge.level-low .score { color: var(--amber-text); }

.match-score-badge .label {
  display: block;
  font-size: 20rpx;
  color: var(--text-muted);
}

.match-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.tag {
  font-size: 22rpx;
  border-radius: var(--r-pill);
  padding: 4rpx 14rpx;
  line-height: 1.5;
  font-weight: 600;
}

.tag-level.level-high { background: var(--mint-soft); color: var(--mint-text); }
.tag-level.level-mid { background: var(--brand-soft); color: var(--brand); }
.tag-level.level-low { background: var(--amber-soft); color: var(--amber-text); }
.tag-primary { background: var(--lilac-soft); color: var(--lilac-text); }
.tag-warning { background: var(--amber-soft); color: var(--amber-text); }

.match-reason {
  display: block;
  font-size: 26rpx;
  color: var(--mint-text);
  background: var(--mint-soft);
  border-radius: 12rpx;
  padding: 10rpx 14rpx;
  margin-bottom: 8rpx;
  line-height: var(--lh-normal);
}

.match-meta {
  display: block;
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: var(--lh-relaxed);
}

.matches-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx 0;
}

.matches-empty-text {
  font-size: 28rpx;
  color: var(--text-dim);
}

.matches-empty-link {
  font-size: 28rpx;
  color: var(--brand);
  font-weight: 600;
}

.matches-cta {
  margin-top: 18rpx;
  padding: 18rpx 0;
  background: var(--brand);
  border-radius: 18rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
}

.matches-cta-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 底部固定操作 */
.footer-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 14rpx;
  padding: 18rpx 24rpx;
  background: var(--bg);
  border-top: 2rpx solid var(--line);
  z-index: 10;
}

.footer-secondary,
.footer-primary {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: var(--r-pill);
  font-size: 28rpx;
  font-weight: 600;
}

.footer-secondary {
  background: var(--bg);
  color: var(--brand);
  border: 2rpx solid var(--brand-soft);
}

.footer-primary {
  background: var(--brand);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: var(--text-dim);
  font-size: 28rpx;
}
