<view class="container">
  <view class="page-header">
    <view class="page-title-group">
      <text class="page-title">我的病历</text>
      <text class="page-subtitle">查看结构化结果、缺失项和对应试验入口。</text>
    </view>
    <view class="add-btn" bindtap="goToUpload">
      <text class="add-icon">+</text>
      <text>上传新病历</text>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>病历加载中...</text>
  </view>

  <view class="empty-state" wx:if="{{!loading && errorMessage}}">
    <text>{{errorMessage}}</text>
  </view>

  <view class="records-list" wx:if="{{!loading && !errorMessage && records.length > 0}}">
    <view class="record-card" wx:for="{{records}}" wx:key="id" bindtap="viewRecord" data-id="{{item.id}}">
      <view class="record-header">
        <view class="record-type">{{item.type}}</view>
        <view class="record-status {{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="record-content">
        <text class="record-diagnosis">诊断：{{item.diagnosis}}</text>
        <text class="record-stage">分期：{{item.stage}}</text>
        <text class="record-date">上传时间：{{item.uploadTime}}</text>
      </view>
      <view class="record-footer">
        <text class="match-count" wx:if="{{item.matchCount > 0}}">已匹配 {{item.matchCount}} 个试验</text>
        <text class="match-count" wx:else>暂无匹配结果</text>
        <text class="gap-hint" wx:if="{{item.missingCount > 0}}">待补 {{item.missingCount}} 项</text>
        <text class="arrow">→</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && !errorMessage && records.length === 0}}">
    <image src="/images/empty-records.png" mode="aspectFit"></image>
    <text>暂无病历记录</text>
    <button class="btn btn-primary mt-30" bindtap="goToUpload">立即上传</button>
  </view>
</view>
