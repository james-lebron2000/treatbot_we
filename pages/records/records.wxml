<view class="container">
  <view class="page-header">
    <view class="page-title-group">
      <text class="page-title">我的病历</text>
      <text class="page-subtitle">我们从病历里看到的信息，哪里不对直接改。您改过的就是对的。</text>
    </view>
    <view class="add-btn" bindtap="goToUpload">
      <icon name="plus" color="brand" size="32" strokeWidth="2.5" />
      <text class="add-btn-text">上传新病历</text>
    </view>
  </view>

  <!-- A 轨入口：看懂这个病 + 标准治疗 -->
  <view class="guideline-entry" bindtap="goToGuideline">
    <icon name="lightbulb" color="brand" size="36" />
    <view class="guideline-entry-body">
      <text class="guideline-entry-title">看懂这个病 · 标准治疗</text>
      <text class="guideline-entry-desc">对照指南，先了解规范治疗大概是什么</text>
    </view>
    <icon name="chevron-right" color="text-muted" size="32" />
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>马上好…</text>
  </view>

  <view class="empty-state" wx:if="{{!loading && errorMessage}}">
    <text>{{errorMessage}}</text>
  </view>

  <view class="records-list" wx:if="{{!loading && !errorMessage && records.length > 0}}">
    <view class="record-card" wx:for="{{records}}" wx:key="id" bindtap="viewRecord" bindlongpress="longPressRecord" data-id="{{item.id}}">
      <view class="record-card-main">
        <view class="record-icon">
          <icon name="clipboard-list" color="brand" size="44" />
        </view>
        <view class="record-body">
          <view class="record-header">
            <text class="record-type">{{item.type}}</text>
            <text class="record-status {{item.status}}">{{item.statusText}}</text>
          </view>
          <text class="record-diagnosis">{{item.diagnosis}}</text>
          <view class="record-meta-row">
            <text class="record-meta">分期 · {{item.stage}}</text>
            <text class="record-meta">{{item.uploadTime}}</text>
          </view>
        </view>
        <icon name="chevron-right" color="text-muted" size="32" />
      </view>
      <view class="record-footer">
        <text class="match-count" wx:if="{{item.matchCount > 0}}">为家人找到 {{item.matchCount}} 种新药</text>
        <text class="match-count empty" wx:else>暂未找到能用的新药</text>
        <text class="gap-hint" wx:if="{{item.missingCount > 0}}">待补 {{item.missingCount}} 项</text>
      </view>
      <!-- PRD-2026Q2 §P1-6：复购钩子 —— 病历过期或缺基因时给一个温和的复诊入口。
           颜色用 brand，与 CTA 同语义；catchtap 防止冒泡到卡片整体的 viewRecord。 -->
      <view wx:if="{{item.hookText}}" class="record-hook" catchtap="goToUpload">
        <icon name="plus" color="brand" size="28" strokeWidth="2.5" />
        <text class="record-hook-text">{{item.hookText}}</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && !errorMessage && records.length === 0}}">
    <image src="/images/empty-records.png" mode="aspectFit"></image>
    <text>暂无病历记录</text>
    <button class="btn btn-primary mt-30" bindtap="goToUpload">立即上传</button>
  </view>
  <help-fab />
</view>
