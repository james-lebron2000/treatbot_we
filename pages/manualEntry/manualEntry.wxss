/* PRD-2026Q2 §3.7：手动录入页骨架样式；细节样式日后再统一到 design tokens */
.container {
  padding: 24rpx 32rpx 120rpx;
  background: #F7FAFE;
  min-height: 100vh;
}

.hero {
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 36rpx;
  color: #0F2B57;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.hero-desc {
  font-size: 26rpx;
  color: #4B5B7A;
  line-height: 1.6;
}

.form-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(15, 43, 87, 0.05);
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  font-size: 28rpx;
  color: #0F2B57;
  margin-bottom: 8rpx;
}

/* U4：字段标签 + 「？」按钮一行排版 */
.field-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.field-label-row .field-label {
  margin-bottom: 0;
}

.field-help-btn {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: #E0ECFF;
  color: #1F5AC7;
  font-size: 24rpx;
  font-weight: 600;
}

/* U4：字段说明卡片 —— 浅蓝底 + 左侧 4rpx accent 边 */
.field-explainer {
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  background: #F0F6FF;
  border-left: 4rpx solid #1F5AC7;
  border-radius: 8rpx;
}

.explainer-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.explainer-tag {
  flex-shrink: 0;
  color: #1F5AC7;
  font-weight: 600;
  min-width: 96rpx;
}

.explainer-text {
  flex: 1;
  color: #2A3A5A;
}

.explainer-skip {
  margin-top: 8rpx;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #1F5AC7;
  text-align: center;
  border-top: 1rpx solid #D4E2F8;
}

.field-input {
  border: 1rpx solid #D4DEF0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #F9FBFE;
}

.field-hint {
  font-size: 24rpx;
  color: #7083A3;
  margin-top: 8rpx;
  line-height: 1.5;
}

.action-bar {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.btn {
  flex: 1;
  border-radius: 999rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  text-align: center;
}

.btn-default {
  background: #ffffff;
  color: #0F2B57;
  border: 1rpx solid #D4DEF0;
}

.btn-primary {
  background: #0F2B57;
  color: #ffffff;
}
