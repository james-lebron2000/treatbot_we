/* manualEntry —— Plan §G token-swap polish
 * 「token 化但不重设计」：保留结构，全部硬编码颜色替换为 design tokens */
.container {
  padding: 24rpx 32rpx 120rpx;
  background: var(--bg-soft);
  min-height: 100vh;
}

.hero {
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 44rpx;
  color: var(--text);
  font-weight: 700;
  margin-bottom: 8rpx;
  letter-spacing: -0.01em;
  line-height: var(--lh-tight);
}

.hero-desc {
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: var(--lh-relaxed);
}

.form-card {
  background: var(--bg);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 2rpx solid var(--line);
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  font-size: 30rpx;
  color: var(--text);
  font-weight: 600;
  margin-bottom: 8rpx;
}

/* U4：字段标签 + 「？」按钮一行排版 */
.field-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.field-label-row .field-label {
  margin-bottom: 0;
}

.field-help-btn {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 28rpx;
  font-weight: 700;
}

/* U4：字段说明卡片 —— brand-soft 底 */
.field-explainer {
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  background: var(--brand-soft);
  border-left: 4rpx solid var(--brand);
  border-radius: 12rpx;
}

.explainer-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  line-height: var(--lh-relaxed);
}

.explainer-tag {
  flex-shrink: 0;
  color: var(--brand);
  font-weight: 700;
  min-width: 96rpx;
}

.explainer-text {
  flex: 1;
  color: var(--text-dim);
}

.explainer-skip {
  margin-top: 8rpx;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: var(--brand);
  font-weight: 600;
  text-align: center;
  border-top: 2rpx solid var(--brand-soft);
}

.field-input {
  border: 2rpx solid var(--line);
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  font-size: 30rpx;
  color: var(--text);
  background: var(--bg);
}

.field-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  line-height: var(--lh-normal);
}

.action-bar {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.btn {
  flex: 1;
  border-radius: var(--r-pill);
  padding: 22rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.btn-default {
  background: var(--bg);
  color: var(--brand);
  border: 2rpx solid var(--brand-soft);
}

.btn-primary {
  background: var(--brand);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
}
