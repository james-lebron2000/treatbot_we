/** 公共样式 **/

/* 上传页面样式 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 24rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #fff8ef 0%, #f7fbff 56%, #eef7f3 100%);
  box-shadow: 0 10rpx 30rpx rgba(28, 63, 45, 0.06);
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 120rpx;
}

.step-dot {
  width: 58rpx;
  height: 58rpx;
  line-height: 58rpx;
  text-align: center;
  background: #f0efe9;
  color: #8b8b84;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
  border: 2rpx solid rgba(16, 24, 40, 0.08);
}

.step.active .step-dot {
  background: linear-gradient(135deg, #1b9c85 0%, #0f766e 100%);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 8rpx 18rpx rgba(15, 118, 110, 0.22);
}

.step-text {
  font-size: 24rpx;
  color: #8f8b84;
  letter-spacing: 1rpx;
}

.step.active .step-text {
  color: #11453d;
  font-weight: 600;
}

.step-line {
  width: 70rpx;
  height: 8rpx;
  background: rgba(17, 69, 61, 0.08);
  border-radius: 999rpx;
  margin: 0 20rpx;
  margin-bottom: 46rpx;
}

.step-line.active {
  background: linear-gradient(90deg, #1b9c85 0%, #e6a93d 100%);
}

/* 上传区域 */
.upload-area {
  background: #fff;
  border: 2rpx dashed #d9d9d9;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  display: block;
  font-size: 36rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.upload-hint {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.55;
}

/* 图片预览 */
.image-preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.preview-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-item image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.file-preview {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: #f7faff;
  border: 1rpx solid #d6e4ff;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 12rpx;
  box-sizing: border-box;
}

.file-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.file-name {
  font-size: 22rpx;
  color: #333;
  line-height: 1.3;
  text-align: center;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

.file-type {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #1677ff;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
}

.add-more {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 备注 */
.remark-section {
  margin-bottom: 30rpx;
}

.remark-input {
  width: 100%;
  height: 200rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.remark-count {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 处理中动画 */
.processing-section {
  padding: 24rpx 0 12rpx;
}

.processing-shell {
  background:
    radial-gradient(circle at top right, rgba(230, 169, 61, 0.18), transparent 28%),
    linear-gradient(165deg, #fffaf1 0%, #f8fcff 52%, #f2fbf6 100%);
  border-radius: 28rpx;
  padding: 38rpx 28rpx 30rpx;
  box-shadow: 0 18rpx 40rpx rgba(16, 24, 40, 0.08);
  border: 1rpx solid rgba(17, 69, 61, 0.08);
}

.processing-animation {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.animation-circle {
  width: 22rpx;
  height: 22rpx;
  background: linear-gradient(135deg, #1b9c85 0%, #e6a93d 100%);
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite both;
}

.animation-circle:nth-child(1) { animation-delay: -0.32s; }
.animation-circle:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.processing-title {
  font-size: 46rpx;
  font-weight: 700;
  color: #17312b;
  margin-bottom: 14rpx;
  line-height: 1.45;
  text-align: center;
}

.processing-desc {
  font-size: 28rpx;
  color: #5d675f;
  margin-bottom: 32rpx;
  line-height: 1.6;
  text-align: center;
}

.progress-section {
  margin-bottom: 28rpx;
}

.progress-panel {
  background: rgba(255, 255, 255, 0.7);
  border-radius: 22rpx;
  padding: 24rpx 24rpx 20rpx;
  border: 1rpx solid rgba(17, 69, 61, 0.06);
  margin-bottom: 24rpx;
}

.progress-panel-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.progress-kicker {
  font-size: 24rpx;
  color: #7a766e;
  letter-spacing: 2rpx;
}

.progress-number {
  font-size: 56rpx;
  line-height: 1;
  font-weight: 800;
  color: #11453d;
}

.progress-bar {
  position: relative;
  height: 18rpx;
  background: rgba(17, 69, 61, 0.1);
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 14rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1b9c85 0%, #24b4a3 48%, #e6a93d 100%);
  border-radius: 999rpx;
  transition: width 0.3s;
}

.progress-shine {
  position: absolute;
  top: 0;
  left: -30%;
  width: 30%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.55) 48%, transparent 100%);
  animation: progressShine 1.8s linear infinite;
}

@keyframes progressShine {
  from { left: -30%; }
  to { left: 130%; }
}

.progress-meta {
  font-size: 24rpx;
  color: #6a746e;
  line-height: 1.5;
}

.background-tip {
  margin-bottom: 28rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(18, 121, 107, 0.08);
  border: 1rpx solid rgba(18, 121, 107, 0.12);
  text-align: left;
}

.background-tip-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #11453d;
  margin-bottom: 10rpx;
}

.background-tip-text {
  display: block;
  font-size: 25rpx;
  color: #5d675f;
  line-height: 1.6;
}

.parse-steps {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 26rpx;
}

.parse-step-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 20rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(17, 69, 61, 0.08);
  transition: all 0.3s;
}

.parse-step-card.current {
  background: linear-gradient(135deg, rgba(27, 156, 133, 0.14) 0%, rgba(230, 169, 61, 0.12) 100%);
  border-color: rgba(27, 156, 133, 0.26);
  box-shadow: 0 12rpx 24rpx rgba(17, 69, 61, 0.08);
}

.parse-step-card.completed {
  background: rgba(242, 251, 246, 0.96);
  border-color: rgba(27, 156, 133, 0.18);
}

.parse-step-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f1efe8;
  color: #8c8578;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.parse-step-card.current .parse-step-badge {
  background: linear-gradient(135deg, #1b9c85 0%, #e6a93d 100%);
  color: #fff;
}

.parse-step-card.completed .parse-step-badge {
  background: #1b9c85;
  color: #fff;
}

.parse-step-main {
  flex: 1;
  text-align: left;
}

.parse-step-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.parse-step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #17312b;
}

.parse-step-state {
  font-size: 22rpx;
  line-height: 1;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #edf1ee;
  color: #77827b;
}

.parse-step-state.current {
  background: rgba(230, 169, 61, 0.18);
  color: #9a6200;
}

.parse-step-state.pending {
  background: #f2f1ec;
  color: #9b978d;
}

.parse-step-desc {
  display: block;
  font-size: 24rpx;
  color: #68736d;
  line-height: 1.6;
}

.background-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 34rpx;
}

.background-actions .btn {
  flex: 1;
}

/* 结果页面 */
.result-section {
  padding: 56rpx 28rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  background: #52c41a;
  color: #fff;
  border-radius: 50%;
  font-size: 60rpx;
  margin: 0 auto 30rpx;
}

.success-title {
  font-size: 42rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 14rpx;
}

.success-desc {
  font-size: 30rpx;
  color: #666;
}

.summary-card {
  background: linear-gradient(145deg, #f6ffed 0%, #f2fbff 100%);
  border: 1rpx solid #d6f5df;
  border-radius: 18rpx;
  padding: 26rpx;
  margin-bottom: 24rpx;
}

.summary-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #237804;
}

.summary-score {
  font-size: 40rpx;
  font-weight: 700;
  color: #1890ff;
}

.summary-progress-track {
  width: 100%;
  height: 18rpx;
  border-radius: 10rpx;
  background: #e8edf3;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.summary-progress-fill {
  height: 100%;
  border-radius: 10rpx;
  background: linear-gradient(90deg, #13c2c2 0%, #1890ff 100%);
}

.summary-metrics {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  flex-wrap: wrap;
}

.summary-metric {
  font-size: 28rpx;
  color: #333;
}

.summary-metric.warning {
  color: #d48806;
  font-weight: 600;
}

.summary-metric.success {
  color: #389e0d;
  font-weight: 600;
}

.summary-note {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #5c6b7a;
  line-height: 1.5;
}

.structured-sections {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 26rpx;
}

.structured-section-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
}

.structured-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.structured-section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
}

.structured-section-count {
  font-size: 25rpx;
  color: #1677ff;
  background: #e6f4ff;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.structured-field {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
  border-top: 1rpx solid #f5f5f5;
  padding: 16rpx 0;
}

.structured-field.first-row {
  border-top: none;
  padding-top: 0;
}

.structured-field.is-missing {
  background: #fffaf0;
  border-radius: 10rpx;
  padding: 14rpx 12rpx;
}

.structured-field-left {
  min-width: 230rpx;
  max-width: 360rpx;
}

.structured-field-label {
  font-size: 28rpx;
  color: #595959;
  line-height: 1.5;
}

.structured-field-tags {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.field-tag {
  font-size: 22rpx;
  line-height: 1;
  padding: 7rpx 10rpx;
  border-radius: 999rpx;
}

.field-tag.required {
  color: #0958d9;
  background: #e6f4ff;
}

.field-tag.missing {
  color: #ad6800;
  background: #fff2e8;
}

.structured-field-value {
  flex: 1;
  text-align: right;
  font-size: 29rpx;
  color: #1f1f1f;
  font-weight: 500;
  line-height: 1.5;
  word-break: break-all;
}

/* 提示 */
.tips-section {
  background: #e6f7ff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1890ff;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

/* 操作栏 */
.action-bar {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
}

.action-bar .btn {
  flex: 1;
  margin-bottom: 20rpx;
  height: 98rpx;
  font-size: 36rpx;
}

.btn.disabled {
  opacity: 0.5;
}

.upload-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.upload-desc {
  font-size: 30rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 28rpx;
}

.gap-section {
  background: #fff7e6;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.gap-title {
  font-size: 30rpx;
  color: #d46b08;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.gap-item {
  margin-bottom: 20rpx;
}

.gap-item:last-child {
  margin-bottom: 0;
}

.gap-label {
  font-size: 26rpx;
  color: #8c5a00;
  margin-bottom: 12rpx;
}

.gap-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.gap-option {
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid #ffd591;
  color: #ad6800;
  font-size: 24rpx;
}

.gap-option.active {
  background: #fa8c16;
  color: #fff;
  border-color: #fa8c16;
}

.gap-input {
  background: #fff;
  border: 1rpx solid #ffd591;
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
}

/* 细节字号统一 */
.add-text,
.remark-count,
.gap-option,
.file-name,
.file-type {
  font-size: 26rpx;
}
