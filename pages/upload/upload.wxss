/** 公共样式 **/

/* 上传页面样式 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: #e5e5e5;
  color: #999;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.step.active .step-dot {
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  color: #fff;
}

.step-text {
  font-size: 24rpx;
  color: #999;
}

.step.active .step-text {
  color: #1890ff;
  font-weight: 500;
}

.step-line {
  width: 80rpx;
  height: 2rpx;
  background: #e5e5e5;
  margin: 0 20rpx;
  margin-bottom: 40rpx;
}

.step-line.active {
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
}

/* 上传区域 */
.upload-area {
  background: #fff;
  border: 2rpx dashed #d9d9d9;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.upload-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 图片预览 */
.image-preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.preview-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-item image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
}

.add-more {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

/* 类型选择 */
.record-type-section {
  margin-bottom: 30rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.type-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-option {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.type-option.active {
  background: #e6f7ff;
  color: #1890ff;
  border: 2rpx solid #1890ff;
}

/* 备注 */
.remark-section {
  margin-bottom: 30rpx;
}

.remark-input {
  width: 100%;
  height: 200rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.remark-count {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 处理中动画 */
.processing-section {
  text-align: center;
  padding: 60rpx 40rpx;
}

.processing-animation {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.animation-circle {
  width: 24rpx;
  height: 24rpx;
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite both;
}

.animation-circle:nth-child(1) { animation-delay: -0.32s; }
.animation-circle:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.processing-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.processing-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.progress-section {
  margin-bottom: 40rpx;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890ff 0%, #36cfc9 100%);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1890ff;
}

.parse-steps {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.parse-step {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.parse-step.completed {
  color: #52c41a;
}

.parse-step.completed .step-icon {
  color: #52c41a;
}

/* 结果页面 */
.result-section {
  text-align: center;
  padding: 60rpx 40rpx;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  background: #52c41a;
  color: #fff;
  border-radius: 50%;
  font-size: 60rpx;
  margin: 0 auto 30rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.result-preview {
  background: #f6ffed;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  text-align: left;
}

.preview-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #52c41a;
  margin-bottom: 20rpx;
}

.preview-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.preview-item {
  display: flex;
}

.item-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666;
}

.item-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 提示 */
.tips-section {
  background: #e6f7ff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1890ff;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 操作栏 */
.action-bar {
  padding: 20rpx 0;
}

.action-bar .btn {
  margin-bottom: 20rpx;
}

.btn.disabled {
  opacity: 0.5;
}
