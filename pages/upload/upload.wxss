/** pages/upload/upload.wxss
 * Q3 视觉对齐 §E.2（Plan web-h5-cozy-gizmo V2）：
 *   - 配色：青绿 #1b9c85 / 琥珀 #e6a93d 全替为 var(--brand)；状态色用 *-text companion
 *   - 卡片：实白 + 1rpx solid var(--line) + 32rpx 圆角，删 glass morphism / backdrop-filter
 *   - Progress：实色 brand fill（去 3 色渐变）+ 慢速浅 shine
 *   - Track C-3 v2 进度模拟（线性 60s）逻辑保持不动 */

/* step indicator -------------------------------------------------------- */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-radius: 32rpx;       /* --r-lg */
  background: var(--bg);
  border: 2rpx solid var(--line);
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 120rpx;
}

.step-dot {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: var(--bg-soft);
  color: var(--text-muted);
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  border: 2rpx solid var(--line);
}

.step.active .step-dot {
  background: var(--brand);
  color: #fff;
  border-color: var(--brand);
}

.step-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

.step.active .step-text {
  color: var(--brand);
  font-weight: 600;
}

.step-line {
  width: 64rpx;
  height: 4rpx;
  background: var(--line);
  border-radius: 999rpx;
  margin: 0 16rpx 44rpx;
}

.step-line.active {
  background: var(--brand);
}

/* upload section ------------------------------------------------------- */
.upload-section {
  background: var(--bg);
  border: 2rpx solid var(--line);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.upload-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.upload-desc {
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.55;
  margin-bottom: 24rpx;
}

/* upload area --------------------------------------------------------- */
/* PRD-2026Q2 §P1-2：dashed 边色 brand-soft → brand。
   旧 brand-soft (#dbeafe) 在浅蓝 bg-soft 底色上几乎看不见虚线；
   实蓝边对比度 ≥ 4.5:1，符合 WCAG AA 老花镜可读性。 */
.upload-area {
  background: var(--bg-soft);
  border: 4rpx dashed var(--brand);
  border-radius: 32rpx;
  padding: 56rpx 32rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-text {
  display: block;
  font-size: 32rpx;
  color: var(--text);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.upload-hint {
  display: block;
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.55;
}

/* preview list -------------------------------------------------------- */
.image-preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.preview-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-item image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.file-preview {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  background: var(--bg);
  border: 2rpx solid var(--line);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 12rpx;
  box-sizing: border-box;
  gap: 8rpx;
}

.file-name {
  font-size: 24rpx;
  color: var(--text);
  line-height: 1.3;
  text-align: center;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

.file-type {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--brand);
  font-weight: 600;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: var(--red);
  color: #fff;
  border-radius: 50%;
  font-size: 30rpx;
}

.add-more {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 4rpx dashed var(--brand-soft);
  border-radius: 16rpx;
  background: var(--bg-soft);
  gap: 4rpx;
}

.add-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

/* remark section ------------------------------------------------------ */
.remark-section {
  margin-bottom: 24rpx;
}

.remark-input {
  width: 100%;
  height: 200rpx;
  background: var(--bg-soft);
  color: var(--text);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.remark-count {
  text-align: right;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* processing section -------------------------------------------------- */
.processing-section {
  padding: 24rpx 0 12rpx;
}

.processing-shell {
  background: var(--bg);
  border: 2rpx solid var(--line);
  border-radius: 32rpx;
  padding: 40rpx 28rpx 32rpx;
}

.processing-hero {
  text-align: center;
  margin-bottom: 32rpx;
}

.processing-animation {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.animation-circle {
  width: 20rpx;
  height: 20rpx;
  background: var(--brand);
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite both;
}

.animation-circle:nth-child(1) { animation-delay: -0.32s; }
.animation-circle:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.processing-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
  line-height: 1.45;
}

.processing-desc {
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: 1.6;
}

/* progress panel ------------------------------------------------------ */
.progress-panel {
  background: var(--bg-soft);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 2rpx solid var(--line);
  margin-bottom: 24rpx;
}

.progress-panel-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.progress-kicker {
  font-size: 26rpx;
  color: var(--text-dim);
  letter-spacing: 1rpx;
}

.progress-number {
  font-size: 48rpx;
  line-height: 1;
  font-weight: 800;
  color: var(--brand);
  letter-spacing: -1rpx;
}

.progress-bar {
  position: relative;
  height: 16rpx;
  background: var(--brand-soft);
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: var(--brand);            /* 实色，删 3 色渐变 */
  border-radius: 999rpx;
  transition: width 0.3s ease;
}

.progress-shine {
  position: absolute;
  top: 0;
  left: -30%;
  width: 30%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.45) 48%, transparent 100%);
  animation: progressShine 3s linear infinite;     /* 慢速浅 shine */
}

@keyframes progressShine {
  from { left: -30%; }
  to { left: 130%; }
}

.progress-meta {
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.5;
}

.progress-eta {
  display: block;
  font-size: 26rpx;
  color: var(--brand);
  font-weight: 600;
  margin-bottom: 4rpx;
}

/* background tip ------------------------------------------------------ */
/* Plan §Phase 3.3：文件名启发式占位卡 ——
   柔和 brand-soft 底，不抢主进度条焦点；点不动（无 bindtap）。
   chip 间距与 background-tip 同节奏，让 step 2 顶部有"在做事"的视觉暗示。 */
.placeholder-hint-card {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: var(--brand-soft);
  border: 2rpx solid transparent;
  text-align: left;
}

.placeholder-hint-kicker {
  display: block;
  font-size: 26rpx;
  color: var(--text-dim);
  margin-bottom: 12rpx;
}

.placeholder-hint-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.placeholder-hint-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid var(--brand);
}

.placeholder-hint-label {
  font-size: 26rpx;
  color: var(--brand);
  font-weight: 600;
}

.placeholder-hint-count {
  font-size: 24rpx;
  color: var(--brand);
  opacity: 0.7;
}

/* Plan §Phase 3.4：队列深度提示，副信息体积，不抢主进度条焦点 */
.placeholder-hint-queue {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.45;
}

.background-tip {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: var(--brand-soft);
  border: 2rpx solid transparent;
  text-align: left;
}

.background-tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--brand);
  margin-bottom: 8rpx;
}

.background-tip-text {
  display: block;
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.55;
}

/* parse step cards ---------------------------------------------------- */
.parse-steps {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.parse-step-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  background: var(--bg);
  border: 2rpx solid var(--line);
  transition: all 0.3s;
}

.parse-step-card.current {
  background: var(--brand-soft);
  border-color: var(--brand);
}

.parse-step-card.completed {
  background: var(--mint-soft);
  border-color: transparent;
}

.parse-step-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg-soft);
  color: var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.parse-step-card.current .parse-step-badge {
  background: var(--brand);
  color: #fff;
}

.parse-step-card.completed .parse-step-badge {
  background: var(--mint);
  color: #fff;
}

.parse-step-main {
  flex: 1;
  text-align: left;
}

.parse-step-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 4rpx;
}

.parse-step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.parse-step-state {
  font-size: 22rpx;
  line-height: 1;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: var(--mint-soft);
  color: var(--mint-text);
  font-weight: 600;
}

.parse-step-state.current {
  background: var(--brand-soft);
  color: var(--brand);
}

.parse-step-state.pending {
  background: var(--bg-soft);
  color: var(--text-muted);
}

.parse-step-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.55;
}

/* result section ----------------------------------------------------- */
.result-section {
  padding: 48rpx 24rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.success-icon {
  width: 112rpx;
  height: 112rpx;
  background: var(--mint);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12rpx;
}

.success-desc {
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: 1.55;
}

/* summary card ------------------------------------------------------- */
.summary-card {
  background: var(--bg);
  border: 2rpx solid var(--line);
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.summary-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.summary-score {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--brand);
}

.summary-progress-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: var(--brand-soft);
  overflow: hidden;
  margin-bottom: 16rpx;
}

.summary-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: var(--brand);
  transition: width 0.3s ease;
}

.summary-metrics {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  flex-wrap: wrap;
}

.summary-metric {
  font-size: 26rpx;
  color: var(--text-dim);
}

.summary-metric.warning {
  color: var(--amber-text);
  font-weight: 600;
}

.summary-metric.success {
  color: var(--mint-text);
  font-weight: 600;
}

.summary-note {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

/* structured sections ------------------------------------------------ */
.structured-sections {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.structured-section-card {
  background: var(--bg);
  border-radius: 32rpx;
  padding: 24rpx;
  border: 2rpx solid var(--line);
}

.structured-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.structured-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.structured-section-count {
  font-size: 22rpx;
  color: var(--brand);
  background: var(--brand-soft);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.structured-field {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
  border-top: 2rpx solid var(--line);
  padding: 16rpx 0;
}

.structured-field.first-row {
  border-top: none;
  padding-top: 0;
}

.structured-field.is-missing {
  background: var(--amber-soft);
  border-radius: 16rpx;
  padding: 14rpx 12rpx;
}

.structured-field-left {
  min-width: 220rpx;
  max-width: 360rpx;
}

.structured-field-label {
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: 1.5;
}

.structured-field-tags {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.field-tag {
  font-size: 20rpx;
  line-height: 1;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.field-tag.required {
  color: var(--brand);
  background: var(--brand-soft);
}

.field-tag.missing {
  color: var(--amber-text);
  background: var(--amber-soft);
}

.structured-field-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
  line-height: 1.5;
  word-break: break-all;
}

/* tips ---------------------------------------------------------------- */
.tips-section {
  background: var(--brand-soft);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.tips-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--brand);
  margin-bottom: 12rpx;
}

.tips-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--brand);
  line-height: 1;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tip-item {
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.55;
}

/* action bar ---------------------------------------------------------- */
.action-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
}

/* Track C-2（PRD-2026Q3）：第三步（结果页）的 action-bar 在 missingFields 较多时
   会被 gap-section 顶到屏外。改为 sticky 到底，并在背景上加微阴影区分 gap-section
   黄底，让用户随时能看到 CTA。 */
.result-section .action-bar {
  position: sticky;
  bottom: 0;
  margin-top: 24rpx;
  padding: 24rpx 0;
  background: var(--bg-soft);
  box-shadow: 0 -4rpx 12rpx rgba(15, 23, 42, 0.04);
  z-index: 10;
}

.action-bar .btn {
  flex: 1;
  margin-bottom: 0;
  height: 96rpx;
  font-size: 32rpx;
}

/* PRD-2026Q2 §P1-7：单 CTA 时让按钮占满宽度（不再需要 flex 1 与隐形伙伴分宽） */
.action-bar-single .btn {
  width: 100%;
}

.btn.disabled {
  opacity: 0.5;
}

/* gap section（缺字段补全） ------------------------------------------- */
/* PRD-2026Q2 §P1-1：amber 大底色拆细。
   旧：整块 amber-soft 底，让用户感觉「整段都坏了」。
   新：白底 + amber 描边（轻量提示），仅缺失字段（.is-missing）保留 amber 高亮。
   amber 的存在感缩小到「点状提示」级别。 */
.gap-section {
  background: var(--bg);
  border: 2rpx solid var(--amber-soft);
  border-radius: 32rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
}

.gap-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  gap: 24rpx;
  padding: 16rpx 20rpx;
  background: var(--amber-soft);
  border-radius: 20rpx;
}

.gap-header-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.gap-title {
  font-size: 30rpx;
  color: var(--amber-text);
  font-weight: 700;
}

.gap-subtitle {
  font-size: 22rpx;
  color: var(--amber-text);
  margin-top: 4rpx;
  opacity: 0.8;
}

.gap-progress {
  width: 180rpx;
  height: 10rpx;
  background: rgba(180, 83, 9, 0.18);
  border-radius: 999rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.gap-progress-fill {
  height: 100%;
  background: var(--amber);
  transition: width 240ms ease-out;
}

.gap-group-card {
  background: var(--bg);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid rgba(180, 83, 9, 0.16);
}

.gap-group-card:last-child {
  margin-bottom: 0;
}

.gap-group-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.gap-group-title {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
  flex: 1;
}

.gap-group-count {
  font-size: 22rpx;
  color: var(--amber-text);
  background: var(--amber-soft);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.gap-group-toggle {
  font-size: 22rpx;
  color: var(--amber);
  font-weight: 600;
}

.gap-group-body {
  margin-top: 16rpx;
}

.gap-item {
  margin-bottom: 16rpx;
}

.gap-item:last-child {
  margin-bottom: 0;
}

.gap-label-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.gap-label {
  font-size: 26rpx;
  color: var(--text-dim);
  font-weight: 600;
}

.gap-hint {
  font-size: 22rpx;
  color: var(--text-muted);
}

.gap-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.gap-option {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(180, 83, 9, 0.32);
  color: var(--amber-text);
  font-size: 24rpx;
  background: var(--bg);
  transition: background 150ms ease, color 150ms ease;
}

.gap-option.active {
  background: var(--amber);
  color: #fff;
  border-color: var(--amber);
}

.gap-input {
  background: var(--bg);
  border: 2rpx solid rgba(180, 83, 9, 0.32);
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: var(--text);
}

/* 细节字号统一 */
.add-text,
.remark-count,
.gap-option,
.file-name,
.file-type {
  font-size: 24rpx;
}

/* PRD-2026Q2 §3.7：上传主按钮下方的手动录入 ghost 入口 */
.manual-entry-link {
  margin-top: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--brand);
  text-decoration: underline;
}
