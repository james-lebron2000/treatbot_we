/* upload/status —— Plan §G token-swap polish
 * 「token 化但不重设计」：替换 Ant Design 调色板 (#1890ff/#36cfc9/#52c41a/#ff4d4f) */
.status-section {
  text-align: center;
  padding: 60rpx 40rpx;
}

.status-icon {
  margin-bottom: 30rpx;
}

.pulse-circle {
  width: 100rpx;
  height: 100rpx;
  background: var(--brand);
  border-radius: 50%;
  margin: 0 auto;
  animation: pulse 2s ease-in-out infinite;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
}

@keyframes pulse {
  0% { transform: scale(0.8); opacity: 0.5; }
  50% { transform: scale(1.2); opacity: 1; }
  100% { transform: scale(0.8); opacity: 0.5; }
}

.status-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
  letter-spacing: -0.01em;
}

.status-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-dim);
  margin-bottom: 40rpx;
  line-height: var(--lh-relaxed);
}

.progress-bar {
  margin-bottom: 40rpx;
}

.progress-track {
  height: 12rpx;
  background: var(--brand-soft);
  border-radius: var(--r-pill);
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: var(--brand);
  border-radius: var(--r-pill);
  transition: width 0.3s;
}

.progress-text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--brand);
}

.steps-list {
  display: flex;
  justify-content: center;
  gap: 30rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-icon {
  font-size: 36rpx;
  color: var(--text-muted);
}

.step-item.completed .step-icon {
  color: var(--mint-text);
}

.step-item.active .step-icon {
  color: var(--brand);
}

.step-name {
  font-size: 26rpx;
  color: var(--text-dim);
}

.step-item.completed .step-name,
.step-item.active .step-name {
  color: var(--text);
  font-weight: 600;
}

/* 结果区域 */
.result-section {
  padding: 40rpx;
}

.success-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.success-icon {
  width: 112rpx;
  height: 112rpx;
  background: var(--mint);
  border-radius: 50%;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.25);
}

.success-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12rpx;
  letter-spacing: -0.01em;
}

.success-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: var(--lh-relaxed);
}

.result-card {
  background: var(--mint-soft);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 40rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--mint-text);
  margin-bottom: 20rpx;
  letter-spacing: -0.01em;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--text-dim);
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.action-btns .btn {
  flex: 1;
}

/* 错误区域 */
.error-section {
  text-align: center;
  padding: 100rpx 40rpx;
}

.error-icon {
  width: 112rpx;
  height: 112rpx;
  background: var(--red);
  border-radius: 50%;
  margin: 0 auto 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(220, 38, 38, 0.25);
}

.error-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
  letter-spacing: -0.01em;
}

.error-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-dim);
  margin-bottom: 40rpx;
  line-height: var(--lh-relaxed);
}
