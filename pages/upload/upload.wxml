<view class="container">
  <view class="step-indicator">
    <view class="step {{currentStep >= 1 ? 'active' : ''}}">
      <view class="step-dot">1</view>
      <text class="step-text">交给我们</text>
    </view>
    <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
    <view class="step {{currentStep >= 2 ? 'active' : ''}}">
      <view class="step-dot">2</view>
      <text class="step-text">看懂病历</text>
    </view>
    <view class="step-line {{currentStep >= 3 ? 'active' : ''}}"></view>
    <view class="step {{currentStep >= 3 ? 'active' : ''}}">
      <view class="step-dot">3</view>
      <text class="step-text">核对并找新药</text>
    </view>
  </view>

  <view wx:if="{{currentStep === 1}}">
    <view class="upload-section">
      <view class="upload-title">把病历交给我们</view>
      <view class="upload-desc">拍照、相册、PDF 都行 —— 我们会自动识别类型。您的数据仅在自己的账户里，随时可以删除。</view>

      <!--
        PRD-2026Q4 followup（"无法上传"+ tap 冒泡修复）：
        旧版外层 .upload-area 整块绑 bindtap="chooseImage"，导致：
          1) 用户点缩略图想预览 → image 的 bindtap="previewFile" 冒泡到外层 → 又开一次选择器
          2) tempFiles 满 9 时 .add-more 已隐藏，但外层 bindtap 还在 → 仍能进 chooseImage，
             count 算成 0 进入 wx.chooseMedia，体验上"额满还能再点弹一次"。
        新版：外层移除 bindtap，由两个明确入口承担选择动作 ——
          (a) tempFiles 为空时显示的 .upload-placeholder
          (b) 非空时显示的 .add-more（自带 wx:if 容量门）
        预览区一律 catchtap，断绝冒泡链路。
      -->
      <view class="upload-area">
        <view
          wx:if="{{tempFiles.length === 0}}"
          class="upload-placeholder"
          bindtap="chooseImage"
        >
          <view class="upload-icon">
            <icon name="camera" color="brand" size="96" />
          </view>
          <text class="upload-text">点这里选文件</text>
          <text class="upload-hint">图片或 PDF 都行，可以从聊天记录选</text>
        </view>

        <view wx:else class="image-preview-list">
          <view class="preview-item" wx:for="{{tempFiles}}" wx:key="index">
            <image
              wx:if="{{item.fileType === 'image'}}"
              src="{{item.path}}"
              mode="aspectFill"
              catchtap="previewFile"
              data-index="{{index}}"
            ></image>
            <view
              wx:else
              class="file-preview"
              catchtap="previewFile"
              data-index="{{index}}"
            >
              <icon name="file-text" color="brand" size="48" />
              <text class="file-name">{{item.name}}</text>
              <text class="file-type">{{item.fileType === 'pdf' ? 'PDF' : '文件'}}</text>
            </view>
            <view class="delete-btn" catchtap="deleteImage" data-index="{{index}}">×</view>
          </view>
          <view class="add-more" catchtap="chooseImage" wx:if="{{tempFiles.length < maxUploadCount}}">
            <icon name="plus" color="text-muted" size="40" />
            <text class="add-text">添加</text>
          </view>
        </view>
      </view>

      <!-- PRD-2026Q2 §T2-5：placeholder 给具体例子，家属知道该写什么。
           旧版「最近的治疗方案、医生说过的话、最新检查等」抽象，家属看了不知道写啥；
           新版给 3 个真实场景，让用户照葫芦画瓢，提高填写率。 -->
      <view class="remark-section">
        <view class="section-label">想告诉我们什么？（选填）</view>
        <textarea
          class="remark-input"
          placeholder="{{remarkPlaceholder}}"
          maxlength="500"
          bindinput="onRemarkInput"
          value="{{remark}}"
        ></textarea>
        <view class="remark-count">{{remark.length}}/500</view>
      </view>
    </view>

    <view class="action-bar">
      <button
        class="btn btn-primary {{tempFiles.length === 0 ? 'disabled' : ''}}"
        bindtap="uploadFiles"
        disabled="{{tempFiles.length === 0 || uploading}}"
      >
        <!-- PRD-2026Q2 §3.7：主按钮走 shared copy.cta.upload / status.parsing -->
        {{uploading ? copy.status.parsing : copy.cta.upload}}
      </button>
      <!-- PRD-2026Q2 §3.7：手动录入入口（与 H5 MatchesView 的 manualEntry query 对齐，路由到 matches tab） -->
      <view class="manual-entry-link" bindtap="goToManualEntry">{{copy.cta.manualEntry}}</view>
    </view>
  </view>

  <view wx:if="{{currentStep === 2}}" class="processing-section">
    <view class="processing-shell">
      <view class="processing-hero">
        <view class="processing-animation">
          <view class="animation-circle"></view>
          <view class="animation-circle"></view>
          <view class="animation-circle"></view>
        </view>
        <view class="processing-title">正在帮您看懂这份病历</view>
        <view class="processing-desc">{{processingStatus}}</view>
      </view>

      <!-- Plan §Phase 3.3：文件名启发式占位卡 ——
           OCR 跑 30-90s，让用户在等待时立刻看到"已经知道您给的是什么类型"。
           这只是猜测；OCR 完成后跳到 step 3，这张卡随 currentStep 切换自动消失。 -->
      <view class="placeholder-hint-card" wx:if="{{placeholderHints.length > 0}}">
        <text class="placeholder-hint-kicker">已收到您的文件</text>
        <view class="placeholder-hint-list">
          <view class="placeholder-hint-chip" wx:for="{{placeholderHints}}" wx:key="label">
            <text class="placeholder-hint-label">{{item.label}}</text>
            <text class="placeholder-hint-count" wx:if="{{item.count > 1}}">×{{item.count}}</text>
          </view>
        </view>
        <!-- Plan §Phase 3.4：队列深度提示 —— 只在 queueAhead > 0 时显示 -->
        <text class="placeholder-hint-queue" wx:if="{{queueAhead > 0}}">前面还有 {{queueAhead}} 份在处理，请稍候</text>
      </view>

      <view class="progress-panel">
        <view class="progress-panel-head">
          <text class="progress-kicker">当前进度</text>
          <text class="progress-number">{{parseProgress}}%</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="{{parseProgressStyle}}"></view>
          <view class="progress-shine"></view>
        </view>
        <view class="progress-meta">
          <!-- Track C-3（PRD-2026Q3）：基于预期时长的 ETA 倒数，给用户「快好了」的体感 -->
          <text class="progress-eta" wx:if="{{etaText}}">{{etaText}}</text>
        </view>
      </view>

      <view class="parse-steps">
        <view
          class="parse-step-card {{parseStep > index ? 'completed' : ''}} {{parseStep === index ? 'current' : ''}}"
          wx:for="{{processSteps}}"
          wx:key="key"
          wx:for-item="step"
          wx:for-index="index"
        >
          <view class="parse-step-badge">
            <!-- PRD-2026Q2 §P0-5：完成态用 Lucide check 而非 Unicode ✓
                 （✓ 在跨厂商安卓上字形差异大，老花镜下可读性差） -->
            <icon wx:if="{{parseStep > index}}" name="check" color="white" size="28" strokeWidth="3" />
            <text wx:elif="{{parseStep === index}}" class="parse-step-badge-text">{{index + 1}}</text>
            <text wx:else class="parse-step-badge-text">{{index + 1}}</text>
          </view>
          <view class="parse-step-main">
            <view class="parse-step-top">
              <text class="parse-step-title">{{step.title}}</text>
              <text class="parse-step-state" wx:if="{{parseStep > index}}">已完成</text>
              <text class="parse-step-state current" wx:elif="{{parseStep === index}}">进行中</text>
              <text class="parse-step-state pending" wx:else>等待中</text>
            </view>
            <text class="parse-step-desc">{{step.desc}}</text>
          </view>
        </view>
      </view>

      <view class="background-tip">
        <text class="background-tip-title">不用一直等着</text>
        <text class="background-tip-text">看好后会自动跳到下一步，您可以放心等待。</text>
      </view>
    </view>
  </view>

  <view wx:if="{{currentStep === 3}}" class="result-section">
    <view class="result-header">
      <view class="success-icon">
        <icon name="check" color="white" size="56" strokeWidth="3" />
      </view>
      <view class="success-title">好了</view>
      <view class="success-desc">以下是我们从病历里看到的 —— 请您过一遍，哪里不对直接改。您改过的就是对的。</view>
    </view>

    <view class="summary-card">
      <view class="summary-header">
        <text class="summary-title">关键信息完整度</text>
        <text class="summary-score">{{structuredSummary.completeness}}%</text>
      </view>
      <view class="summary-progress-track">
        <view class="summary-progress-fill" style="{{summaryProgressStyle}}"></view>
      </view>
      <view class="summary-metrics">
        <text class="summary-metric">已填 {{structuredSummary.completedRequired}} / {{structuredSummary.requiredTotal}}</text>
        <text class="summary-metric warning" wx:if="{{structuredSummary.missingRequired > 0}}">再补 {{structuredSummary.missingRequired}} 项会更准</text>
        <text class="summary-metric success" wx:else>信息齐全</text>
      </view>
      <text class="summary-note">麻烦重点核对：诊断分期、ECOG、病理类型、基因、既往治疗、血液/肝肾功能、感染与妊娠状态</text>
    </view>

    <view class="structured-sections">
      <view class="structured-section-card" wx:for="{{parsedSections}}" wx:key="key" wx:for-item="section">
        <view class="structured-section-head">
          <text class="structured-section-title">{{section.title}}</text>
          <text class="structured-section-count">已填 {{section.filledCount}}/{{section.totalCount}}</text>
        </view>
        <view
          class="structured-field {{field.isMissing ? 'is-missing' : ''}} {{fieldIndex === 0 ? 'first-row' : ''}}"
          wx:for="{{section.fields}}"
          wx:key="key"
          wx:for-item="field"
          wx:for-index="fieldIndex"
        >
          <view class="structured-field-left">
            <text class="structured-field-label">{{field.label}}</text>
            <view class="structured-field-tags">
              <text class="field-tag required" wx:if="{{field.required}}">必填</text>
              <text class="field-tag missing" wx:if="{{field.isMissing}}">待补</text>
            </view>
          </view>
          <text class="structured-field-value">{{field.value}}</text>
        </view>
      </view>
    </view>

    <!-- Track C-2（PRD-2026Q3）：missingFields 多到 8+ 时一字排开会把主按钮推出屏。
         改为「头部进度条 + 按 GROUP_META 分组的折叠卡片」，默认只展开第一组（基本入组），
         其它组折叠让用户一眼看到底部 sticky CTA。 -->
    <view id="gapSection" class="gap-section" wx:if="{{missingFields.length > 0}}">
      <view class="gap-header">
        <view class="gap-header-left">
          <text class="gap-title">再补 {{gapSummary.totalMissing}} 项会更准</text>
          <text class="gap-subtitle">已补 {{gapSummary.filledNow}} / {{gapSummary.totalMissing}}</text>
        </view>
        <view class="gap-progress">
          <view class="gap-progress-fill" style="width: {{gapSummary.percent}}%;"></view>
        </view>
      </view>

      <view class="gap-group-card" wx:for="{{gapSections}}" wx:key="key" wx:for-item="section">
        <view class="gap-group-head" bindtap="toggleGapGroup" data-key="{{section.key}}">
          <text class="gap-group-title">{{section.title}}</text>
          <text class="gap-group-count">{{section.fields.length}} 项</text>
          <text class="gap-group-toggle">{{collapsedGroups[section.key] ? '展开' : '收起'}}</text>
        </view>
        <view wx:if="{{!collapsedGroups[section.key]}}" class="gap-group-body">
          <view class="gap-item" wx:for="{{section.fields}}" wx:key="key" wx:for-item="field">
            <view class="gap-label-row">
              <text class="gap-label">{{field.label}}</text>
              <text class="gap-hint" wx:if="{{field.hint}}">{{field.hint}}</text>
            </view>

            <view wx:if="{{field.type === 'select'}}" class="gap-options">
              <view
                class="gap-option {{parsedData[field.key] === option ? 'active' : ''}}"
                wx:for="{{field.options}}"
                wx:key="*this"
                wx:for-item="option"
                bindtap="selectGapOption"
                data-key="{{field.key}}"
                data-value="{{option}}"
              >
                {{option}}
              </view>
            </view>

            <input
              wx:elif="{{field.type === 'number'}}"
              class="gap-input"
              type="number"
              placeholder="请输入{{field.label}}"
              value="{{parsedData[field.key]}}"
              bindinput="onGapInput"
              data-key="{{field.key}}"
            />

            <input
              wx:else
              class="gap-input"
              placeholder="请输入{{field.label}}"
              value="{{parsedData[field.key]}}"
              bindinput="onGapInput"
              data-key="{{field.key}}"
            />
          </view>
        </view>
      </view>
    </view>

    <!-- PRD-2026Q2 §P1-7：双按钮简化为单 CTA。
         旧：「信息已补好（次）」+「看看为家人找到的新药（主）」—— 两个按钮做同一件事，
              「信息已补好」只是把字段保存到本地，对用户无感，反而分散注意力。
         新：单一 primary 按钮，文案随 missingFields 数量动态切换：
              missing > 0 → "再补 X 项更准 · 直接看新药"
              missing == 0 → "信息已齐 · 看找到的新药" -->
    <view class="action-bar action-bar-single">
      <button class="btn btn-primary" bindtap="startMatching" loading="{{submittingGap}}">{{primaryCtaText}}</button>
    </view>
  </view>

  <view class="tips-section">
    <view class="tips-title">
      <icon name="lightbulb" color="brand" size="32" />
      <text class="tips-title-text">小贴士</text>
    </view>
    <view class="tips-list">
      <text class="tip-item">• 照片清晰一点，我们看得更准</text>
      <text class="tip-item">• 出院小结、诊断证明最有帮助</text>
      <text class="tip-item">• 有基因检测报告，一并传上来更好</text>
      <text class="tip-item">• 您的数据仅在自己账户里 · 随时可带走或删除</text>
    </view>
  </view>
  <help-fab />
</view>
