<view class="container">
  <view class="step-indicator">
    <view class="step {{currentStep >= 1 ? 'active' : ''}}">
      <view class="step-dot">1</view>
      <text class="step-text">上传病历</text>
    </view>
    <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
    <view class="step {{currentStep >= 2 ? 'active' : ''}}">
      <view class="step-dot">2</view>
      <text class="step-text">AI解析</text>
    </view>
    <view class="step-line {{currentStep >= 3 ? 'active' : ''}}"></view>
    <view class="step {{currentStep >= 3 ? 'active' : ''}}">
      <view class="step-dot">3</view>
      <text class="step-text">完善并匹配</text>
    </view>
  </view>

  <view wx:if="{{currentStep === 1}}">
    <view class="upload-section">
      <view class="upload-title">请上传全部病历资料</view>
      <view class="upload-desc">系统会自动识别资料类型，无需手动选择</view>

      <view class="upload-area" bindtap="chooseImage">
        <view wx:if="{{tempFiles.length === 0}}" class="upload-placeholder">
          <text class="upload-icon">📷</text>
          <text class="upload-text">请选择上传方式</text>
          <text class="upload-hint">支持 JPG、PNG、PDF，支持从聊天记录选文件</text>
        </view>

        <view wx:else class="image-preview-list">
          <view class="preview-item" wx:for="{{tempFiles}}" wx:key="index">
            <image
              wx:if="{{item.fileType === 'image'}}"
              src="{{item.path}}"
              mode="aspectFill"
              bindtap="previewFile"
              data-index="{{index}}"
            ></image>
            <view
              wx:else
              class="file-preview"
              bindtap="previewFile"
              data-index="{{index}}"
            >
              <text class="file-icon">📄</text>
              <text class="file-name">{{item.name}}</text>
              <text class="file-type">{{item.fileType === 'pdf' ? 'PDF' : '文件'}}</text>
            </view>
            <view class="delete-btn" catchtap="deleteImage" data-index="{{index}}">×</view>
          </view>
          <view class="add-more" bindtap="chooseImage" wx:if="{{tempFiles.length < 9}}">
            <text class="add-icon">+</text>
            <text class="add-text">添加</text>
          </view>
        </view>
      </view>

      <view class="remark-section">
        <view class="section-label">备注（选填）</view>
        <textarea
          class="remark-input"
          placeholder="补充当前治疗方案或近期检查信息"
          maxlength="500"
          bindinput="onRemarkInput"
          value="{{remark}}"
        ></textarea>
        <view class="remark-count">{{remark.length}}/500</view>
      </view>
    </view>

    <view class="action-bar">
      <button
        class="btn btn-primary {{tempFiles.length === 0 ? 'disabled' : ''}}"
        bindtap="uploadFiles"
        disabled="{{tempFiles.length === 0 || uploading}}"
      >
        {{uploading ? '上传中...' : '上传资料'}}
      </button>
    </view>
  </view>

  <view wx:if="{{currentStep === 2}}" class="processing-section">
    <view class="processing-shell">
      <view class="processing-hero">
        <view class="processing-animation">
          <view class="animation-circle"></view>
          <view class="animation-circle"></view>
          <view class="animation-circle"></view>
        </view>
        <view class="processing-title">正在为您整理病历信息</view>
        <view class="processing-desc">{{processingStatus}}</view>
      </view>

      <view class="progress-panel">
        <view class="progress-panel-head">
          <text class="progress-kicker">当前进度</text>
          <text class="progress-number">{{parseProgress}}%</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="{{parseProgressStyle}}"></view>
          <view class="progress-shine"></view>
        </view>
        <view class="progress-meta">
          <text>上传后可切到其他页面，系统会继续后台整理</text>
        </view>
      </view>

      <view class="parse-steps">
        <view
          class="parse-step-card {{parseStep > index ? 'completed' : ''}} {{parseStep === index ? 'current' : ''}}"
          wx:for="{{processSteps}}"
          wx:key="key"
          wx:for-item="step"
          wx:for-index="index"
        >
          <view class="parse-step-badge">
            <text wx:if="{{parseStep > index}}" class="parse-step-badge-text">✓</text>
            <text wx:elif="{{parseStep === index}}" class="parse-step-badge-text">{{index + 1}}</text>
            <text wx:else class="parse-step-badge-text">{{index + 1}}</text>
          </view>
          <view class="parse-step-main">
            <view class="parse-step-top">
              <text class="parse-step-title">{{step.title}}</text>
              <text class="parse-step-state" wx:if="{{parseStep > index}}">已完成</text>
              <text class="parse-step-state current" wx:elif="{{parseStep === index}}">进行中</text>
              <text class="parse-step-state pending" wx:else>等待中</text>
            </view>
            <text class="parse-step-desc">{{step.desc}}</text>
          </view>
        </view>
      </view>

      <view class="background-tip">
        <text class="background-tip-title">后台会自动继续整理</text>
        <text class="background-tip-text">完成后会自动写入病历结果，并提前准备匹配结果。你不必停留在这个界面等待。</text>
      </view>

      <view class="background-actions">
        <button class="btn btn-default" bindtap="goToRecords">去看病历列表</button>
        <button class="btn btn-primary" bindtap="goToMatchesPage">稍后看匹配</button>
      </view>
    </view>
  </view>

  <view wx:if="{{currentStep === 3}}" class="result-section">
    <view class="result-header">
      <view class="success-icon">✓</view>
      <view class="success-title">解析完成</view>
      <view class="success-desc">病历关键信息已提取，补全后可提升匹配准确率</view>
    </view>

    <view class="summary-card">
      <view class="summary-header">
        <text class="summary-title">关键入组信息完整度</text>
        <text class="summary-score">{{structuredSummary.completeness}}%</text>
      </view>
      <view class="summary-progress-track">
        <view class="summary-progress-fill" style="{{summaryProgressStyle}}"></view>
      </view>
      <view class="summary-metrics">
        <text class="summary-metric">必填已完成 {{structuredSummary.completedRequired}} / {{structuredSummary.requiredTotal}}</text>
        <text class="summary-metric warning" wx:if="{{structuredSummary.missingRequired > 0}}">仍缺 {{structuredSummary.missingRequired}} 项</text>
        <text class="summary-metric success" wx:else>必填信息齐全</text>
      </view>
      <text class="summary-note">重点核对：诊断分期、ECOG、病理类型、基因、既往治疗、血液/肝肾功能、感染与妊娠状态</text>
    </view>

    <view class="structured-sections">
      <view class="structured-section-card" wx:for="{{parsedSections}}" wx:key="key" wx:for-item="section">
        <view class="structured-section-head">
          <text class="structured-section-title">{{section.title}}</text>
          <text class="structured-section-count">{{section.filledCount}}/{{section.totalCount}} 已填</text>
        </view>
        <view
          class="structured-field {{field.isMissing ? 'is-missing' : ''}} {{fieldIndex === 0 ? 'first-row' : ''}}"
          wx:for="{{section.fields}}"
          wx:key="key"
          wx:for-item="field"
          wx:for-index="fieldIndex"
        >
          <view class="structured-field-left">
            <text class="structured-field-label">{{field.label}}</text>
            <view class="structured-field-tags">
              <text class="field-tag required" wx:if="{{field.required}}">必填</text>
              <text class="field-tag missing" wx:if="{{field.isMissing}}">待补</text>
            </view>
          </view>
          <text class="structured-field-value">{{field.value}}</text>
        </view>
      </view>
    </view>

    <view id="gapSection" class="gap-section" wx:if="{{missingFields.length > 0}}">
      <view class="gap-title">请补全关键字段（{{missingFields.length}}项）</view>
      <view class="gap-item" wx:for="{{missingFields}}" wx:key="key" wx:for-item="field">
        <view class="gap-label">{{field.label}}</view>

        <view wx:if="{{field.type === 'select'}}" class="gap-options">
          <view
            class="gap-option {{field.currentValue === option ? 'active' : ''}}"
            wx:for="{{field.options}}"
            wx:key="*this"
            wx:for-item="option"
            bindtap="selectGapOption"
            data-key="{{field.key}}"
            data-value="{{option}}"
          >
            {{option}}
          </view>
        </view>

        <input
          wx:elif="{{field.type === 'number'}}"
          class="gap-input"
          type="number"
          placeholder="请输入{{field.label}}"
          value="{{field.currentValue}}"
          bindinput="onGapInput"
          data-key="{{field.key}}"
        />

        <input
          wx:else
          class="gap-input"
          placeholder="请输入{{field.label}}"
          value="{{field.currentValue}}"
          bindinput="onGapInput"
          data-key="{{field.key}}"
        />
      </view>
    </view>

    <view class="action-bar">
      <button class="btn btn-default" bindtap="editResult">确认补充完成</button>
      <button class="btn btn-primary" bindtap="startMatching" loading="{{submittingGap}}">开始匹配</button>
    </view>
  </view>

  <view class="tips-section">
    <view class="tips-title">💡 上传小贴士</view>
    <view class="tips-list">
      <text class="tip-item">• 确保照片清晰，文字可辨认</text>
      <text class="tip-item">• 建议上传完整的出院小结或诊断证明</text>
      <text class="tip-item">• 如有基因检测报告，请一并上传</text>
      <text class="tip-item">• 所有资料仅用于试验匹配，严格保密</text>
    </view>
  </view>
</view>
