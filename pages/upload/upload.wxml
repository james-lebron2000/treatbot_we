<!--pages/upload/upload.wxml-->
<view class="container">
  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view class="step {{currentStep >= 1 ? 'active' : ''}}">
      <view class="step-dot">1</view>
      <text class="step-text">上传病历</text>
    </view>
    <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
    <view class="step {{currentStep >= 2 ? 'active' : ''}}">
      <view class="step-dot">2</view>
      <text class="step-text">AI解析</text>
    </view>
    <view class="step-line {{currentStep >= 3 ? 'active' : ''}}"></view>
    <view class="step {{currentStep >= 3 ? 'active' : ''}}">
      <view class="step-dot">3</view>
      <text class="step-text">匹配试验</text>
    </view>
  </view>

  <!-- 步骤1: 上传病历 -->
  <view wx:if="{{currentStep === 1}}">
    <view class="upload-section">
      <view class="upload-title">请选择病历资料</view>
      <view class="upload-desc">支持出院小结、病理报告、影像报告、基因检测等</view>

      <!-- 上传区域 -->
      <view class="upload-area" bindtap="chooseImage">
        <view wx:if="{{tempFiles.length === 0}}" class="upload-placeholder">
          <text class="upload-icon">📷</text>
          <text class="upload-text">点击拍照或从相册选择</text>
          <text class="upload-hint">支持 JPG、PNG 格式，单张不超过10MB（每次仅 1 张）</text>
        </view>
        
        <!-- 已选图片预览 -->
        <view wx:else class="image-preview-list">
          <view class="preview-item" wx:for="{{tempFiles}}" wx:key="index">
            <image src="{{item.path}}" mode="aspectFill" bindtap="previewImage" data-index="{{index}}"></image>
            <view class="delete-btn" catchtap="deleteImage" data-index="{{index}}">×</view>
          </view>
          <view class="add-more" bindtap="chooseImage" wx:if="{{tempFiles.length < maxFileCount}}">
            <text class="add-icon">+</text>
            <text class="add-text">添加</text>
          </view>
        </view>
      </view>

      <!-- 病历类型选择 -->
      <view class="record-type-section">
        <view class="section-label">病历类型</view>
        <view class="type-options">
          <view class="type-option {{selectedType === item ? 'active' : ''}}" 
                wx:for="{{recordTypes}}" 
                wx:key="*this"
                bindtap="selectType"
                data-type="{{item}}">
            {{item}}
          </view>
        </view>
      </view>

      <!-- 备注 -->
      <view class="remark-section">
        <view class="section-label">备注（选填）</view>
        <textarea class="remark-input" 
                  placeholder="请补充说明病历情况，如：最新检查结果、当前治疗方案等"
                  maxlength="500"
                  bindinput="onRemarkInput"
                  value="{{remark}}"></textarea>
        <view class="remark-count">{{remark.length}}/500</view>
      </view>
    </view>

    <!-- 上传按钮 -->
    <view class="action-bar">
      <button class="btn btn-primary {{tempFiles.length === 0 ? 'disabled' : ''}}" 
              bindtap="uploadFiles"
              disabled="{{tempFiles.length === 0 || uploading}}">
        {{uploading ? '上传中...' : '开始上传'}}
      </button>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tips-section">
    <view class="tips-title">💡 上传小贴士</view>
    <view class="tips-list">
      <text class="tip-item">• 确保照片清晰，文字可辨认</text>
      <text class="tip-item">• 每次上传 1 张病历图片，可重复上传</text>
      <text class="tip-item">• 如有基因检测报告，请一并上传</text>
      <text class="tip-item">• 所有资料仅用于试验匹配，严格保密</text>
    </view>
  </view>
</view>
