/* profile/consent —— Plan §G token-swap polish */
.container {
  padding: 32rpx 24rpx 64rpx;
  background: var(--bg-soft);
  min-height: 100vh;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.01em;
  line-height: var(--lh-tight);
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: var(--lh-relaxed);
}

.state-card {
  margin-top: 32rpx;
  padding: 32rpx;
  background: var(--bg);
  border-radius: 24rpx;
  border: 2rpx solid var(--line);
  text-align: center;
  font-size: 28rpx;
  color: var(--text-dim);
}

.state-card.error {
  color: var(--red-text);
  background: var(--red-soft);
  border-color: transparent;
}

.state-card.empty {
  color: var(--text-muted);
  line-height: var(--lh-relaxed);
}

.consent-list {
  margin-top: 16rpx;
}

.consent-item {
  background: var(--bg);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid var(--line);
}

.consent-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.consent-row.meta {
  margin-top: 12rpx;
}

.consent-scope {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.consent-version {
  font-size: 24rpx;
  color: var(--brand);
  background: var(--brand-soft);
  padding: 4rpx 14rpx;
  border-radius: var(--r-pill);
  font-weight: 600;
}

.consent-time {
  font-size: 24rpx;
  color: var(--text-muted);
}
