.container {
  padding: 32rpx 24rpx 64rpx;
  background: #f7f8fa;
  min-height: 100vh;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  color: #666;
}

.state-card {
  margin-top: 32rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  text-align: center;
  font-size: 36rpx;
  color: #888;
}

.state-card.error {
  color: #d93025;
}

.state-card.empty {
  color: #555;
  line-height: 1.6;
}

.consent-list {
  margin-top: 16rpx;
}

.consent-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.consent-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.consent-row.meta {
  margin-top: 12rpx;
}

.consent-scope {
  font-size: 38rpx;
  font-weight: 600;
  color: #222;
}

.consent-version {
  font-size: 32rpx;
  color: #888;
  background: #f0f1f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.consent-time {
  font-size: 32rpx;
  color: #888;
}
