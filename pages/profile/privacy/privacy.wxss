/* profile/privacy —— Plan §G token-swap polish */
.card {
  background: var(--bg);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
  border: 2rpx solid var(--line);
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 14rpx;
  letter-spacing: -0.01em;
}

.desc {
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: var(--lh-relaxed);
  margin-bottom: 12rpx;
}

.desc:last-child {
  margin-bottom: 0;
}
