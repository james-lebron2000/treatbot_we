/* profile 页 —— Apple-cozy 重设计（Plan §E.5）
 * 重灾区：用户卡 dark-blue gradient → Landing 同款 .hero-shell radial 浅光
 * 9 个中文字符假 icon → Lucide SVG */

/* 用户卡：复用 .hero-shell 基底，仅做 padding 微调 */
.user-card.hero-shell {
  padding: 32rpx 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.user-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  position: relative;
  z-index: 1;
}

.identity-badge {
  padding: 8rpx 18rpx;
  border-radius: var(--r-pill);
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.user-card-main {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg);
  margin-right: 24rpx;
  border: 4rpx solid var(--bg);
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
  line-height: var(--lh-tight);
  letter-spacing: -0.01em;
}

.user-note {
  display: block;
  font-size: 26rpx;
  line-height: var(--lh-relaxed);
  color: var(--text-dim);
}

/* 数愈健康承诺卡 —— mint 系 */
.privacy-promise-card {
  background: var(--mint-soft);
  border-radius: 24rpx;
  padding: 24rpx 26rpx;
  margin-bottom: 24rpx;
}

.privacy-promise-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.privacy-promise-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--mint-text);
  letter-spacing: -0.01em;
}

.privacy-promise-bullets {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.privacy-promise-bullet {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.privacy-promise-bullet-text {
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: var(--lh-normal);
}

.privacy-promise-link {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 16rpx;
}

.privacy-promise-link-text {
  font-size: 28rpx;
  color: var(--brand);
  font-weight: 600;
}

/* Stats grid —— 大数字 brand 色，紧凑 3 列 */
.stats-grid {
  display: flex;
  gap: 14rpx;
  margin-bottom: 32rpx;
}

.stats-item {
  flex: 1;
  text-align: center;
  background: var(--bg);
  border-radius: 28rpx;
  padding: 28rpx 14rpx;
  border: 2rpx solid var(--line);
  transition: transform 150ms cubic-bezier(0.4, 0, 0.2, 1);
}

.stats-item:active {
  transform: translateY(-2rpx);
}

/* PRD-2026Q2 §P0-1：与首页 stat-number 同步，数字色 → var(--text)，
   让 brand 蓝在 profile 内只用于 CTA 与 menu icon。 */
.stats-num {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4rpx;
  line-height: 1;
  letter-spacing: -0.01em;
}

.stats-label {
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: var(--lh-normal);
}

/* Menu sections */
.menu-section {
  margin-bottom: 32rpx;
}

.menu-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 6rpx;
  line-height: var(--lh-tight);
  letter-spacing: -0.01em;
}

.menu-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: var(--lh-relaxed);
  margin-bottom: 16rpx;
}

.menu-list {
  background: var(--bg);
  border-radius: 24rpx;
  overflow: hidden;
  border: 2rpx solid var(--line);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 22rpx 22rpx;
  border-bottom: 2rpx solid var(--line);
  transition: background 150ms ease-out;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg-soft);
}

/* 图标徽章 —— 用 *-soft 底，对应色 Lucide 描线在内 */
.menu-icon {
  width: 72rpx;
  height: 72rpx;
  margin-right: 18rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-brand {
  background: var(--brand-soft);
}

.menu-icon-mint {
  background: var(--mint-soft);
}

.menu-icon-lilac {
  background: var(--lilac-soft);
}

.menu-icon-amber {
  background: var(--amber-soft);
}

.menu-icon-red {
  background: var(--red-soft);
}

.menu-text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
}

.menu-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  line-height: var(--lh-normal);
}

.menu-meta {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: var(--lh-normal);
}

/* PRD-2026Q2 §T2-3：拆为「价值文案 + 版本号」上下两行
   - tagline：主色调（text-dim）+ 26rpx，告诉用户「这是个什么 app」
   - build：弱化（text-muted）+ 22rpx，只给开发者看的版本号 */
.version-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 32rpx 0 40rpx;
  text-align: center;
}

.version-tagline {
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.5;
  letter-spacing: 0.2rpx;
}

.version-build {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.4;
  letter-spacing: 0.4rpx;
}
