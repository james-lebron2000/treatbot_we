.user-card {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.18), transparent 32%),
    linear-gradient(145deg, #0f2b57 0%, #163a73 52%, #255493 100%);
  border-radius: 34rpx;
  padding: 28rpx 26rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 26rpx 48rpx rgba(15, 43, 87, 0.22);
}

.user-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.identity-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.user-card-main {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.82);
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.18);
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-phone {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.88);
  margin-bottom: 8rpx;
}

.user-note {
  display: block;
  font-size: 23rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.68);
}

.edit-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.16);
  border-radius: 999rpx;
  color: #fff;
  font-size: 25rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.stats-grid {
  display: flex;
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.stats-item {
  flex: 1;
  text-align: center;
  background: rgba(255, 255, 255, 0.88);
  border-radius: 28rpx;
  padding: 24rpx 14rpx;
  border: 1rpx solid rgba(15, 43, 87, 0.07);
  box-shadow: 0 16rpx 32rpx rgba(15, 43, 87, 0.06);
}

.stats-kicker {
  display: block;
  margin-bottom: 8rpx;
  font-size: 20rpx;
  letter-spacing: 1.6rpx;
  color: #8da0bf;
}

.stats-num {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  color: #0f2b57;
  margin-bottom: 6rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #516783;
}

.menu-section {
  margin-bottom: 30rpx;
}

.menu-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #12233d;
  margin-bottom: 8rpx;
}

.menu-subtitle {
  display: block;
  font-size: 22rpx;
  color: #7b8faa;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.menu-list {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(15, 43, 87, 0.06);
  box-shadow: 0 18rpx 36rpx rgba(15, 43, 87, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 26rpx 24rpx;
  border-bottom: 1rpx solid rgba(15, 43, 87, 0.06);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 66rpx;
  height: 66rpx;
  margin-right: 18rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, rgba(15, 43, 87, 0.08) 0%, rgba(31, 77, 143, 0.12) 100%);
  color: #0f2b57;
  font-size: 26rpx;
  font-weight: 700;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #12233d;
}

.menu-meta {
  font-size: 22rpx;
  color: #7b8faa;
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 34rpx;
  color: #9eb0c9;
}

.version-info {
  text-align: center;
  padding: 22rpx 0 34rpx;
  color: #8ca0bb;
  font-size: 22rpx;
  letter-spacing: 0.8rpx;
}
