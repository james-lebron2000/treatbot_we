/* profile/applications —— Plan §G token-swap polish */
.records-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.record-card {
  background: var(--bg);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 2rpx solid var(--line);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
  gap: 16rpx;
}

.trial-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  line-height: var(--lh-normal);
  letter-spacing: -0.01em;
}

.status {
  color: var(--brand);
  font-size: 24rpx;
  font-weight: 600;
  background: var(--brand-soft);
  padding: 4rpx 14rpx;
  border-radius: var(--r-pill);
}

.institution,
.apply-time {
  display: block;
  color: var(--text-dim);
  font-size: 26rpx;
  line-height: var(--lh-relaxed);
}
