<view class="container">
  <view class="user-card">
    <view class="user-card-top">
      <view class="identity-badge">ACCOUNT</view>
    </view>
    <view class="user-card-main">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickName || '微信用户'}}</text>
        <text class="user-note">病历和匹配结果按当前微信账号隔离；手机号仅在报名时按需填写。</text>
      </view>
    </view>
  </view>

  <view class="stats-grid">
    <view class="stats-item" bindtap="goToRecords">
      <text class="stats-kicker">Records</text>
      <text class="stats-num">{{stats.records}}</text>
      <text class="stats-label">病历</text>
    </view>
    <view class="stats-item" bindtap="goToMatches">
      <text class="stats-kicker">Matches</text>
      <text class="stats-num">{{stats.matches}}</text>
      <text class="stats-label">匹配</text>
    </view>
    <view class="stats-item" bindtap="goToApplications">
      <text class="stats-kicker">Applies</text>
      <text class="stats-num">{{stats.applications}}</text>
      <text class="stats-label">报名</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">我的服务</view>
    <view class="menu-subtitle">查看病历、匹配结果和报名进度。</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToRecords">
        <view class="menu-icon">档</view>
        <text class="menu-text">我的病历</text>
        <text class="menu-meta">结构化记录</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToMatches">
        <view class="menu-icon">筛</view>
        <text class="menu-text">匹配记录</text>
        <text class="menu-meta">试验建议</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToApplications">
        <view class="menu-icon">报</view>
        <text class="menu-text">报名记录</text>
        <text class="menu-meta">跟进状态</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">设置</view>
    <view class="menu-subtitle">联系支持、查看机构信息与隐私说明。</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="contactSupport">
        <view class="menu-icon">联</view>
        <text class="menu-text">联系客服</text>
        <text class="menu-meta">工作时间</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="aboutUs">
        <view class="menu-icon">介</view>
        <text class="menu-text">关于我们</text>
        <text class="menu-meta">项目介绍</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="showPrivacyPolicy">
        <view class="menu-icon">隐</view>
        <text class="menu-text">隐私政策</text>
        <text class="menu-meta">数据说明</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="version-info">
    <text>Treatbot Clinical Matching · v1.1.0</text>
  </view>
</view>
