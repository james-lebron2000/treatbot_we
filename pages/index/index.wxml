<view class="container">
  <!-- PRD-2026Q3 §U5：首屏期望管理 banner —— 30 秒了解我们；点过「我看过了」就不再展示
       Q3 视觉对齐 §E.1：用 .card baseline + .pill-brand eyebrow + Lucide 图标徽章 -->
  <view class="onboarding-banner card" wx:if="{{!onboardingSeen}}">
    <view class="onboarding-banner-head">
      <text class="pill pill-brand">30 秒了解</text>
      <view class="onboarding-banner-toggle" bindtap="toggleOnboarding">
        <text>{{ onboardingExpanded ? '收起' : '展开' }}</text>
      </view>
    </view>
    <text class="onboarding-banner-title">{{ onboarding.title }}</text>
    <view class="onboarding-banner-body" wx:if="{{onboardingExpanded}}">
      <view class="onboarding-step" wx:for="{{onboarding.steps}}" wx:key="icon">
        <view class="onboarding-step-icon">{{index + 1}}</view>
        <view class="onboarding-step-body">
          <text class="onboarding-step-title">{{item.title}}</text>
          <text class="onboarding-step-text">{{item.body}}</text>
        </view>
      </view>
      <view class="onboarding-promise">{{onboarding.promise}}</view>
      <view class="onboarding-actions">
        <view class="btn btn-primary onboarding-cta-primary" bindtap="dismissOnboarding">{{onboarding.ctaPrimary}}</view>
        <view class="btn btn-ghost onboarding-cta-secondary" bindtap="dismissOnboarding">{{onboarding.ctaSecondary}}</view>
      </view>
    </view>
  </view>

  <!-- Q3 视觉对齐 §E.1：Hero 改用 .hero-shell（Landing 同款 radial 浅光） -->
  <view class="hero-section hero-shell">
    <view class="hero-content">
      <!-- PRD-2026Q2 §P0-6：用 view 而非 text 承载 pill 样式
           （text 元素在 WeChat 下 padding/inline-flex 表现不稳，导致 pill 高度被压扁） -->
      <!-- PRD-2026Q3 §UI-Audit-R2 §R2-1：eyebrow 措辞回到家属可读 ——
           「临床研究入组匹配」太 B2B 干硬，「用药全程免费」单开「免费」承诺过强。
           折中："帮家属找能用的新药" 描述事实功能，正面但不夸大。 -->
      <view class="hero-eyebrow"><text>数愈健康 · 帮家属找能用的新药</text></view>
      <text class="hero-title">让每一份病历</text>
      <text class="hero-title">都找到<text class="accent">能用的新药</text></text>
      <!-- PRD-2026Q3 §UI-Audit-R1 §P0-9 + R2 §R2-LLP-5：拆为两行 + 进一步缩短 ——
           原 41 字 → R1 26 字 → R2 18 字。第一行说价值，第二行说承诺。 -->
      <text class="hero-subtitle">我们帮您看懂病历，找到能免费用上的新药。</text>
      <text class="hero-subtitle hero-subtitle-secondary">数据只在您自己的账户里，随时可带走。</text>
    </view>
    <image class="hero-image" src="/images/hero-doctor.png" mode="aspectFit"></image>
  </view>

  <!-- PRD-2026Q2 §P0-1：数字降为中性色（不抢主 CTA），第三格用 lock 图标 +
       caption 出处替代「零」字（避免抽象、增强可信度）。 -->
  <!-- PRD-2026Q3 §UI-Audit-R1 §P0-1：stats 措辞口径合规化
         旧版「10,000+ 已找到免费用药 / 含三甲合作渠道」歧义且无可审计来源
         新版改成更保守、可追溯的措辞。
       PRD-2026Q3 §UI-Audit-R1 §P0-10：「在研新药」对老人易误读为"未上市，不安全"，加 caption 说明 -->
  <view class="stats-section">
    <view class="stat-item">
      <text class="stat-number">5,000+</text>
      <text class="stat-label">在研新药</text>
      <text class="stat-caption">国家备案、医院在做的研究</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">10,000+</text>
      <text class="stat-label">已匹配的家属</text>
      <text class="stat-caption">每周更新</text>
    </view>
    <view class="stat-item">
      <view class="stat-icon-wrap">
        <icon name="lock" color="brand" size="64" />
      </view>
      <text class="stat-label">数据由您掌控</text>
      <text class="stat-caption">个保法第 13 条第二款（二）项</text>
    </view>
  </view>

  <!-- PRD-2026Q3 §U5（迭代）：首页只保留一个明确的上传 CTA。
       Q3 视觉对齐 §E.1：emoji 全替为 Lucide 图标；上传按钮走 .btn-primary。 -->
  <view class="feature-section">
    <view class="section-title">从这里开始</view>
    <view class="section-subtitle">一次上传，我们陪您走完「看懂病历 → 找到能用的新药」全程。</view>

    <view class="upload-hero card">
      <view class="upload-hero-info">
        <view class="upload-hero-line">
          <icon name="camera" color="brand" size="44" />
          <text class="upload-hero-text">拍照、相册或 PDF 都行 —— 看不清的报告也能认</text>
        </view>
        <view class="upload-hero-line">
          <icon name="pill" color="brand" size="44" />
          <text class="upload-hero-text">不到 2 分钟，您拿到一份能用的新药清单</text>
        </view>
        <view class="upload-hero-line">
          <icon name="lock" color="brand" size="44" />
          <text class="upload-hero-text">数据完全由您掌管，随时可带走或删除</text>
        </view>
      </view>
      <view class="btn btn-primary upload-hero-button" bindtap="goToUpload">
        <text class="upload-hero-button-text">开始上传</text>
        <icon name="arrow-right" color="white" size="32" />
      </view>
    </view>

    <!-- PRD-2026Q3 §U7：先看个例子。0 医学基础家属面对一个空首页常常不敢点
         上传——给一个「无门槛预览」入口，看完一份完整的样例病历 + 新药匹配再决定。 -->
    <view class="demo-entry" bindtap="goToDemo" hover-class="demo-entry-hover">
      <view class="demo-entry-icon">
        <icon name="lightbulb" color="brand" size="36" />
      </view>
      <view class="demo-entry-info">
        <text class="demo-entry-title">先看个例子</text>
        <text class="demo-entry-desc">看一份完整的样例病历 + 找到的新药，了解上传后能拿到什么</text>
      </view>
      <icon name="chevron-right" color="text-muted" size="32" />
    </view>
  </view>

  <!-- PRD-2026Q2 §P1-3：抽公共 <parse-progress-banner>，actions slot 注入两个文本链接。 -->
  <parse-progress-banner
    wx:if="{{activeParseTask}}"
    title="我们正在看懂这份病历"
    progress="{{activeParseTask.progress}}"
    statusText="{{activeParseTask.text}}"
    showActions="{{true}}"
    class="processing-card-wrap"
  >
    <view slot="actions" class="processing-card-actions-slot">
      <text class="processing-card-link" bindtap="goToRecords">看病历</text>
      <text class="processing-card-link" bindtap="goToMatches">看新药</text>
    </view>
  </parse-progress-banner>

  <view class="loading" wx:if="{{loading}}">
    <text>马上好…</text>
  </view>

  <view class="empty-state" wx:if="{{!loading && errorMessage}}">
    <text>{{errorMessage}}</text>
  </view>

  <view class="recent-section" wx:if="{{!loading && recentMatches.length > 0}}">
    <view class="section-header">
      <text class="section-title">最近找到的新药</text>
      <text class="view-all" bindtap="goToMatches">看全部</text>
    </view>

    <view class="match-list">
      <view class="match-item card" wx:for="{{recentMatches}}" wx:key="id" bindtap="viewMatchDetail" data-id="{{item.id}}">
        <view class="match-header">
          <view class="match-title-group">
            <view class="match-drug-name">
              <icon name="pill" color="lilac" size="32" />
              <text class="match-drug-text">{{item.drugName}}<text class="match-drug-code" wx:if="{{item.drugCode}}"> / {{item.drugCode}}</text></text>
            </view>
            <text class="match-drug-class" wx:if="{{item.drugClass}}">{{item.drugClass}}</text>
          </view>
          <view class="match-score">
            <text class="score-value">{{item.matchScore}}%</text>
            <text class="score-label">匹配度</text>
          </view>
        </view>
        <view class="match-tags">
          <text class="pill pill-mint">免费用药</text>
          <text class="pill pill-brand">{{item.phase}}</text>
          <text class="pill pill-amber">{{item.location}}</text>
        </view>
        <view class="match-info">
          <text class="info-item">主治：{{item.indication}}</text>
          <text class="info-item" wx:if="{{item.manufacturer}}">提供：{{item.manufacturer}} ｜ {{item.institution}}</text>
          <text class="info-item" wx:else>提供：{{item.institution}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- PRD-2026Q3 §UI-Audit-R2 §R2-3：原 subtitle「几分钟走完全程」误导时间口径 ——
       上传 → 看到匹配清单确实只要几分钟，但「全程」（从匹配到入组用药）需要数周
       （研究方联系 → 医院筛查 → 知情同意书 → 入组）。改用更精准的口径。
       PRD-2026Q3 §UI-Audit-R2 §R2-2：step 3 desc「对接药企/医院」太抽象；改为更具体的
       「研究方在 3 个工作日内联系您」，让用户对"接下来会发生什么"有真实预期。 -->
  <view class="process-section card">
    <view class="section-title">看到能用的新药，几分钟就够</view>
    <view class="section-subtitle">上传到看到匹配清单 1-3 分钟。看完之后，由您决定要不要让研究方联络您。</view>
    <view class="process-steps">
      <view class="process-step">
        <view class="step-number">1</view>
        <text class="step-title">交给我们</text>
        <text class="step-desc">拍照或选病历</text>
      </view>
      <view class="step-arrow">
        <icon name="arrow-right" color="text-muted" size="28" />
      </view>
      <view class="process-step">
        <view class="step-number">2</view>
        <text class="step-title">帮您看懂</text>
        <text class="step-desc">找到关键信息</text>
      </view>
      <view class="step-arrow">
        <icon name="arrow-right" color="text-muted" size="28" />
      </view>
      <view class="process-step">
        <view class="step-number">3</view>
        <text class="step-title">找到新药</text>
        <text class="step-desc">您说要再联络研究方</text>
      </view>
    </view>
  </view>

  <!-- PRD-2026Q3 §UI-Audit-R1 §P0-12：「隐私零存储」与 records 实际行为矛盾（病历需临时保存
       才能匹配），与 privacy 页措辞对齐 —— 「数据只在您自己的账户里」 -->
  <view class="safety-tips">
    <icon name="shield-check" color="mint" size="32" />
    <text class="tips-text">数据只在您自己的账户里 · 您随时可带走或删除 · 不与药企或医院共享，除非您主动报名</text>
  </view>

  <help-fab />
</view>
