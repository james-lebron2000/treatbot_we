.hero-section {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.32), transparent 34%),
    linear-gradient(145deg, #111827 0%, #1f2937 48%, #334155 100%);
  border-radius: 36rpx;
  padding: 44rpx 36rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  box-shadow: 0 26rpx 50rpx rgba(15, 23, 42, 0.18);
}

.hero-content {
  flex: 1;
  margin-right: 18rpx;
}

.hero-eyebrow {
  display: inline-block;
  margin-bottom: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.82);
  font-size: 30rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  display: block;
  font-size: 62rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
  line-height: 1.18;
}

.hero-subtitle {
  display: block;
  margin-top: 18rpx;
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.72);
  line-height: 1.65;
}

.hero-image {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.92;
}

.stats-section {
  display: flex;
  gap: 14rpx;
  margin-bottom: 26rpx;
}

.stat-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.82);
  border-radius: 24rpx;
  padding: 26rpx 12rpx;
  text-align: center;
  border: 1rpx solid rgba(15, 23, 42, 0.05);
  box-shadow: 0 18rpx 30rpx rgba(15, 23, 42, 0.04);
}

.stat-number {
  display: block;
  font-size: 50rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #111827;
  margin-bottom: 10rpx;
}

.stat-label {
  display: block;
  font-size: 30rpx;
  color: #6b7280;
  line-height: 1.4;
}

.feature-section,
.recent-section,
.process-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 10rpx;
}

.section-subtitle {
  display: block;
  margin-bottom: 18rpx;
  font-size: 32rpx;
  color: #6b7280;
  line-height: 1.6;
}

.feature-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: rgba(255, 255, 255, 0.86);
  border-radius: 28rpx;
  padding: 28rpx 26rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 18rpx 34rpx rgba(15, 23, 42, 0.05);
}

.feature-card:active {
  transform: scale(0.988);
}

.feature-card.primary {
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.22), transparent 30%),
    linear-gradient(145deg, #16344b 0%, #1f4e5f 48%, #2f6f75 100%);
  border-color: transparent;
}

.feature-icon {
  width: 78rpx;
  height: 78rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(17, 24, 39, 0.06);
  color: #111827;
  font-size: 38rpx;
  font-weight: 700;
}

.feature-card.primary .feature-icon {
  background: rgba(255, 255, 255, 0.14);
  color: #fff;
}

.feature-info {
  flex: 1;
}

.feature-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 6rpx;
}

.feature-desc {
  display: block;
  font-size: 32rpx;
  color: #6b7280;
  line-height: 1.6;
}

.feature-card.primary .feature-title,
.feature-card.primary .feature-desc,
.feature-card.primary .feature-arrow {
  color: #fff;
}

.feature-arrow {
  font-size: 50rpx;
  line-height: 1;
  color: #9ca3af;
}

/* PRD-2026Q3 §U5（迭代）：上传 CTA 卡片 —— 把信息摊到页面上，按钮只剩「开始」。 */
.upload-hero {
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.18), transparent 32%),
    linear-gradient(145deg, #16344b 0%, #1f4e5f 48%, #2f6f75 100%);
  border-radius: 32rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 22rpx 42rpx rgba(15, 52, 75, 0.18);
  margin-bottom: 22rpx;
}

.upload-hero-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.upload-hero-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.upload-hero-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.upload-hero-text {
  flex: 1;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.5;
}

.upload-hero-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 108rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #fff 0%, #f1f5f9 100%);
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.18);
}

.upload-hero-button-hover {
  transform: scale(0.985);
  background: linear-gradient(145deg, #f8fafc 0%, #e2e8f0 100%);
}

.upload-hero-button-text {
  font-size: 44rpx;
  font-weight: 700;
  color: #16344b;
  letter-spacing: 12rpx;
  /* letter-spacing 让「开」「始」之间留白，更像独立按钮文字 */
}

.demo-entry {
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: rgba(255, 255, 255, 0.86);
  border-radius: 28rpx;
  padding: 26rpx 24rpx;
  border: 1rpx dashed rgba(47, 111, 117, 0.4);
}

.demo-entry-hover {
  transform: scale(0.988);
  background: #f1f5f9;
}

.demo-entry-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  background: rgba(47, 111, 117, 0.12);
  color: #16344b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.demo-entry-info {
  flex: 1;
}

.demo-entry-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 4rpx;
}

.demo-entry-desc {
  display: block;
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.55;
}

.demo-entry-arrow {
  font-size: 44rpx;
  color: #94a3b8;
  line-height: 1;
}

.processing-card {
  margin-bottom: 30rpx;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.94) 0%, rgba(244, 247, 250, 0.92) 100%);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 30rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.06);
}

.processing-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.processing-card-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
}

.processing-card-progress {
  font-size: 38rpx;
  font-weight: 700;
  color: #1d4ed8;
}

.processing-card-text {
  display: block;
  font-size: 32rpx;
  color: #6b7280;
  line-height: 1.65;
  margin-bottom: 18rpx;
}

.processing-card-bar {
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(29, 78, 216, 0.08);
  overflow: hidden;
}

.processing-card-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #0f172a 0%, #2563eb 100%);
}

.processing-card-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.processing-card-link,
.view-all {
  font-size: 33rpx;
  font-weight: 600;
  color: #1d4ed8;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.match-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.match-item {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 28rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 18rpx 34rpx rgba(15, 23, 42, 0.05);
}

.match-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 14rpx;
}

.match-title {
  flex: 1;
  font-size: 39rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.4;
}

.match-score {
  min-width: 94rpx;
  text-align: right;
}

.score-value {
  display: block;
  font-size: 46rpx;
  line-height: 1;
  font-weight: 700;
  color: #111827;
}

.score-label {
  display: block;
  margin-top: 6rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.match-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.match-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-item {
  font-size: 32rpx;
  color: #4b5563;
  line-height: 1.55;
}

.process-section {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 30rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.05);
}

.process-steps {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 10rpx;
  margin-top: 10rpx;
}

.step {
  flex: 1;
  background: rgba(248, 250, 252, 0.92);
  border-radius: 22rpx;
  padding: 24rpx 18rpx;
  text-align: center;
}

.step-number {
  width: 54rpx;
  height: 54rpx;
  margin: 0 auto 14rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #111827;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
}

.step-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 6rpx;
}

.step-desc {
  display: block;
  font-size: 30rpx;
  color: #6b7280;
  line-height: 1.55;
}

.step-arrow {
  align-self: center;
  font-size: 38rpx;
  color: #c0c6d0;
  margin-top: -10rpx;
}

.safety-tips {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 8rpx;
}

.tips-icon {
  font-size: 36rpx;
}

.tips-text {
  flex: 1;
  font-size: 31rpx;
  color: #6b7280;
  line-height: 1.55;
}

/* PRD-2026Q3 §U5：首屏期望管理 banner */
.onboarding-banner {
  margin: 24rpx 24rpx 0;
  padding: 20rpx 24rpx;
  background: #F0F6FF;
  border: 2rpx solid #C7D9F5;
  border-radius: 20rpx;
}
.onboarding-banner-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.onboarding-banner-title {
  color: #1F5AC7;
  font-size: 38rpx;
  font-weight: 600;
}
.onboarding-banner-toggle {
  color: #1F5AC7;
  font-size: 34rpx;
}
.onboarding-banner-body {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.onboarding-step {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 18rpx;
  background: #fff;
  border-radius: 16rpx;
}
.onboarding-step-icon {
  flex: 0 0 auto;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #1F5AC7;
  color: #fff;
  text-align: center;
  line-height: 48rpx;
  font-weight: 700;
  font-size: 34rpx;
}
.onboarding-step-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.onboarding-step-title {
  font-size: 36rpx;
  color: #0F172A;
  font-weight: 600;
}
.onboarding-step-text {
  font-size: 34rpx;
  color: #334155;
  line-height: 1.5;
}
.onboarding-promise {
  text-align: center;
  background: #fff;
  color: #1F5AC7;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
}
.onboarding-actions {
  display: flex;
  gap: 16rpx;
}
.onboarding-cta-primary {
  flex: 1;
  text-align: center;
  background: #1F5AC7;
  color: #fff;
  padding: 18rpx 0;
  border-radius: 12rpx;
  font-size: 36rpx;
  font-weight: 600;
}
.onboarding-cta-secondary {
  flex: 1;
  text-align: center;
  border: 2rpx solid #C7D9F5;
  background: #fff;
  color: #475569;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 34rpx;
}
