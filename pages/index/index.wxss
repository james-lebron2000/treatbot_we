/* pages/index/index.wxss
 * Q3 视觉对齐 §E.1（Plan web-treatbot-cozy-gizmo V2）：
 *   - Hero 改 Landing 同款 radial 浅光 (.hero-shell baseline 已生效，本文件仅做尺寸/响应微调)
 *   - 卡片：实白 + 1px 细边 + 32rpx 圆角；按下 -2rpx + shadow-1
 *   - 颜色全 token；字号语义命名 */

/* hero ------------------------------------------------------------------ */
.hero-section {
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 64rpx 32rpx 48rpx;     /* override hero-shell 默认 padding */
}

.hero-content {
  flex: 1;
  margin-right: 16rpx;
}

.hero-eyebrow {
  display: inline-block;
  margin-bottom: 16rpx;
}

.hero-title {
  display: block;
  font-size: 56rpx;               /* 比 baseline 80rpx 收一点，适配卡片宽度 */
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;            /* PRD §P1-4：4rpx → 8rpx 行间撑开 */
  /* PRD §P1-4：1.18 → 1.3，小屏（iPhone SE / 360pt 安卓）三行不再视觉拥挤 */
  line-height: 1.3;
}

.hero-title .accent { color: var(--brand); }

.hero-subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: 1.6;
}

.hero-image {
  width: 160rpx;
  height: 160rpx;
}

/* stats grid ------------------------------------------------------------ */
.stats-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-item {
  flex: 1;
  background: var(--bg);
  border: 2rpx solid var(--line);
  border-radius: 24rpx;           /* --r-md */
  padding: 24rpx 12rpx;
  text-align: center;
}

/* PRD-2026Q2 §P0-1：数字色 var(--brand) → var(--text)，让 CTA 是页面唯一的强势蓝。
   字重保持 700，仅去掉饱和色，保留视觉重量层次。 */
.stat-number {
  display: block;
  font-size: 44rpx;
  line-height: 1.1;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
  letter-spacing: -0.5rpx;
}

/* 第三格不再用「零」字数字而是 lock 图标，给一个 stat-number 等高的容器
   让三格视觉对齐。 */
.stat-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;       /* 与 .stat-number 视觉等高（44rpx font-size × line-height 1.1 + margin-bottom 8rpx，留 4rpx 误差） */
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.4;
}

/* caption 给数字一个出处脚注，回应 "五千这数字哪来的" 的隐性疑问。 */
.stat-caption {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.4;
  margin-top: 4rpx;
}

/* feature/recent/process sections --------------------------------------- */
.feature-section,
.recent-section,
.process-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
}

.section-subtitle {
  display: block;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: 1.6;
}

/* upload hero card（Landing CTA 同款） ----------------------------------- */
.upload-hero {
  margin-bottom: 24rpx;
}

.upload-hero-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.upload-hero-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.upload-hero-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: 1.5;
}

.upload-hero-button {
  width: 100%;
  height: 96rpx;
  gap: 12rpx;
}

.upload-hero-button-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0;
}

/* demo entry（ghost CTA） ----------------------------------------------- */
.demo-entry {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--bg);
  border: 2rpx solid var(--line);
  border-radius: 32rpx;           /* --r-lg */
  padding: 24rpx;
  transition: transform 100ms cubic-bezier(0.4, 0, 0.2, 1);
}

.demo-entry-hover {
  transform: scale(0.985);
  background: var(--bg-soft);
}

.demo-entry-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 24rpx;
  background: var(--brand-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.demo-entry-info {
  flex: 1;
}

.demo-entry-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4rpx;
}

.demo-entry-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.55;
}

/* PRD-2026Q2 §P1-3：以下样式已迁到 components/parse-progress-banner/。
   仅保留宿主级别的外间距 + actions slot 内的链接样式。 */
.processing-card-wrap {
  display: block;
  margin-bottom: 32rpx;
}

.processing-card-actions-slot {
  display: flex;
  gap: 24rpx;
}

/* PRD-2026Q2 §P0-7：裸文本链接老花镜下点不准。
   padding 撑出 88rpx 触达高度（HIG / Material Design 双标都满足），
   配 negative margin 保持视觉位置不变。 */
.processing-card-link,
.view-all {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--brand);
  padding: 16rpx 24rpx;
  margin: -16rpx -24rpx;
  border-radius: 16rpx;
  transition: background 150ms ease-out;
}

.processing-card-link:active,
.view-all:active {
  background: var(--brand-soft);
}

/* recent matches list --------------------------------------------------- */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.match-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.match-item {
  margin-bottom: 0;
}

.match-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.match-title-group {
  flex: 1;
}

.match-drug-name {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.match-drug-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  line-height: 1.4;
}

.match-drug-code {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-muted);
}

.match-drug-class {
  display: block;
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.4;
}

.match-score {
  min-width: 96rpx;
  text-align: right;
}

.score-value {
  display: block;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--brand);
}

.score-label {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.match-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.match-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-item {
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.55;
}

/* process section: 3 steps grid ---------------------------------------- */
.process-section {
  background: var(--bg);
  border: 2rpx solid var(--line);
  border-radius: 32rpx;
  padding: 32rpx;
}

.process-steps {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 16rpx;
}

.process-step {
  flex: 1;
  background: var(--bg-soft);
  border-radius: 24rpx;           /* --r-md */
  padding: 24rpx 12rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* PRD-2026Q2 §T2-2：48rpx → 56rpx 与 .step-num utility 对齐
   保留 step-number class 名（避免改 wxml），但视觉等价于 .step-num.active */
.step-number {
  width: 56rpx;
  height: 56rpx;
  margin: 0 auto 12rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--brand);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.step-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4rpx;
}

.step-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-dim);
  line-height: 1.5;
}

.step-arrow {
  align-self: center;
  display: flex;
  align-items: center;
}

/* safety tips footer ---------------------------------------------------- */
.safety-tips {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 8rpx;
  margin-bottom: 32rpx;
}

.tips-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.55;
}

/* PRD-2026Q3 §U5：首屏期望管理 banner —— 全 token 化 */
.onboarding-banner {
  margin-bottom: 32rpx;
}

.onboarding-banner-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.onboarding-banner-toggle {
  color: var(--brand);
  font-size: 26rpx;
  font-weight: 600;
}

.onboarding-banner-title {
  display: block;
  color: var(--text);
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.onboarding-banner-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.onboarding-step {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx;
  background: var(--bg-soft);
  border-radius: 24rpx;           /* --r-md */
}

/* PRD-2026Q2 §T2-2：48rpx → 56rpx 与 .step-num utility 对齐 */
.onboarding-step-icon {
  flex: 0 0 auto;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--brand);
  color: #fff;
  text-align: center;
  line-height: 56rpx;
  font-weight: 700;
  font-size: 28rpx;
}

.onboarding-step-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.onboarding-step-title {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
}

.onboarding-step-text {
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.5;
}

.onboarding-promise {
  text-align: center;
  background: var(--brand-soft);
  color: var(--brand);
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  margin-top: 8rpx;
}

.onboarding-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.onboarding-cta-primary,
.onboarding-cta-secondary {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
}
