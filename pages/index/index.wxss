/* pages/index/index.wxss
 * Q3 视觉对齐 §E.1（Plan web-h5-cozy-gizmo V2）：
 *   - Hero 改 Landing 同款 radial 浅光 (.hero-shell baseline 已生效，本文件仅做尺寸/响应微调)
 *   - 卡片：实白 + 1px 细边 + 32rpx 圆角；按下 -2rpx + shadow-1
 *   - 颜色全 token；字号语义命名 */

/* hero ------------------------------------------------------------------ */
.hero-section {
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 64rpx 32rpx 48rpx;     /* override hero-shell 默认 padding */
}

.hero-content {
  flex: 1;
  margin-right: 16rpx;
}

.hero-eyebrow {
  display: inline-block;
  margin-bottom: 16rpx;
}

.hero-title {
  display: block;
  font-size: 56rpx;               /* 比 baseline 80rpx 收一点，适配卡片宽度 */
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4rpx;
  line-height: 1.18;
}

.hero-title .accent { color: var(--brand); }

.hero-subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: 1.6;
}

.hero-image {
  width: 160rpx;
  height: 160rpx;
}

/* stats grid ------------------------------------------------------------ */
.stats-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-item {
  flex: 1;
  background: var(--bg);
  border: 2rpx solid var(--line);
  border-radius: 24rpx;           /* --r-md */
  padding: 24rpx 12rpx;
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 44rpx;
  line-height: 1.1;
  font-weight: 700;
  color: var(--brand);
  margin-bottom: 8rpx;
  letter-spacing: -0.5rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.4;
}

/* feature/recent/process sections --------------------------------------- */
.feature-section,
.recent-section,
.process-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
}

.section-subtitle {
  display: block;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: 1.6;
}

/* upload hero card（Landing CTA 同款） ----------------------------------- */
.upload-hero {
  margin-bottom: 24rpx;
}

.upload-hero-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.upload-hero-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.upload-hero-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: 1.5;
}

.upload-hero-button {
  width: 100%;
  height: 96rpx;
  gap: 12rpx;
}

.upload-hero-button-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0;
}

/* demo entry（ghost CTA） ----------------------------------------------- */
.demo-entry {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--bg);
  border: 2rpx solid var(--line);
  border-radius: 32rpx;           /* --r-lg */
  padding: 24rpx;
  transition: transform 100ms cubic-bezier(0.4, 0, 0.2, 1);
}

.demo-entry-hover {
  transform: scale(0.985);
  background: var(--bg-soft);
}

.demo-entry-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 24rpx;
  background: var(--brand-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.demo-entry-info {
  flex: 1;
}

.demo-entry-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4rpx;
}

.demo-entry-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.55;
}

/* processing card ------------------------------------------------------- */
.processing-card {
  margin-bottom: 32rpx;
}

.processing-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.processing-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.processing-card-progress {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--brand);
}

.processing-card-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.processing-card-bar {
  height: 12rpx;
  border-radius: 999rpx;
  background: var(--brand-soft);
  overflow: hidden;
}

.processing-card-fill {
  height: 100%;
  border-radius: 999rpx;
  background: var(--brand);
  transition: width 0.3s ease;
}

.processing-card-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.processing-card-link,
.view-all {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--brand);
}

/* recent matches list --------------------------------------------------- */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.match-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.match-item {
  margin-bottom: 0;
}

.match-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.match-title-group {
  flex: 1;
}

.match-drug-name {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.match-drug-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  line-height: 1.4;
}

.match-drug-code {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-muted);
}

.match-drug-class {
  display: block;
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.4;
}

.match-score {
  min-width: 96rpx;
  text-align: right;
}

.score-value {
  display: block;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--brand);
}

.score-label {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.match-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.match-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-item {
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.55;
}

/* process section: 3 steps grid ---------------------------------------- */
.process-section {
  background: var(--bg);
  border: 2rpx solid var(--line);
  border-radius: 32rpx;
  padding: 32rpx;
}

.process-steps {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 16rpx;
}

.process-step {
  flex: 1;
  background: var(--bg-soft);
  border-radius: 24rpx;           /* --r-md */
  padding: 24rpx 12rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  margin: 0 auto 12rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--brand);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.step-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4rpx;
}

.step-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-dim);
  line-height: 1.5;
}

.step-arrow {
  align-self: center;
  display: flex;
  align-items: center;
}

/* safety tips footer ---------------------------------------------------- */
.safety-tips {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 8rpx;
  margin-bottom: 32rpx;
}

.tips-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.55;
}

/* PRD-2026Q3 §U5：首屏期望管理 banner —— 全 token 化 */
.onboarding-banner {
  margin-bottom: 32rpx;
}

.onboarding-banner-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.onboarding-banner-toggle {
  color: var(--brand);
  font-size: 26rpx;
  font-weight: 600;
}

.onboarding-banner-title {
  display: block;
  color: var(--text);
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.onboarding-banner-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.onboarding-step {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx;
  background: var(--bg-soft);
  border-radius: 24rpx;           /* --r-md */
}

.onboarding-step-icon {
  flex: 0 0 auto;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--brand);
  color: #fff;
  text-align: center;
  line-height: 48rpx;
  font-weight: 700;
  font-size: 26rpx;
}

.onboarding-step-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.onboarding-step-title {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
}

.onboarding-step-text {
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.5;
}

.onboarding-promise {
  text-align: center;
  background: var(--brand-soft);
  color: var(--brand);
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  margin-top: 8rpx;
}

.onboarding-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.onboarding-cta-primary,
.onboarding-cta-secondary {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
}
