<view class="container">
  <!-- 样例标识 banner -->
  <view class="sample-banner">
    <view class="sample-banner-tag">📘 样例</view>
    <view class="sample-banner-body">
      <text class="sample-banner-title">{{sampleBanner.title}}</text>
      <text class="sample-banner-subtitle">{{sampleBanner.subtitle}}</text>
    </view>
  </view>

  <!-- 步骤指示器：第 1 步当前激活 -->
  <view class="step-indicator">
    <view class="step active">
      <view class="step-dot">1</view>
      <text class="step-text">看懂病历</text>
    </view>
    <view class="step-line"></view>
    <view class="step">
      <view class="step-dot">2</view>
      <text class="step-text">找到新药</text>
    </view>
  </view>

  <!-- ===== Phase A: 上传 / Phase B: 解析（共享 hero + 进度条） ===== -->
  <view wx:if="{{phase !== 'done'}}" class="processing-section">
    <view class="processing-hero">
      <view class="processing-animation">
        <view class="animation-circle"></view>
        <view class="animation-circle"></view>
        <view class="animation-circle"></view>
      </view>
      <view class="processing-title">
        <text wx:if="{{phase === 'uploading'}}">正在仿真上传…</text>
        <text wx:else>正在帮您看懂这份样例病历…</text>
      </view>
      <view class="processing-desc">
        <text wx:if="{{phase === 'uploading'}}">把样例文件传到我们这里 —— 实际场景里这一步是您的病历</text>
        <text wx:else>下面 4 件事会同时进行 —— 您可以看到字段一条一条被认出来</text>
      </view>
    </view>

    <!-- 文件缩略图 -->
    <view class="file-card">
      <view class="file-icon-box">📄</view>
      <view class="file-info">
        <text class="file-name">{{sampleFile.name}}</text>
        <text class="file-meta">{{sampleFile.kind}} · {{sampleFile.pages}} 页 · 样例</text>
      </view>
      <view class="file-status">
        <text wx:if="{{phase === 'uploading'}}">上传中</text>
        <text wx:else>已上传 ✓</text>
      </view>
    </view>

    <!-- 进度条 -->
    <view class="progress-panel">
      <view class="progress-panel-head">
        <text class="progress-kicker">{{phase === 'uploading' ? '上传进度' : '解析进度'}}</text>
        <text class="progress-number">{{progress}}%</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="{{progressStyle}}"></view>
        <view class="progress-shine"></view>
      </view>
    </view>

    <!-- 解析阶段才显示的 4-step 卡 -->
    <view wx:if="{{phase === 'parsing'}}" class="parse-steps">
      <view
        class="parse-step-card {{parseStepIndex > index ? 'completed' : ''}} {{parseStepIndex === index ? 'current' : ''}}"
        wx:for="{{parseSteps}}"
        wx:key="key"
        wx:for-item="step"
        wx:for-index="index"
      >
        <view class="parse-step-badge">
          <text wx:if="{{parseStepIndex > index}}" class="parse-step-badge-text">✓</text>
          <text wx:else class="parse-step-badge-text">{{index + 1}}</text>
        </view>
        <view class="parse-step-main">
          <view class="parse-step-top">
            <text class="parse-step-title">{{step.title}}</text>
            <text class="parse-step-state" wx:if="{{parseStepIndex > index}}">已完成</text>
            <text class="parse-step-state current" wx:elif="{{parseStepIndex === index}}">进行中</text>
            <text class="parse-step-state pending" wx:else>等待中</text>
          </view>
          <text class="parse-step-desc">{{step.desc}}</text>
        </view>
      </view>
    </view>

    <!-- 解析阶段实时 reveal 的字段 stream -->
    <view wx:if="{{phase === 'parsing'}}" class="extract-stream">
      <text class="extract-stream-title">已认出的关键信息</text>
      <view class="extract-line {{revealedFields['patient.basic'] ? 'shown' : ''}}">
        <text class="extract-icon">✓</text>
        <text class="extract-label">基本信息</text>
        <text class="extract-value">{{record.patient.nickName}} · {{record.patient.age}} 岁 · ECOG {{record.ecog}}</text>
      </view>
      <view class="extract-line {{revealedFields['diagnosis.primary'] ? 'shown' : ''}}">
        <text class="extract-icon">✓</text>
        <text class="extract-label">诊断</text>
        <text class="extract-value">{{record.diagnosis.primary}}</text>
      </view>
      <view class="extract-line {{revealedFields['diagnosis.stage'] ? 'shown' : ''}}">
        <text class="extract-icon">✓</text>
        <text class="extract-label">分期</text>
        <text class="extract-value">{{record.diagnosis.stage}}</text>
      </view>
      <view class="extract-line {{revealedFields['diagnosis.pathology'] ? 'shown' : ''}}">
        <text class="extract-icon">✓</text>
        <text class="extract-label">病理类型</text>
        <text class="extract-value">{{record.diagnosis.pathology}}</text>
      </view>
      <view class="extract-line {{revealedFields['genes'] ? 'shown' : ''}}">
        <text class="extract-icon">✓</text>
        <text class="extract-label">基因检测</text>
        <text class="extract-value">EGFR 19 缺失阳性 · ALK / ROS1 阴性 · PD-L1 30%</text>
      </view>
      <view class="extract-line {{revealedFields['labs'] ? 'shown' : ''}}">
        <text class="extract-icon">✓</text>
        <text class="extract-label">化验</text>
        <text class="extract-value">血红蛋白偏低 118 g/L · 其他指标正常</text>
      </view>
      <view class="extract-line {{revealedFields['treatments'] ? 'shown' : ''}}">
        <text class="extract-icon">✓</text>
        <text class="extract-label">治疗经历</text>
        <text class="extract-value">手术 → 化疗 → 奥希替尼 → 进展（共 4 段）</text>
      </view>
      <view class="extract-line {{revealedFields['imaging'] ? 'shown' : ''}}">
        <text class="extract-icon">✓</text>
        <text class="extract-label">影像</text>
        <text class="extract-value">{{record.imaging.newLesion}}</text>
      </view>
      <view class="extract-line {{revealedFields['summary'] ? 'shown' : ''}}">
        <text class="extract-icon">✓</text>
        <text class="extract-label">病情摘要</text>
        <text class="extract-value summary">{{record.summary}}</text>
      </view>
    </view>

    <view class="processing-actions">
      <text class="processing-skip-link" bindtap="skipSimulation">跳过演示，直接看结果 →</text>
    </view>
  </view>

  <!-- ===== Phase C: 完成态 / 结构化病历卡 ===== -->
  <view wx:if="{{phase === 'done'}}" class="done-section">
    <view class="done-banner">
      <text class="done-banner-icon">✓</text>
      <view class="done-banner-body">
        <text class="done-banner-title">看懂了 —— 共认出 {{record.treatments.length}} 段治疗 / {{record.genes.length}} 项基因 / {{record.labs.length}} 项化验</text>
        <text class="done-banner-subtitle">下面是为您整理的样例病历卡片，请过一遍。哪里不对在真实场景里可以直接改。</text>
      </view>
    </view>

    <!-- 完整结构化病历卡片（与 done 后展示给真实用户的视图风格一致） -->
    <view class="record-card">
      <view class="record-summary">
        <text class="record-summary-label">一句话病情</text>
        <text class="record-summary-text">{{record.summary}}</text>
      </view>

      <view class="record-row">
        <text class="record-row-label">基本信息</text>
        <view class="record-row-grid">
          <view class="kv">
            <text class="kv-label">姓名</text>
            <text class="kv-value">{{record.patient.nickName}}</text>
          </view>
          <view class="kv">
            <text class="kv-label">年龄 / 性别</text>
            <text class="kv-value">{{record.patient.age}} 岁 / {{record.patient.sex}}</text>
          </view>
          <view class="kv">
            <text class="kv-label">身高 / 体重</text>
            <text class="kv-value">{{record.patient.height}} / {{record.patient.weight}}</text>
          </view>
          <view class="kv">
            <text class="kv-label">体力评分 ECOG</text>
            <text class="kv-value">{{record.ecog}}</text>
          </view>
        </view>
      </view>

      <view class="record-row">
        <text class="record-row-label">诊断</text>
        <view class="record-row-grid">
          <view class="kv">
            <text class="kv-label">原发病</text>
            <text class="kv-value highlight">{{record.diagnosis.primary}}</text>
          </view>
          <view class="kv">
            <text class="kv-label">病理类型</text>
            <text class="kv-value">{{record.diagnosis.pathology}}</text>
          </view>
          <view class="kv">
            <text class="kv-label">分期</text>
            <text class="kv-value highlight">{{record.diagnosis.stage}}</text>
          </view>
          <view class="kv">
            <text class="kv-label">确诊时间</text>
            <text class="kv-value">{{record.diagnosis.diagnosedAt}}</text>
          </view>
        </view>
      </view>

      <view class="record-row">
        <text class="record-row-label">基因检测</text>
        <view class="gene-list">
          <view class="gene-item {{item.highlight ? 'highlight' : ''}}" wx:for="{{record.genes}}" wx:key="name">
            <text class="gene-name">{{item.name}}</text>
            <text class="gene-detail">{{item.detail}}</text>
          </view>
        </view>
      </view>

      <view class="record-row">
        <text class="record-row-label">关键化验</text>
        <view class="lab-list">
          <view class="lab-item" wx:for="{{record.labs}}" wx:key="name">
            <text class="lab-name">{{item.name}}</text>
            <text class="lab-value {{item.flag === 'low' ? 'lab-flag-low' : ''}}">{{item.value}}</text>
            <text class="lab-range">参考 {{item.range}}</text>
          </view>
        </view>
      </view>

      <view class="record-row">
        <text class="record-row-label">治疗经历</text>
        <view class="timeline">
          <view class="timeline-item" wx:for="{{record.treatments}}" wx:key="date">
            <view class="timeline-dot"></view>
            <view class="timeline-content">
              <view class="timeline-head">
                <text class="timeline-date">{{item.date}}</text>
                <text class="timeline-kind">{{item.kind}}</text>
              </view>
              <text class="timeline-name">{{item.name}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="record-row last">
        <text class="record-row-label">影像与病灶</text>
        <view class="record-row-grid">
          <view class="kv">
            <text class="kv-label">靶病灶</text>
            <text class="kv-value">{{record.imaging.targetLesion}}</text>
          </view>
          <view class="kv">
            <text class="kv-label">新发病灶</text>
            <text class="kv-value highlight">{{record.imaging.newLesion}}</text>
          </view>
          <view class="kv">
            <text class="kv-label">最近一次检查</text>
            <text class="kv-value">{{record.imaging.latestExam}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 第 1 步收尾 + 跳转第 2 步 -->
    <view class="next-cta">
      <text class="next-cta-title">第 1 步完成</text>
      <text class="next-cta-subtitle">下一步我们会围绕这份病历，从公开的临床研究库找出可能能免费用上的新药 —— 每一种都说清楚为什么。</text>
      <view class="next-cta-button" bindtap="goToDemoMatches" hover-class="next-cta-button-hover">
        <text class="next-cta-button-text">下一步：看为家人找到的新药 →</text>
      </view>
      <view class="next-cta-secondary">
        <text class="next-cta-link" bindtap="replaySimulation">↻ 再看一次演示</text>
        <text class="next-cta-link" bindtap="goBack">先返回</text>
      </view>
    </view>
  </view>
</view>
