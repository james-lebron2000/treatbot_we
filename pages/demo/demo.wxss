/* PRD-2026Q3 §U7 演示页 第 1 步样式 —— 与真实 upload 流水线观感一致。 */

.container {
  padding: 24rpx 24rpx 80rpx;
}

/* ===== 样例 banner ===== */
.sample-banner {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  background: linear-gradient(145deg, #fff7ed 0%, #fef3c7 100%);
  border: 2rpx dashed #f59e0b;
  border-radius: 24rpx;
  padding: 22rpx 22rpx;
  margin-bottom: 24rpx;
}

.sample-banner-tag {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f59e0b;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 16rpx;
  padding: 0 18rpx;
  flex-shrink: 0;
}

.sample-banner-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.sample-banner-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #92400e;
}

.sample-banner-subtitle {
  font-size: 28rpx;
  color: #b45309;
  line-height: 1.55;
}

/* ===== 步骤指示器 ===== */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  margin-bottom: 32rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  opacity: 0.4;
}

.step.active {
  opacity: 1;
}

.step-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #cbd5e1;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
}

.step.active .step-dot {
  background: #16344b;
}

.step-text {
  font-size: 26rpx;
  color: #1e293b;
}

.step.active .step-text {
  color: #0f172a;
  font-weight: 600;
}

.step-line {
  flex: 0 0 80rpx;
  height: 4rpx;
  background: #cbd5e1;
}

/* ===== Phase A/B：上传/解析共享 hero + 进度条 ===== */
.processing-section {
  margin-bottom: 32rpx;
}

.processing-hero {
  text-align: center;
  margin-bottom: 24rpx;
}

.processing-animation {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
  height: 40rpx;
}

.animation-circle {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #2f6f75;
  animation: pulse-bounce 1.2s ease-in-out infinite;
}

.animation-circle:nth-child(2) { animation-delay: 0.18s; }
.animation-circle:nth-child(3) { animation-delay: 0.36s; }

@keyframes pulse-bounce {
  0%, 60%, 100% { transform: scale(1); opacity: 0.6; }
  30% { transform: scale(1.5); opacity: 1; }
}

.processing-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 6rpx;
}

.processing-desc {
  font-size: 30rpx;
  color: #374151;
  line-height: 1.55;
}

/* 文件缩略卡 */
.file-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 20rpx;
}

.file-icon-box {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #fef3c7 0%, #fde68a 100%);
  color: #92400e;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  flex-shrink: 0;
}

.file-info {
  flex: 1;
  min-width: 0;
}

.file-name {
  display: block;
  font-size: 30rpx;
  color: #0f172a;
  font-weight: 600;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.file-meta {
  display: block;
  margin-top: 2rpx;
  font-size: 26rpx;
  color: #334155;
}

.file-status {
  font-size: 26rpx;
  color: #16a34a;
  font-weight: 600;
}

/* 进度条 */
.progress-panel {
  background: #fff;
  border-radius: 22rpx;
  padding: 20rpx;
  border: 1rpx solid #e2e8f0;
  margin-bottom: 22rpx;
}

.progress-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-kicker {
  font-size: 28rpx;
  color: #1e293b;
}

.progress-number {
  font-size: 32rpx;
  font-weight: 700;
  color: #16344b;
}

.progress-bar {
  position: relative;
  height: 18rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  overflow: hidden;
}

.progress-fill {
  position: absolute;
  inset: 0;
  width: 0;
  background: linear-gradient(90deg, #16344b 0%, #2f6f75 100%);
  border-radius: 999rpx;
  transition: width 80ms linear;
}

.progress-shine {
  position: absolute;
  top: 0;
  left: -40%;
  width: 40%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.5) 50%, transparent 100%);
  animation: shine 1.6s ease-in-out infinite;
}

@keyframes shine {
  0% { left: -40%; }
  100% { left: 110%; }
}

/* 4 步卡 */
.parse-steps {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.parse-step-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  opacity: 0.6;
  transition: opacity 200ms ease, border-color 200ms ease;
}

.parse-step-card.current {
  opacity: 1;
  border-color: #2f6f75;
  box-shadow: 0 12rpx 24rpx rgba(47, 111, 117, 0.12);
}

.parse-step-card.completed {
  opacity: 1;
  border-color: #d1fae5;
  background: #f0fdf4;
}

.parse-step-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #cbd5e1;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  flex-shrink: 0;
}

.parse-step-card.current .parse-step-badge {
  background: #2f6f75;
  animation: pulse-ring 1.4s ease-in-out infinite;
}

.parse-step-card.completed .parse-step-badge {
  background: #16a34a;
}

@keyframes pulse-ring {
  0%, 100% { box-shadow: 0 0 0 0 rgba(47, 111, 117, 0.4); }
  50% { box-shadow: 0 0 0 12rpx rgba(47, 111, 117, 0); }
}

.parse-step-badge-text {
  font-size: 28rpx;
}

.parse-step-main {
  flex: 1;
}

.parse-step-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 4rpx;
}

.parse-step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  flex: 1;
  min-width: 0;
}

.parse-step-state {
  font-size: 24rpx;
  color: #334155;
  flex-shrink: 0;
}

.parse-step-state.current {
  color: #2f6f75;
  font-weight: 600;
}

.parse-step-card.completed .parse-step-state {
  color: #16a34a;
}

.parse-step-desc {
  display: block;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.5;
}

/* 解析阶段实时 reveal 的字段 stream */
.extract-stream {
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  border: 1rpx dashed #cbd5e1;
}

.extract-stream-title {
  display: block;
  font-size: 26rpx;
  color: #1e293b;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.extract-line {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 6rpx 0;
  opacity: 0;
  transform: translateY(8rpx);
  transition: opacity 360ms ease, transform 360ms ease;
}

.extract-line.shown {
  opacity: 1;
  transform: translateY(0);
}

.extract-icon {
  color: #16a34a;
  font-size: 28rpx;
  width: 32rpx;
  flex-shrink: 0;
  font-weight: 700;
  line-height: 1.5;
}

.extract-label {
  font-size: 28rpx;
  color: #374151;
  width: 140rpx;
  flex-shrink: 0;
  line-height: 1.5;
}

.extract-value {
  flex: 1;
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 500;
  line-height: 1.5;
}

.extract-value.summary {
  color: #16344b;
  font-weight: 600;
}

.processing-actions {
  text-align: center;
  margin-top: 20rpx;
}

.processing-skip-link {
  font-size: 28rpx;
  color: #2f6f75;
  text-decoration: underline;
}

/* ===== Phase C：完成态 ===== */
.done-section {
  /* 整段从下往上滑入 */
  animation: slide-up 360ms ease;
}

@keyframes slide-up {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.done-banner {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: linear-gradient(145deg, #ecfdf5 0%, #d1fae5 100%);
  border: 2rpx solid #10b981;
  border-radius: 24rpx;
  padding: 22rpx;
  margin-bottom: 24rpx;
}

.done-banner-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #10b981;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.done-banner-body {
  flex: 1;
}

.done-banner-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #064e3b;
  margin-bottom: 4rpx;
}

.done-banner-subtitle {
  display: block;
  font-size: 28rpx;
  color: #065f46;
  line-height: 1.55;
}

/* ===== 病历卡片（与原 demo.wxss 同结构，保留以兼容现有视觉） ===== */
.record-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.05);
  margin-bottom: 28rpx;
}

.record-summary {
  background: linear-gradient(145deg, #ecfdf5 0%, #d1fae5 100%);
  border-left: 8rpx solid #10b981;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 24rpx;
}

.record-summary-label {
  display: block;
  font-size: 24rpx;
  color: #047857;
  margin-bottom: 6rpx;
  letter-spacing: 1rpx;
}

.record-summary-text {
  font-size: 28rpx;
  color: #064e3b;
  font-weight: 600;
  line-height: 1.55;
}

.record-row {
  padding-bottom: 22rpx;
  margin-bottom: 22rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.record-row.last {
  border-bottom: none;
  padding-bottom: 0;
  margin-bottom: 0;
}

.record-row-label {
  display: block;
  font-size: 26rpx;
  color: #334155;
  margin-bottom: 14rpx;
  letter-spacing: 1rpx;
}

.record-row-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx 24rpx;
}

.kv {
  flex: 1 1 calc(50% - 12rpx);
  min-width: calc(50% - 12rpx);
}

.kv-label {
  display: block;
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 4rpx;
}

.kv-value {
  display: block;
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 600;
}

.kv-value.highlight {
  color: #16344b;
}

.gene-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.gene-item {
  flex: 1 1 calc(50% - 8rpx);
  min-width: calc(50% - 8rpx);
  background: #f8fafc;
  border-radius: 14rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid #e2e8f0;
}

.gene-item.highlight {
  background: linear-gradient(145deg, #fef3c7 0%, #fde68a 100%);
  border-color: #f59e0b;
}

.gene-name {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.gene-detail {
  display: block;
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #374151;
}

.gene-item.highlight .gene-detail {
  color: #92400e;
  font-weight: 600;
}

.lab-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.lab-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.lab-name {
  font-size: 26rpx;
  color: #0f172a;
  flex: 1;
}

.lab-value {
  font-size: 26rpx;
  color: #0f172a;
  font-weight: 600;
  margin: 0 18rpx;
  min-width: 180rpx;
  text-align: right;
}

.lab-value.lab-flag-low { color: #dc2626; }

.lab-range {
  font-size: 24rpx;
  color: #334155;
  min-width: 200rpx;
  text-align: right;
}

.timeline {
  display: flex;
  flex-direction: column;
}

.timeline-item {
  position: relative;
  padding-left: 32rpx;
  padding-bottom: 18rpx;
}

.timeline-item:last-child { padding-bottom: 0; }

.timeline-item::before {
  content: '';
  position: absolute;
  left: 11rpx;
  top: 12rpx;
  bottom: 0;
  width: 2rpx;
  background: #e2e8f0;
}

.timeline-item:last-child::before { display: none; }

.timeline-dot {
  position: absolute;
  left: 0;
  top: 8rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #16344b;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 2rpx #16344b;
}

.timeline-content {
  background: #f8fafc;
  border-radius: 14rpx;
  padding: 12rpx 16rpx;
  border: 1rpx solid #e2e8f0;
}

.timeline-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.timeline-date {
  font-size: 26rpx;
  color: #374151;
}

.timeline-kind {
  background: #16344b;
  color: #fff;
  font-size: 22rpx;
  border-radius: 999rpx;
  padding: 2rpx 12rpx;
}

.timeline-name {
  font-size: 26rpx;
  color: #0f172a;
  font-weight: 500;
  line-height: 1.5;
}

/* ===== 下一步 CTA ===== */
.next-cta {
  background: linear-gradient(145deg, #16344b 0%, #1f4e5f 48%, #2f6f75 100%);
  border-radius: 32rpx;
  padding: 32rpx 28rpx;
  text-align: center;
  box-shadow: 0 22rpx 42rpx rgba(15, 52, 75, 0.18);
}

.next-cta-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.next-cta-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.55;
  margin-bottom: 24rpx;
}

.next-cta-button {
  background: #fff;
  border-radius: 22rpx;
  padding: 22rpx 0;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.18);
}

.next-cta-button-hover {
  transform: scale(0.985);
  background: #f1f5f9;
}

.next-cta-button-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #16344b;
}

.next-cta-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  margin-top: 22rpx;
}

.next-cta-link {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.78);
  text-decoration: underline;
}
