/* PRD-2026Q3 §U7 演示页 第 2 步样式 —— 与 /pages/matches/matches.wxss 视觉一致。 */

.container {
  padding: 24rpx 24rpx 80rpx;
}

.sample-banner {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  background: linear-gradient(145deg, #fff7ed 0%, #fef3c7 100%);
  border: 2rpx dashed #f59e0b;
  border-radius: 24rpx;
  padding: 22rpx 22rpx;
  margin-bottom: 24rpx;
}

.sample-banner-tag {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f59e0b;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 16rpx;
  padding: 0 18rpx;
  flex-shrink: 0;
}

.sample-banner-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.sample-banner-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #92400e;
}

.sample-banner-subtitle {
  font-size: 28rpx;
  color: #b45309;
  line-height: 1.55;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  opacity: 0.5;
}

.step.active, .step.done { opacity: 1; }

.step-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #cbd5e1;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
}

.step.active .step-dot { background: #16344b; }
.step.done .step-dot { background: #16a34a; }

.step-text {
  font-size: 26rpx;
  color: #1e293b;
}

.step.active .step-text {
  color: #0f172a;
  font-weight: 600;
}

.step-line {
  flex: 0 0 80rpx;
  height: 4rpx;
  background: #cbd5e1;
}

.step-line.done { background: #16a34a; }

/* 病历回顾条 */
.record-recap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  border-radius: 18rpx;
  padding: 14rpx 18rpx;
  margin-bottom: 22rpx;
}

.record-recap-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.record-recap-text {
  flex: 1;
  font-size: 28rpx;
  color: #1e3a8a;
  line-height: 1.5;
}

.record-recap-link {
  font-size: 26rpx;
  color: #2563eb;
  text-decoration: underline;
  flex-shrink: 0;
}

/* 统计 */
.match-stats {
  display: flex;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.stat-item {
  flex: 1;
  background: #fff;
  border-radius: 22rpx;
  padding: 18rpx 16rpx;
  border: 1rpx solid #e2e8f0;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #16344b;
}

.stat-label {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #374151;
}

.score-rule-tip {
  margin: 6rpx 0 14rpx;
}

.score-rule-tip text {
  font-size: 26rpx;
  color: #334155;
  line-height: 1.6;
}

/* 匹配卡片 */
.matches-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.match-card {
  background: #fff;
  border-radius: 26rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.04);
}

.human-reason {
  background: linear-gradient(145deg, #ecfdf5 0%, #d1fae5 100%);
  border-radius: 14rpx;
  padding: 12rpx 16rpx;
  font-size: 26rpx;
  color: #065f46;
  font-weight: 500;
  line-height: 1.55;
  margin-bottom: 16rpx;
}

.match-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.match-content { flex: 1; }

.match-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.45;
}

/* 阿里健康/美团买药货架风格：药品名作为卡片主标题 */
.drug-headline {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.drug-icon {
  font-size: 30rpx;
  line-height: 1;
  flex-shrink: 0;
}

.drug-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.3;
}

.drug-code {
  font-size: 26rpx;
  color: #475569;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.drug-subline {
  display: block;
  font-size: 26rpx;
  color: #1e293b;
  line-height: 1.5;
}

.drug-class,
.drug-form,
.drug-brand {
  display: inline;
  font-size: 26rpx;
  color: #1e293b;
}

.match-header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  flex-shrink: 0;
}

.match-score-badge {
  border-radius: 16rpx;
  padding: 8rpx 14rpx;
  text-align: center;
  background: #f1f5f9;
}

.match-score-badge.level-high {
  background: linear-gradient(145deg, #ecfdf5 0%, #d1fae5 100%);
}

.match-score-badge.level-mid {
  background: linear-gradient(145deg, #eff6ff 0%, #dbeafe 100%);
}

.match-score-badge.level-low {
  background: linear-gradient(145deg, #fff7ed 0%, #fed7aa 100%);
}

.score {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.label {
  display: block;
  font-size: 22rpx;
  color: #374151;
}

.match-expand-indicator {
  font-size: 24rpx;
  color: #16344b;
}

.match-card-summary { margin-top: 14rpx; }

.match-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: 24rpx;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
  line-height: 1.5;
}

.tag-level.level-high { background: #d1fae5; color: #065f46; }
.tag-level.level-mid { background: #dbeafe; color: #1e40af; }
.tag-level.level-low { background: #fed7aa; color: #9a3412; }
.tag-primary { background: #e0e7ff; color: #3730a3; }
.tag-warning { background: #fef3c7; color: #92400e; }

/* 绿色"免费用药"标签 —— 强 CTA 视觉锚（仿阿里健康"立即购买"价格位） */
.tag-free {
  background: linear-gradient(145deg, #15803d 0%, #16a34a 100%);
  color: #fff;
  font-weight: 700;
  padding: 6rpx 18rpx;
  font-size: 24rpx;
  letter-spacing: 0.5rpx;
  box-shadow: 0 4rpx 10rpx rgba(21, 128, 61, 0.25);
}

.match-indication {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.5;
}

.match-source {
  display: block;
  font-size: 26rpx;
  color: #475569;
  margin-top: 6rpx;
  line-height: 1.55;
}

.match-card-expanded {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx dashed #e2e8f0;
}

.decision-banner {
  border-radius: 14rpx;
  padding: 14rpx 16rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid #16344b;
  background: #f8fafc;
}

.decision-banner.tone-positive { border-left-color: #10b981; background: #ecfdf5; }
.decision-banner.tone-neutral { border-left-color: #2563eb; background: #eff6ff; }
.decision-banner.tone-caution { border-left-color: #f59e0b; background: #fff7ed; }

.decision-label {
  display: block;
  font-size: 24rpx;
  color: #1e293b;
  margin-bottom: 4rpx;
}

.decision-text {
  font-size: 28rpx;
  color: #0f172a;
  line-height: 1.55;
}

.detail-panel { margin-top: 14rpx; }

.detail-panel-title {
  display: block;
  font-size: 26rpx;
  color: #334155;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.sub-center-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.sub-center-chip {
  background: #eff6ff;
  color: #1e40af;
  font-size: 26rpx;
  border-radius: 999rpx;
  padding: 4rpx 16rpx;
}

.meta-line {
  display: block;
  font-size: 28rpx;
  color: #1e293b;
  line-height: 1.7;
}

.criteria-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.criteria-icon {
  font-size: 28rpx;
  font-weight: 700;
  width: 28rpx;
  flex-shrink: 0;
  text-align: center;
  line-height: 1.55;
}

.criteria-item.inclusion .criteria-icon { color: #10b981; }
.criteria-item.exclusion .criteria-icon { color: #ef4444; }

.criteria-text {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.55;
}

/* 转化 CTA */
.cta-section {
  margin-top: 36rpx;
  background: linear-gradient(145deg, #16344b 0%, #1f4e5f 48%, #2f6f75 100%);
  border-radius: 32rpx;
  padding: 32rpx 28rpx;
  text-align: center;
  box-shadow: 0 22rpx 42rpx rgba(15, 52, 75, 0.18);
}

.cta-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
}

.cta-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.55;
  margin-bottom: 28rpx;
}

.cta-button {
  background: #fff;
  border-radius: 22rpx;
  padding: 24rpx 0;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.18);
}

.cta-button-hover {
  transform: scale(0.985);
  background: #f1f5f9;
}

.cta-button-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #16344b;
  letter-spacing: 2rpx;
}

.cta-back {
  display: inline-block;
  margin-top: 22rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  text-decoration: underline;
}
