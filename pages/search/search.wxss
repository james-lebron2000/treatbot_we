/* search —— Plan §G token-swap polish
 * 「token 化但不重设计」：替换 Ant Design (#1890ff/#52c41a/#faad14) */
.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: var(--bg);
  border-bottom: 2rpx solid var(--line);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--bg-soft);
  border-radius: var(--r-pill);
  padding: 16rpx 24rpx;
  margin-right: 20rpx;
}

.search-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  color: var(--text-muted);
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}

.clear-btn {
  width: 36rpx;
  height: 36rpx;
  background: var(--text-muted);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-btn text {
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

.filter-btn {
  display: flex;
  align-items: center;
  padding: 16rpx;
}

.filter-btn text {
  font-size: 28rpx;
  color: var(--brand);
  font-weight: 600;
}

.filter-arrow {
  font-size: 24rpx;
  margin-left: 8rpx;
  color: var(--brand);
  transition: transform 0.3s;
}

.filter-arrow.up {
  transform: rotate(180deg);
}

.filter-panel {
  background: var(--bg);
  padding: 30rpx;
  border-bottom: 2rpx solid var(--line);
}

.filter-section {
  margin-bottom: 30rpx;
}

.filter-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.filter-option {
  padding: 12rpx 24rpx;
  background: var(--bg-soft);
  color: var(--text-dim);
  border-radius: var(--r-pill);
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.filter-option.active {
  background: var(--brand);
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(37, 99, 235, 0.25);
}

.filter-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
}

.filter-actions .btn {
  flex: 1;
  height: 80rpx;
  border-radius: var(--r-pill);
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-actions .btn-default {
  background: var(--bg);
  color: var(--brand);
  border: 2rpx solid var(--brand-soft);
}

.filter-actions .btn-primary {
  background: var(--brand);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
}

.search-history {
  padding: 30rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.01em;
}

.clear-history {
  font-size: 26rpx;
  color: var(--text-muted);
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 14rpx 22rpx;
  background: var(--bg-soft);
  border-radius: var(--r-pill);
}

.history-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  color: var(--text-muted);
}

.history-text {
  font-size: 26rpx;
  color: var(--text-dim);
}

.search-results {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.results-header {
  padding: 20rpx 30rpx;
  background: var(--bg-soft);
}

.results-count {
  font-size: 26rpx;
  color: var(--text-dim);
}

.results-list {
  flex: 1;
  padding: 20rpx 30rpx;
}

.result-card {
  background: var(--bg);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
  border: 2rpx solid var(--line);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.result-phase {
  background: var(--brand-soft);
  color: var(--brand);
  padding: 6rpx 14rpx;
  border-radius: var(--r-pill);
  font-size: 24rpx;
  font-weight: 600;
}

.result-status {
  font-size: 24rpx;
  font-weight: 600;
}

.result-status.recruiting {
  color: var(--mint-text);
}

.result-status.pending {
  color: var(--amber-text);
}

.result-status.completed {
  color: var(--text-muted);
}

.result-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  line-height: var(--lh-normal);
  margin-bottom: 16rpx;
  letter-spacing: -0.01em;
}

.result-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.info-item {
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: var(--lh-normal);
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  background: var(--bg-soft);
  color: var(--text-dim);
  padding: 6rpx 14rpx;
  border-radius: var(--r-pill);
  font-size: 22rpx;
  font-weight: 600;
}

.loading-state,
.no-more {
  text-align: center;
  padding: 40rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12rpx;
  letter-spacing: -0.01em;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-dim);
  text-align: center;
  line-height: var(--lh-relaxed);
}
