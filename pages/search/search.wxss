.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
  margin-right: 20rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  background: #ccc;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-btn text {
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

.filter-btn {
  display: flex;
  align-items: center;
  padding: 16rpx;
}

.filter-btn text {
  font-size: 28rpx;
  color: #666;
}

.filter-arrow {
  font-size: 20rpx;
  margin-left: 8rpx;
  transition: transform 0.3s;
}

.filter-arrow.up {
  transform: rotate(180deg);
}

.filter-panel {
  background: #fff;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-section {
  margin-bottom: 30rpx;
}

.filter-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 12rpx 28rpx;
  background: #f5f5f5;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.filter-option.active {
  background: #1890ff;
  color: #fff;
}

.filter-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.filter-actions .btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-actions .btn-default {
  background: #f5f5f5;
  color: #666;
}

.filter-actions .btn-primary {
  background: #1890ff;
  color: #fff;
}

.search-history {
  padding: 30rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.clear-history {
  font-size: 26rpx;
  color: #999;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
}

.history-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
}

.history-text {
  font-size: 26rpx;
  color: #666;
}

.search-results {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.results-header {
  padding: 20rpx 30rpx;
  background: #f9f9f9;
}

.results-count {
  font-size: 26rpx;
  color: #666;
}

.results-list {
  flex: 1;
  padding: 20rpx 30rpx;
}

.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.result-phase {
  background: #e6f7ff;
  color: #1890ff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.result-status {
  font-size: 24rpx;
}

.result-status.recruiting {
  color: #52c41a;
}

.result-status.pending {
  color: #faad14;
}

.result-status.completed {
  color: #999;
}

.result-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.result-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.info-item {
  font-size: 26rpx;
  color: #666;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  background: #f5f5f5;
  color: #666;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.loading-state,
.no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}
