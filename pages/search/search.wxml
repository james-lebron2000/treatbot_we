<view class="container">
  <!-- 搜索栏 -->
  <view class="search-header">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索试验名称、疾病、医院..."
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        focus
      />
      <view class="clear-btn" bindtap="clearKeyword" wx:if="{{keyword}}">
        <text>×</text>
      </view>
    </view>
    <view class="filter-btn" bindtap="toggleFilter">
      <text>筛选</text>
      <text class="filter-arrow {{showFilter ? 'up' : ''}}">▼</text>
    </view>
  </view>

  <!-- 筛选面板 -->
  <view class="filter-panel" wx:if="{{showFilter}}">
    <view class="filter-section">
      <text class="filter-label">试验阶段</text>
      <view class="filter-options">
        <view 
          wx:for="{{filterOptions.phases}}" 
          wx:key="*this"
          class="filter-option {{filters.phase === (item === '全部' ? '' : item) ? 'active' : ''}}"
          bindtap="onFilterSelect"
          data-type="phase"
          data-value="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view class="filter-section">
      <text class="filter-label">所在地区</text>
      <view class="filter-options">
        <view 
          wx:for="{{filterOptions.locations}}" 
          wx:key="*this"
          class="filter-option {{filters.location === (item === '全部' ? '' : item) ? 'active' : ''}}"
          bindtap="onFilterSelect"
          data-type="location"
          data-value="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view class="filter-section">
      <text class="filter-label">招募状态</text>
      <view class="filter-options">
        <view 
          wx:for="{{filterOptions.statuses}}" 
          wx:key="*this"
          class="filter-option {{filters.status === (item === '全部' ? '' : item) ? 'active' : ''}}"
          bindtap="onFilterSelect"
          data-type="status"
          data-value="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view class="filter-actions">
      <button class="btn btn-default" bindtap="resetFilters">重置</button>
      <button class="btn btn-primary" bindtap="toggleFilter">确定</button>
    </view>
  </view>

  <!-- 搜索历史 -->
  <view class="search-history" wx:if="{{!keyword && history.length > 0}}">
    <view class="history-header">
      <text class="history-title">搜索历史</text>
      <text class="clear-history" bindtap="clearHistory">清空</text>
    </view>
    <view class="history-list">
      <view 
        wx:for="{{history}}" 
        wx:key="*this"
        class="history-item"
        bindtap="onHistoryTap"
        data-keyword="{{item}}"
      >
        <text class="history-icon">🕐</text>
        <text class="history-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="search-results" wx:if="{{results.length > 0 || loading}}">
    <view class="results-header">
      <text class="results-count">找到 {{results.length}} 个相关试验</text>
    </view>

    <scroll-view 
      scroll-y 
      class="results-list"
      lower-threshold="100"
      bindscrolltolower="onLoadMore"
    >
      <view 
        wx:for="{{results}}" 
        wx:key="id"
        class="result-card"
        bindtap="viewDetail"
        data-id="{{item.id}}"
      >
        <view class="result-header">
          <text class="result-phase">{{item.phase}}</text>
          <text class="result-status {{item.status}}">{{item.statusText}}</text>
        </view>
        <text class="result-name">{{item.name}}</text>
        <view class="result-info">
          <text class="info-item">📍 {{item.location}}</text>
          <text class="info-item">🏥 {{item.institution}}</text>
        </view>
        <view class="result-tags">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
        </view>
      </view>

      <!-- 加载状态 -->
      <view class="loading-state" wx:if="{{loading}}">
        <text>加载中...</text>
      </view>
      
      <view class="no-more" wx:if="{{!hasMore && results.length > 0}}">
        <text>没有更多了</text>
      </view>
    </scroll-view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && keyword && results.length === 0}}">
    <image class="empty-image" src="/images/empty.png" mode="aspectFit"></image>
    <text class="empty-title">未找到相关试验</text>
    <text class="empty-desc">换个关键词试试，或减少筛选条件</text>
  </view>
</view>
