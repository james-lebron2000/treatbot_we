.container {
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.skip-btn {
  position: absolute;
  top: 80rpx;
  right: 40rpx;
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
}

.skip-btn text {
  color: #fff;
  font-size: 28rpx;
}

.guide-swiper {
  flex: 1;
  width: 100%;
  height: 100%;
}

.guide-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 40rpx;
}

.guide-image {
  width: 480rpx;
  height: 480rpx;
  margin-bottom: 60rpx;
}

.guide-text {
  text-align: center;
}

.guide-title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
}

.guide-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  padding: 0 40rpx;
}

.indicator {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 60rpx;
}

.indicator-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.4);
  transition: all 0.3s;
}

.indicator-dot.active {
  width: 40rpx;
  background: #fff;
}

.button-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 40rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: #fff;
  color: #667eea;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-default {
  background: transparent;
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.btn-default::after {
  border: none;
}
