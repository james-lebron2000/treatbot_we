<view class="container">
  <view class="card trial-card">
    <view class="card-title">报名试验</view>
    <view class="trial-name">{{trialName || '未命名试验'}}</view>
    <view class="trial-meta">试验ID：{{trialId || '--'}}</view>
    <view class="trial-meta" wx:if="{{trialPhase}}">分期：{{trialPhase}}</view>
    <view class="trial-meta" wx:if="{{trialLocation}}">研究中心：{{trialLocation}}</view>
  </view>

  <view class="card form-card">
    <view class="card-title">填写报名信息</view>

    <view class="form-item">
      <text class="label">姓名</text>
      <input
        class="input"
        placeholder="请输入真实姓名"
        value="{{form.name}}"
        bindinput="onNameInput"
      />
    </view>

    <view class="form-item">
      <text class="label">疾病（选填）</text>
      <input
        class="input"
        placeholder="例如：非小细胞肺癌"
        value="{{form.disease}}"
        bindinput="onDiseaseInput"
      />
    </view>

    <view class="form-item">
      <text class="label">手机号（选填）</text>
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="如需后续联系，可填写手机号"
        value="{{form.phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="tips">手机号仅在你主动报名时用于后续联系，不影响病历识别和匹配。</view>
  </view>

  <!-- P0：报名前强制知情同意。报名 = 把病历交给申办方/CRO 做入组评估，必须显式勾选。 -->
  <view class="card consent-card">
    <view class="card-title">{{consent.title}}</view>
    <view class="consent-bullets">
      <view class="consent-bullet" wx:for="{{consent.bullets}}" wx:key="*this">
        <icon name="check" color="brand" size="26" strokeWidth="2.5" />
        <text class="consent-bullet-text">{{item}}</text>
      </view>
    </view>
    <view class="consent-check" bindtap="toggleConsent">
      <view class="consent-box {{consentChecked ? 'checked' : ''}}">
        <icon wx:if="{{consentChecked}}" name="check" color="white" size="26" strokeWidth="3" />
      </view>
      <text class="consent-check-text">{{consent.checkbox}}</text>
    </view>
  </view>

  <view class="action-bar">
    <button class="btn btn-primary" bindtap="submitApplication" loading="{{submitting}}" disabled="{{!consentChecked}}">
      提交报名
    </button>
  </view>

  <medical-disclaimer />
</view>
