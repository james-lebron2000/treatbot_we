/* matches/apply —— Plan §G token-swap polish */
.trial-card {
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12rpx;
  letter-spacing: -0.01em;
}

.trial-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  line-height: var(--lh-normal);
  margin-bottom: 10rpx;
  letter-spacing: -0.01em;
}

.trial-meta {
  display: block;
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: var(--lh-relaxed);
}

.form-card {
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 22rpx;
}

.form-item:last-of-type {
  margin-bottom: 12rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 10rpx;
}

.input {
  height: 84rpx;
  border-radius: 14rpx;
  border: 2rpx solid var(--line);
  background: var(--bg-soft);
  color: var(--text);
  padding: 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.tips {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: var(--lh-relaxed);
}

.action-bar {
  padding-top: 4rpx;
}

/* ===== P0 知情同意 ===== */
.consent-card {
  /* 复用 .card 基线样式 */
}

.consent-bullets {
  margin: 16rpx 0 24rpx;
}

.consent-bullet {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.consent-bullet-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--text);
}

.consent-check {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--bg-soft);
  border-radius: 16rpx;
}

.consent-box {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--text-muted);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
}

.consent-box.checked {
  background: var(--brand);
  border-color: var(--brand);
}

.consent-check-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--text);
}
