<view class="container">
  <view class="page-header">
    <view class="page-title-group">
      <text class="page-title">为家人找到的新药</text>
      <text class="page-subtitle">围绕您上传的病历，为家人找出可能能免费用上的新药。</text>
    </view>
    <view class="filter-btn" bindtap="loadMatches">
      <text>刷新</text>
    </view>
  </view>

  <!-- 2026-05 UX：信任三件套。家属对「免费」二字本能怀疑，必须在折叠态就把
       「谁审核 / 数据从哪来 / 收不收钱」摆在眼前。三个 chip 各一句，不超 14 字。 -->
  <view class="trust-strip">
    <view class="trust-chip">
      <icon name="shield-check" color="mint" size="24" />
      <text>肿瘤科医师人工复核</text>
    </view>
    <view class="trust-chip">
      <icon name="clipboard-list" color="brand" size="24" />
      <text>药监局 + 临床试验官方库</text>
    </view>
    <view class="trust-chip">
      <icon name="lock" color="lilac" size="24" />
      <text>全程免费 · 不卖信息</text>
    </view>
  </view>

  <!-- PRD-2026Q2 §P1-5：每个 stat 加 8 字内说明。
       旧版只有数字 + 短标签，「高度匹配 / 值得优先申请」语义重叠，家属看不懂区别。
       新版 caption 给出具体判定依据。 -->
  <view class="match-stats">
    <view class="stat-item">
      <text class="stat-value">{{matches.length}}</text>
      <text class="stat-label">找到的新药</text>
      <text class="match-stat-caption">含已申请 {{appliedCount}} 种</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{highMatches}}</text>
      <text class="stat-label">高度匹配</text>
      <text class="match-stat-caption">诊断+基因都对得上</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{readyMatches}}</text>
      <text class="stat-label">值得优先申请</text>
      <text class="match-stat-caption">入组评估通过</text>
    </view>
  </view>

  <view class="score-rule-tip">
    <text>我们先展示最匹配的几种新药 · 数量少会自动放宽标准让您多几个选择。</text>
  </view>

  <view class="score-fallback-tip" wx:if="{{lowScoreMode}}">
    <text>暂时没有高度匹配的新药 —— 我们放宽了标准，下面是还值得一看的候选。</text>
  </view>

  <!-- PRD-2026Q2 §P1-3：从内嵌 markup 改为 <parse-progress-banner> 共用组件，
       与 index 同位进度条视觉一致；改一处生效两处。 -->
  <parse-progress-banner
    wx:if="{{activeParseTask}}"
    title="病历还在帮您看懂中"
    progress="{{activeParseTask.progress}}"
    statusText="{{activeParseTask.text}}"
    class="processing-banner-wrap"
  />

  <view class="supplement-tip" wx:if="{{!loading && needSupplement > 0}}">
    <text class="supplement-text">再补一点病历信息，{{needSupplement}} 种新药会评得更准。</text>
    <button class="supplement-btn" bindtap="goToUpload">去补一补</button>
  </view>

  <view class="fallback-tip" wx:if="{{usingFallback}}">
    <text>{{fallbackMessage || '先给您看一个参考版本，正式结果马上就好'}}</text>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>正在为家人找合适的新药…</text>
  </view>

  <view class="empty-state" wx:if="{{!loading && errorMessage}}">
    <text>{{errorMessage}}</text>
  </view>

  <view class="matches-list" wx:if="{{!loading && !errorMessage && matches.length > 0}}">
    <view class="match-card" wx:for="{{matches}}" wx:key="id">
      <!-- 2026-05 重设计：卡片折叠态只保留患者/家属真正需要的三件事 —— 是什么药、有多匹配、谁来提供。
           原来的「为什么适合」(humanReason)、药物分类/剂型副标题、三色标签 (免费/高度匹配/I期)、
           主治线均移除：要么重复（page-title 已说明免费用药范围、score badge 已表达匹配度），
           要么对家属决策没增量信息（drugClass/drugForm/phase 都属于专业元信息）。
           需要更详细信息的家属点 chevron 展开 → decisionHint + 医院 + 入组/排除标准。 -->
      <view class="match-card-header" bindtap="toggleMatchExpand" data-id="{{item.id}}">
        <view class="match-content">
          <view class="drug-headline">
            <icon name="pill" color="lilac" size="36" />
            <text class="drug-name">{{item.drugName}}</text>
            <text class="drug-code" wx:if="{{item.drugCode}}">/ {{item.drugCode}}</text>
          </view>
          <text class="match-source" wx:if="{{item.manufacturer}}">{{item.manufacturer}}<text wx:if="{{item.institution && item.institution !== '待补'}}"> ｜ {{item.institution}}</text></text>
          <!-- 2026-05 UX：把「我们的看法」从展开态提到折叠态。家属盯着 87% 不知道
               87 算好算坏，但一眼看到「建议优先了解」就能立刻判断要不要点开。
               展开态里这条会消失（避免重复）。 -->
          <view class="decision-glance tone-{{item.decisionTone}}" wx:if="{{item.decisionHint && !item.expanded}}">
            <icon name="lightbulb" color="{{item.decisionTone === 'good' ? 'mint' : item.decisionTone === 'warn' ? 'amber' : item.decisionTone === 'risk' ? 'red' : 'brand'}}" size="24" />
            <text class="decision-glance-text">{{item.decisionHint}}</text>
          </view>
        </view>
        <view class="match-header-right">
          <view class="match-expand-indicator {{item.expanded ? 'expanded' : ''}}" aria-label="{{item.expanded ? '收起' : '看详情'}}">
            <icon name="chevron-right" color="text-dim" size="32" />
          </view>
          <view class="match-score-badge">
            <text class="score">{{item.score}}%</text>
            <text class="label">匹配度</text>
          </view>
        </view>
      </view>

      <view wx:if="{{item.expanded}}" class="match-card-expanded">
        <view class="decision-banner tone-{{item.decisionTone}}">
          <text class="decision-label">我们的看法</text>
          <text class="decision-text">{{item.decisionHint}}</text>
        </view>

        <view class="detail-panel">
          <text class="detail-panel-title">提供这种新药的医院</text>
          <view class="sub-center-list" wx:if="{{item.subCenters.length > 0}}">
            <text class="sub-center-chip" wx:for="{{item.subCenters}}" wx:for-item="center" wx:key="index">{{center}}</text>
          </view>
          <view class="column-empty" wx:else>
            <text>医院信息还没拿到，我们会继续跟进</text>
          </view>
        </view>

        <view class="detail-panel">
          <text class="detail-panel-title">来源信息</text>
          <text class="match-meta" wx:if="{{item.manufacturer}}">药企：{{item.manufacturer}}</text>
          <text class="match-meta" wx:if="{{item.institution}}">主导医院：{{item.institution}}</text>
          <text class="match-meta" wx:if="{{item.nctId}}">研究编号：{{item.nctId}}</text>
          <text class="match-meta" wx:if="{{item.status}}">招募状态：{{item.status}}</text>
        </view>

        <view class="detail-panel" wx:if="{{item.inclusion.length > 0}}">
          <text class="detail-panel-title">能用这种新药的条件</text>
          <view class="criteria-item inclusion" wx:for="{{item.inclusion}}" wx:for-item="criterion" wx:key="index">
            <icon name="check" color="mint" size="28" strokeWidth="2.5" />
            <text class="criteria-text">{{criterion}}</text>
          </view>
        </view>

        <view class="detail-panel" wx:if="{{item.exclusion.length > 0}}">
          <text class="detail-panel-title">不能用这种新药的情况</text>
          <view class="criteria-item exclusion" wx:for="{{item.exclusion}}" wx:for-item="criterion" wx:key="index">
            <icon name="x-circle" color="red" size="28" strokeWidth="2" />
            <text class="criteria-text">{{criterion}}</text>
          </view>
        </view>

        <view class="match-actions">
          <button class="btn btn-default" catchtap="viewDetail" data-id="{{item.id}}">看用药详情</button>
          <button class="btn btn-primary apply-btn" catchtap="applyTrial" data-id="{{item.id}}">
            <icon name="phone-call" color="white" size="32" />
            <!-- 2026-05 UX：「申请免费用药」对焦虑家属来说承诺感太重，「免费」二字
                 又像广告 —— 改成「我想申请这个」语气轻，决策门槛低。「免费」信息
                 由 page-title 和 trust-strip 承担。 -->
            <text class="apply-btn-text">我想申请这个</text>
          </button>
        </view>
        <!-- 2026-05 UX：期望管理 + 信任补强。「申请按下去会怎样」是家属最大的黑箱
             焦虑；把「2-3 天回电 / 全程免费 / 不卖信息」摆出来，让她敢按下去。 -->
        <view class="match-expectation">
          <icon name="alert-circle" color="text-dim" size="22" />
          <text>申请后通常 2-3 天医院主动联系您 · 全程不收家属一分钱 · 不会把您的信息卖给任何人</text>
        </view>
        <!-- 2026-05 UX：「发给医生看看」是最强的口碑发动机。主治医生背书是中国家庭
             决策催化剂；同时家属在病友群转发这个「医生版方案」的概率远高于转发
             小程序链接。catchtap 防止冒泡触发卡片收起。 -->
        <view class="match-share-row">
          <view class="share-link" catchtap="shareToDoctor" data-id="{{item.id}}">
            <icon name="file-text" color="text-dim" size="26" />
            <text>打印给医生看看</text>
          </view>
          <view class="share-link" catchtap="shareToFamily" data-id="{{item.id}}">
            <icon name="arrow-right" color="text-dim" size="26" />
            <text>发给家人讨论</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- PRD-2026Q2 §P0-4：0 结果不能死循环「再找一次」。
       三步兜底：订阅通知（被动等）/ 拨打客服（主动找人）/ 覆盖范围说明（缓解疑虑）。 -->
  <view class="empty-state" wx:if="{{!loading && !errorMessage && matches.length === 0}}">
    <view class="empty-hero">
      <icon name="search" color="text-muted" size="120" strokeWidth="1.5" />
      <view class="empty-title">{{emptyCopy.title}}</view>
      <view class="empty-subtitle">{{emptyCopy.subtitle}}</view>
    </view>

    <view class="empty-cards">
      <!-- Card 1：订阅通知 -->
      <view class="empty-card empty-card-notify">
        <view class="empty-card-head">
          <view class="empty-card-icon empty-card-icon-brand">
            <icon name="{{emptyCopy.notify.icon}}" color="brand" size="40" />
          </view>
          <view class="empty-card-title">{{emptyCopy.notify.title}}</view>
        </view>
        <view class="empty-card-desc">{{emptyCopy.notify.desc}}</view>
        <button class="btn btn-ghost empty-card-btn" bindtap="notifyOnNewMatch">
          {{emptyCopy.notify.cta}}
        </button>
      </view>

      <!-- Card 2：拨打客服 -->
      <view class="empty-card empty-card-contact">
        <view class="empty-card-head">
          <view class="empty-card-icon empty-card-icon-mint">
            <icon name="{{emptyCopy.contact.icon}}" color="mint" size="40" />
          </view>
          <view class="empty-card-title">{{emptyCopy.contact.title}}</view>
        </view>
        <view class="empty-card-desc">{{emptyCopy.contact.desc}}</view>
        <view class="empty-card-phone">
          <text class="empty-card-phone-num">{{emptyCopy.contact.phone}}</text>
          <text class="empty-card-phone-hours">{{emptyCopy.contact.hours}}</text>
        </view>
        <button class="btn btn-primary empty-card-btn" bindtap="callSupport">
          <icon name="phone-call" color="white" size="32" />
          <text>{{emptyCopy.contact.cta}}</text>
        </button>
      </view>

      <!-- Card 3：覆盖范围说明 -->
      <view class="empty-card empty-card-coverage">
        <view class="empty-card-head">
          <view class="empty-card-icon empty-card-icon-lilac">
            <icon name="{{emptyCopy.coverage.icon}}" color="lilac" size="40" />
          </view>
          <view class="empty-card-title">{{coverageTitle}}</view>
        </view>
        <view class="empty-card-desc">{{emptyCopy.coverage.desc}}</view>
        <view class="empty-card-secondary" bindtap="loadMatches">
          <icon name="search" color="text-dim" size="28" />
          <text>再找一次</text>
        </view>
      </view>
    </view>
  </view>
  <help-fab />
</view>
