<!--pages/matches/matches.wxml-->
<view class="container">
  <view class="page-header">
    <text class="page-title">试验匹配</text>
    <view class="filter-btn">
      <text>筛选</text>
    </view>
  </view>

  <!-- 匹配统计 -->
  <view class="match-stats">
    <view class="stat-item">
      <text class="stat-value">{{matches.length}}</text>
      <text class="stat-label">匹配试验</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{highMatches}}</text>
      <text class="stat-label">高匹配度(>80%)</text>
    </view>
  </view>

  <!-- 匹配列表 -->
  <view class="matches-list">
    <view class="match-card" wx:for="{{matches}}" wx:key="id">
      <view class="match-score-badge">
        <text class="score">{{item.score}}%</text>
        <text class="label">匹配度</text>
      </view>
      
      <view class="match-content">
        <text class="match-title">{{item.name}}</text>
        <view class="match-tags">
          <text class="tag tag-primary">{{item.phase}}</text>
          <text class="tag tag-success">{{item.location}}</text>
          <text class="tag tag-warning">{{item.type}}</text>
        </view>
        <text class="match-indication">适应症：{{item.indication}}</text>
        <text class="match-institution">{{item.institution}}</text>
      </view>

      <view class="match-reasons">
        <view class="reason-title">匹配理由：</view>
        <view class="reason-item" wx:for="{{item.reasons}}" wx:key="*this" wx:for-item="reason">
          <text class="reason-icon">✓</text>
          <text>{{reason}}</text>
        </view>
      </view>

      <view class="match-actions">
        <button class="btn btn-default" bindtap="viewDetail" data-id="{{item.id}}">查看详情</button>
        <button class="btn btn-primary" bindtap="applyTrial" data-id="{{item.id}}">立即报名</button>
      </view>
    </view>
  </view>
</view>