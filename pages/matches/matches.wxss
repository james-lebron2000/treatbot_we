.page-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.page-title-group {
  flex: 1;
}

.page-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
}

.filter-btn {
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.04);
}

.match-stats {
  display: flex;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.stat-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.86);
  border-radius: 26rpx;
  padding: 24rpx 14rpx;
  text-align: center;
  border: 1rpx solid rgba(15, 23, 42, 0.05);
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.05);
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.45;
}

.score-rule-tip,
.score-fallback-tip,
.supplement-tip,
.fallback-tip,
.processing-banner {
  border-radius: 24rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  line-height: 1.65;
}

.score-rule-tip {
  background: rgba(37, 99, 235, 0.08);
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  color: #1d4ed8;
}

.score-fallback-tip,
.supplement-tip,
.fallback-tip {
  background: rgba(217, 119, 6, 0.08);
  border: 1rpx solid rgba(217, 119, 6, 0.12);
  color: #b45309;
}

.processing-banner {
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(15, 23, 42, 0.05);
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.05);
}

.processing-banner-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.processing-banner-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.processing-banner-progress {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d4ed8;
}

.processing-banner-text {
  display: block;
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 14rpx;
}

.processing-banner-bar {
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(29, 78, 216, 0.08);
  overflow: hidden;
}

.processing-banner-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #111827 0%, #2563eb 100%);
}

.supplement-text {
  display: block;
}

.supplement-btn {
  margin-top: 14rpx;
  height: 68rpx;
  line-height: 68rpx;
  font-size: 26rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #fff;
}

.matches-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.match-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  padding: 28rpx 24rpx 24rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 20rpx 40rpx rgba(15, 23, 42, 0.06);
}

/* U4：卡片顶部的人话理由 —— 紧贴 padding 顶部，绿色 14sp，不抢占 score 视觉权重。 */
.human-reason {
  display: block;
  margin: -8rpx 0 14rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #0A6E3A;
  font-weight: 500;
}

.match-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.match-header-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.match-score-badge {
  width: 106rpx;
  height: 106rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #111827 0%, #334155 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.18);
}

.match-score-badge .score {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
}

.match-score-badge .label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
}

.match-content {
  flex: 1;
  padding-right: 0;
  margin-bottom: 0;
}

.match-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.42;
  margin-bottom: 0;
}

/* 阿里健康/美团买药货架风格：药品名作为卡片主标题 */
.drug-headline {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.drug-icon {
  font-size: 30rpx;
  line-height: 1;
  flex-shrink: 0;
}

.drug-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.3;
}

.drug-code {
  font-size: 26rpx;
  color: #475569;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.drug-subline {
  display: block;
  font-size: 26rpx;
  color: #1e293b;
  line-height: 1.5;
}

.drug-class,
.drug-form,
.drug-brand {
  display: inline;
  font-size: 26rpx;
  color: #1e293b;
}

/* 绿色"免费用药"标签 —— 强 CTA 视觉锚 */
.tag-free {
  background: linear-gradient(145deg, #15803d 0%, #16a34a 100%);
  color: #fff;
  font-weight: 700;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  letter-spacing: 0.5rpx;
  box-shadow: 0 4rpx 10rpx rgba(21, 128, 61, 0.25);
}

.match-source {
  display: block;
  font-size: 28rpx;
  color: #374151;
  margin-top: 6rpx;
  line-height: 1.55;
}

.match-expand-indicator {
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
}

.match-card-summary {
  margin-bottom: 4rpx;
}

.match-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.tag-level {
  font-weight: 700;
}

.level-high {
  background: rgba(21, 128, 61, 0.1);
  color: #15803d;
}

.level-mid {
  background: rgba(217, 119, 6, 0.1);
  color: #b45309;
}

.level-low {
  background: rgba(15, 23, 42, 0.07);
  color: #1e293b;
}

.match-indication,
.match-institution,
.match-meta,
.match-summary {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #4b5563;
}

.match-meta,
.match-summary {
  margin-top: 8rpx;
}

.match-card-expanded {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(15, 23, 42, 0.06);
}

.decision-banner {
  border-radius: 20rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.decision-label {
  font-size: 24rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
}

.decision-text {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.45;
}

.tone-good {
  background: rgba(21, 128, 61, 0.08);
  border: 1rpx solid rgba(21, 128, 61, 0.12);
  color: #15803d;
}

.tone-normal {
  background: rgba(37, 99, 235, 0.08);
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  color: #1d4ed8;
}

.tone-warn {
  background: rgba(217, 119, 6, 0.08);
  border: 1rpx solid rgba(217, 119, 6, 0.12);
  color: #b45309;
}

.tone-risk {
  background: rgba(185, 28, 28, 0.08);
  border: 1rpx solid rgba(185, 28, 28, 0.12);
  color: #b91c1c;
}

.detail-panel {
  background: rgba(248, 250, 252, 0.88);
  border-radius: 22rpx;
  padding: 18rpx;
  margin-bottom: 14rpx;
}

.detail-panel-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.sub-center-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.sub-center-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.08);
  color: #1d4ed8;
  font-size: 24rpx;
  font-weight: 600;
}

.column-empty {
  color: #374151;
}

.column-empty text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.55;
}

.criteria-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.criteria-item:last-child {
  margin-bottom: 0;
}

.criteria-icon {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.4;
}

.criteria-item.inclusion .criteria-icon {
  color: #15803d;
}

.criteria-item.exclusion .criteria-icon {
  color: #b91c1c;
}

.criteria-text {
  flex: 1;
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
}

.match-actions {
  display: flex;
  gap: 14rpx;
}

.match-actions .btn {
  flex: 1;
}
