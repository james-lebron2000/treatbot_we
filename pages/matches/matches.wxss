/* pages/matches/matches.wxss */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.filter-btn {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.match-stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.matches-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.match-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.match-score-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #52c41a 0%, #95de64 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.match-score-badge .score {
  font-size: 32rpx;
  font-weight: 700;
}

.match-score-badge .label {
  font-size: 18rpx;
}

.match-content {
  padding-right: 120rpx;
  margin-bottom: 20rpx;
}

.match-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.match-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.match-indication {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.match-institution {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.match-reasons {
  background: #f6ffed;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.reason-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #52c41a;
  margin-bottom: 12rpx;
}

.reason-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.reason-icon {
  color: #52c41a;
  font-weight: bold;
}

.match-actions {
  display: flex;
  gap: 20rpx;
}

.match-actions .btn {
  flex: 1;
}