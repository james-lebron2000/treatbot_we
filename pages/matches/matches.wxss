/* pages/matches/matches.wxss */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
}

.filter-btn {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 30rpx;
  color: #666;
}

.match-stats {
  display: flex;
  gap: 14rpx;
  margin-bottom: 30rpx;
}

.score-rule-tip {
  background: #f0f5ff;
  border: 1rpx solid #adc6ff;
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  margin-bottom: 18rpx;
  color: #1d39c4;
  font-size: 25rpx;
  line-height: 1.5;
}

.score-fallback-tip {
  background: #fff7e6;
  border: 1rpx solid #ffd591;
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  margin-bottom: 18rpx;
  color: #ad6800;
  font-size: 25rpx;
  line-height: 1.5;
}

.supplement-tip {
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  border-radius: 12rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 20rpx;
}

.supplement-text {
  display: block;
  color: #ad6800;
  font-size: 27rpx;
  line-height: 1.5;
}

.supplement-btn {
  margin-top: 14rpx;
  height: 68rpx;
  line-height: 68rpx;
  font-size: 26rpx;
  border-radius: 10rpx;
  background: #fa8c16;
  color: #fff;
}

.fallback-tip {
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 24rpx;
  color: #ad6800;
  font-size: 28rpx;
  line-height: 1.5;
}

.stat-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stat-value {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 25rpx;
  color: #666;
  line-height: 1.4;
}

.matches-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.match-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.match-score-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #52c41a 0%, #95de64 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.match-score-badge .score {
  font-size: 32rpx;
  font-weight: 700;
}

.match-score-badge .label {
  font-size: 20rpx;
}

.match-content {
  padding-right: 120rpx;
  margin-bottom: 16rpx;
}

.match-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.match-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag-level {
  font-weight: 600;
}

.level-high {
  background: #f6ffed;
  color: #389e0d;
}

.level-mid {
  background: #fffbe6;
  color: #ad6800;
}

.level-low {
  background: #f5f5f5;
  color: #595959;
}

.match-indication {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.match-institution {
  display: block;
  font-size: 28rpx;
  color: #999;
  line-height: 1.5;
}

.match-meta {
  display: block;
  font-size: 25rpx;
  color: #8c8c8c;
  margin-top: 6rpx;
}

.match-summary {
  display: block;
  font-size: 27rpx;
  color: #666;
  margin-top: 10rpx;
  line-height: 1.5;
}

.decision-banner {
  border-radius: 14rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.decision-label {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
}

.decision-text {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
}

.tone-good {
  background: #f6ffed;
  border: 1rpx solid #d9f7be;
  color: #389e0d;
}

.tone-normal {
  background: #e6f7ff;
  border: 1rpx solid #bae7ff;
  color: #096dd9;
}

.tone-warn {
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  color: #ad6800;
}

.tone-risk {
  background: #fff2f0;
  border: 1rpx solid #ffccc7;
  color: #cf1322;
}

.explain-board {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.explain-column {
  border-radius: 12rpx;
  padding: 14rpx;
}

.column-hit {
  background: #f6ffed;
  border: 1rpx solid #d9f7be;
}

.column-risk {
  background: #fff7e6;
  border: 1rpx solid #ffd591;
}

.column-missing {
  background: #e6f7ff;
  border: 1rpx solid #bae7ff;
}

.column-title {
  font-size: 27rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.column-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.column-icon {
  width: 26rpx;
  text-align: center;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.4;
}

.column-icon.hit {
  color: #389e0d;
}

.column-icon.risk {
  color: #d46b08;
}

.column-icon.missing {
  color: #096dd9;
}

.column-text {
  flex: 1;
  font-size: 24rpx;
  color: #434343;
  line-height: 1.5;
}

.column-empty {
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 1.5;
}

.column-empty.safe {
  color: #389e0d;
}

.match-actions {
  display: flex;
  gap: 20rpx;
}

.match-actions .btn {
  flex: 1;
}
