/* matches 页 —— Apple-cozy 重设计（Plan §E.3）
 * 一种主色（var(--brand)）+ companion soft/text 状态色 + 实白卡 + 1rpx 边
 * 删除：dark gradient score badge / glass morphism / 8% opacity tint */

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.page-title-group {
  flex: 1;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
  line-height: var(--lh-tight);
  letter-spacing: -0.01em;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: var(--lh-relaxed);
}

.filter-btn {
  padding: 14rpx 28rpx;
  background: var(--bg);
  border-radius: var(--r-pill);
  border: 2rpx solid var(--brand-soft);
  font-size: 26rpx;
  font-weight: 600;
  color: var(--brand);
}

.match-stats {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  background: var(--bg);
  border-radius: 28rpx;
  padding: 28rpx 14rpx;
  text-align: center;
  border: 2rpx solid var(--line);
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--brand);
  margin-bottom: 6rpx;
  line-height: 1;
  letter-spacing: -0.01em;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: var(--lh-normal);
}

.score-rule-tip,
.score-fallback-tip,
.supplement-tip,
.fallback-tip,
.processing-banner {
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  line-height: var(--lh-relaxed);
}

.score-rule-tip {
  background: var(--brand-soft);
  color: var(--brand);
}

.score-fallback-tip,
.supplement-tip,
.fallback-tip {
  background: var(--amber-soft);
  color: var(--amber-text);
}

.processing-banner {
  background: var(--bg);
  border: 2rpx solid var(--line);
}

.processing-banner-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.processing-banner-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.processing-banner-progress {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--brand);
}

.processing-banner-text {
  display: block;
  font-size: 26rpx;
  color: var(--text-dim);
  margin-bottom: 14rpx;
}

.processing-banner-bar {
  height: 10rpx;
  border-radius: var(--r-pill);
  background: var(--brand-soft);
  overflow: hidden;
}

.processing-banner-fill {
  height: 100%;
  border-radius: var(--r-pill);
  background: var(--brand);
  transition: width 200ms ease-out;
}

.supplement-text {
  display: block;
  color: var(--amber-text);
}

.supplement-btn {
  margin-top: 14rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  border-radius: var(--r-pill);
  background: var(--bg);
  color: var(--brand);
  border: 2rpx solid var(--brand-soft);
  font-weight: 600;
}

.matches-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.match-card {
  background: var(--bg);
  border-radius: 32rpx;
  padding: 28rpx 24rpx 24rpx;
  border: 2rpx solid var(--line);
  transition: transform 150ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 150ms;
}

.match-card:active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-1);
}

/* U4：人话理由 —— Lucide check icon + mint 文本，置顶给一行解释 */
.human-reason {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin: 0 0 16rpx;
  padding: 14rpx 16rpx;
  background: var(--mint-soft);
  border-radius: 16rpx;
}

.human-reason-text {
  flex: 1;
  font-size: 28rpx;
  line-height: var(--lh-normal);
  color: var(--mint-text);
  font-weight: 600;
}

.match-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.match-header-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

/* Score badge —— 实色 brand 圆，去除 dark gradient */
.match-score-badge {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: var(--brand);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
}

.match-score-badge .score {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.01em;
}

.match-score-badge .label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.match-content {
  flex: 1;
}

.match-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  line-height: var(--lh-normal);
}

/* 货架卡片 header —— 药品名为主标题，icon 在前 */
.drug-headline {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.drug-name {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text);
  line-height: var(--lh-tight);
  letter-spacing: -0.01em;
}

.drug-code {
  font-size: 26rpx;
  color: var(--text-muted);
  font-weight: 600;
}

.drug-subline {
  display: block;
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: var(--lh-normal);
}

.drug-class,
.drug-form,
.drug-brand {
  display: inline;
  font-size: 26rpx;
  color: var(--text-dim);
}

/* 标签系统：复用 app.wxss .pill 体系；这里只声明 .tag 别名容器样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: var(--r-pill);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.tag-free {
  background: var(--mint);
  color: #fff;
}

.tag-primary {
  background: var(--brand-soft);
  color: var(--brand);
}

.tag-level {
  font-weight: 600;
}

.level-high {
  background: var(--mint-soft);
  color: var(--mint-text);
}

.level-mid {
  background: var(--amber-soft);
  color: var(--amber-text);
}

.level-low {
  background: var(--bg-soft);
  color: var(--text-dim);
}

.match-source {
  display: block;
  font-size: 26rpx;
  color: var(--text-dim);
  margin-top: 6rpx;
  line-height: var(--lh-normal);
}

.match-expand-indicator {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-dim);
}

.match-card-summary {
  margin-bottom: 4rpx;
}

.match-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.match-indication,
.match-institution,
.match-meta,
.match-summary {
  display: block;
  font-size: 26rpx;
  line-height: var(--lh-relaxed);
  color: var(--text-dim);
}

.match-meta,
.match-summary {
  margin-top: 8rpx;
}

.match-card-expanded {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid var(--line);
}

/* Decision banner —— 用 companion soft/text 配色 */
.decision-banner {
  border-radius: 20rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.decision-label {
  font-size: 24rpx;
  padding: 6rpx 14rpx;
  border-radius: var(--r-pill);
  background: rgba(255, 255, 255, 0.65);
  font-weight: 600;
}

.decision-text {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  font-weight: 600;
  line-height: var(--lh-normal);
}

.tone-good {
  background: var(--mint-soft);
  color: var(--mint-text);
}

.tone-normal {
  background: var(--brand-soft);
  color: var(--brand);
}

.tone-warn {
  background: var(--amber-soft);
  color: var(--amber-text);
}

.tone-risk {
  background: var(--red-soft);
  color: var(--red-text);
}

.detail-panel {
  background: var(--bg-soft);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
}

.detail-panel-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12rpx;
}

.sub-center-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.sub-center-chip {
  padding: 8rpx 16rpx;
  border-radius: var(--r-pill);
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 24rpx;
  font-weight: 600;
}

.column-empty {
  color: var(--text-muted);
}

.column-empty text {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: var(--lh-normal);
}

.criteria-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.criteria-item:last-child {
  margin-bottom: 0;
}

.criteria-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: var(--lh-relaxed);
}

.match-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 6rpx;
}

.match-actions .btn {
  flex: 1;
}

/* 申请按钮 —— icon + 文本居中 */
.apply-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.apply-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}
