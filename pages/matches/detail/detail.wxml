<view class="container">
  <view class="loading" wx:if="{{loading}}">
    <text>试验详情加载中...</text>
  </view>

  <view class="empty-state" wx:if="{{!loading && errorMessage}}">
    <text>{{errorMessage}}</text>
  </view>

  <block wx:if="{{!loading && trial}}">
    <view class="trial-header">
      <view class="match-score">
        <text class="score-value">{{trial.score}}</text>
        <text class="score-label">匹配度</text>
      </view>
      <view class="trial-title">{{trial.name}}</view>
      <view class="trial-tags">
        <text class="tag tag-level level-{{trial.score <= 0 ? 'pending' : (trial.score >= 80 ? 'high' : (trial.score >= 60 ? 'mid' : 'low'))}}">{{trial.matchLevel}}</text>
        <text class="tag">{{trial.phase}}</text>
        <text class="tag">{{trial.location}}</text>
        <text class="tag">{{trial.type}}</text>
      </view>
      <text class="trial-meta" wx:if="{{trial.nctId}}">试验编号：{{trial.nctId}}</text>
      <text class="trial-meta" wx:if="{{trial.status}}">招募状态：{{trial.status}}</text>
    </view>

    <view class="fallback-tip" wx:if="{{usingCachedData}}">
      <text>当前详情由试验列表数据补全，建议稍后刷新获取完整入排标准。</text>
    </view>

    <!-- PRD-2026Q3 §UI-Audit-R1 §P0-3：与列表页统一 —— 「我们的看法」+ inline disclaimer -->
    <view class="decision-banner tone-{{trial.decisionTone}}">
      <view class="decision-head">
        <text class="decision-label">我们的看法</text>
        <medical-disclaimer variant="inline" />
      </view>
      <text class="decision-text">{{trial.decisionHint}}</text>
    </view>

    <view class="explain-section">
      <view class="section-title">预筛解释</view>

      <view class="explain-column column-hit">
        <view class="column-title">入组命中</view>
        <view class="column-item" wx:for="{{trial.inclusionHits}}" wx:key="index">
          <icon name="check" color="mint" size="28" strokeWidth="2.5" />
          <text class="column-text">{{item}}</text>
        </view>
        <view class="column-empty" wx:if="{{trial.inclusionHits.length === 0}}">
          <text>暂无明确命中证据</text>
        </view>
      </view>

      <view class="explain-column column-risk">
        <view class="column-title">排除风险</view>
        <view class="column-item" wx:for="{{trial.exclusionRisks}}" wx:key="index">
          <icon name="alert-circle" color="amber" size="28" />
          <text class="column-text">{{item}}</text>
        </view>
        <view class="column-empty safe" wx:if="{{trial.exclusionRisks.length === 0}}">
          <text>暂未识别明确排除风险</text>
        </view>
      </view>

      <view class="explain-column column-missing">
        <view class="column-title">缺失证据</view>
        <view class="column-item" wx:for="{{trial.missingEvidence}}" wx:key="index">
          <icon name="alert-circle" color="text-muted" size="28" />
          <text class="column-text">{{item}}</text>
        </view>
        <view class="column-empty safe" wx:if="{{trial.missingEvidence.length === 0}}">
          <text>关键证据基本齐全</text>
        </view>
        <button class="supplement-btn" wx:if="{{trial.missingEvidence.length > 0}}" bindtap="goToUpload">去补全病历</button>
      </view>
    </view>

    <view class="evidence-section">
      <view class="section-title">证据来源</view>
      <view class="evidence-group">
        <text class="evidence-title">入组证据片段</text>
        <view class="evidence-item" wx:for="{{trial.hitSources}}" wx:key="index">
          <view class="evidence-dot hit"></view>
          <text class="evidence-text">{{item}}</text>
        </view>
        <view class="column-empty" wx:if="{{!trial.hitSources || trial.hitSources.length === 0}}">
          <text>暂无可提取入组证据</text>
        </view>
      </view>

      <view class="evidence-group">
        <text class="evidence-title">排除风险片段</text>
        <view class="evidence-item" wx:for="{{trial.riskSources}}" wx:key="index">
          <view class="evidence-dot risk"></view>
          <text class="evidence-text">{{item}}</text>
        </view>
        <view class="column-empty" wx:if="{{!trial.riskSources || trial.riskSources.length === 0}}">
          <text>暂无可提取排除风险证据</text>
        </view>
      </view>

      <view class="evidence-group">
        <text class="evidence-title">待补证据片段</text>
        <view class="evidence-item" wx:for="{{trial.missingSources}}" wx:key="index">
          <view class="evidence-dot missing"></view>
          <text class="evidence-text">{{item}}</text>
        </view>
        <view class="column-empty" wx:if="{{!trial.missingSources || trial.missingSources.length === 0}}">
          <text>暂无可提取待补证据</text>
        </view>
      </view>
    </view>

    <view class="info-section">
      <view class="section-title">基本信息</view>
      <view class="info-list">
        <view class="info-item">
          <text class="info-label">适应症</text>
          <text class="info-value">{{trial.indication}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">研究机构</text>
          <text class="info-value">{{trial.institution}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">申办方</text>
          <text class="info-value">{{trial.sponsor}}</text>
        </view>
      </view>
    </view>

    <view class="description-section">
      <view class="section-title">研究介绍</view>
      <text class="description-text">{{trial.description}}</text>
    </view>

    <!-- PRD-2026Q3 §UI-Audit-R1 §B7：标题改为更准确的临床表述，加底部小字「最终由研究医生评估」 -->
    <view class="criteria-section">
      <view class="section-title">入组要满足这些条件</view>
      <view class="criteria-list">
        <view class="criteria-item inclusion" wx:for="{{trial.inclusion}}" wx:key="index">
          <icon name="check" color="mint" size="28" strokeWidth="2.5" />
          <text class="criteria-text">{{item}}</text>
        </view>
        <view class="column-empty" wx:if="{{trial.inclusion.length === 0}}">
          <text>暂无入选标准文本</text>
        </view>
      </view>
      <text class="criteria-clarify" wx:if="{{trial.inclusion.length > 0}}">满足以上条件 ≠ 一定能入组；最终由研究医生面对面评估</text>
    </view>

    <view class="criteria-section">
      <view class="section-title">这些情况会被排除</view>
      <view class="criteria-list">
        <view class="criteria-item exclusion" wx:for="{{trial.exclusion}}" wx:key="index">
          <icon name="x-circle" color="red" size="28" strokeWidth="2" />
          <text class="criteria-text">{{item}}</text>
        </view>
        <view class="column-empty" wx:if="{{trial.exclusion.length === 0}}">
          <text>暂无排除标准文本</text>
        </view>
      </view>
      <text class="criteria-clarify" wx:if="{{trial.exclusion.length > 0}}">如有疑问请在筛查时主动告诉研究医生 —— 有些情况可以个案评估</text>
    </view>

    <view class="contact-section">
      <view class="section-title">联系方式</view>
      <view class="contact-info">
        <text class="contact-name">联系人：{{trial.contact.name}}</text>
        <text class="contact-phone" bindtap="callPhone">电话：{{trial.contact.phoneMasked || '--'}}</text>
        <text class="contact-email">邮箱：{{trial.contact.email}}</text>
      </view>
    </view>

    <!-- PRD-2026Q3 §UI-Audit-R1 §P0-3 + §B1：详情页底部固定医学免责声明 -->
    <medical-disclaimer variant="default" />

    <!-- PRD-2026Q3 §UI-Audit-R1 §P0-2：CTA 文案与列表页统一 —— 「申请免费用药」（携带 phone-call 图标）
         不再用「立即报名」（措辞过于推销） -->
    <view class="bottom-bar">
      <button class="btn btn-primary btn-block apply-btn" bindtap="applyTrial">
        <icon name="phone-call" color="white" size="32" />
        <text class="apply-btn-text">申请免费用药</text>
      </button>
    </view>
  </block>
</view>
