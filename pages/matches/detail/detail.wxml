<!--pages/matches/detail/detail.wxml-->
<view class="container">
  <!-- 头部信息 -->
  <view class="trial-header">
    <view class="match-score">
      <text class="score-value">{{trial.score}}</text>
      <text class="score-label">匹配度</text>
    </view>
    <view class="trial-title">{{trial.name}}</view>
    <view class="trial-tags">
      <text class="tag tag-primary">{{trial.phase}}</text>
      <text class="tag tag-success">{{trial.location}}</text>
      <text class="tag tag-warning">{{trial.type}}</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="info-section">
    <view class="section-title">基本信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">适应症</text>
        <text class="info-value">{{trial.indication}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">研究机构</text>
        <text class="info-value">{{trial.institution}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">申办方</text>
        <text class="info-value">{{trial.sponsor}}</text>
      </view>
    </view>
  </view>

  <!-- 匹配理由 -->
  <view class="reasons-section">
    <view class="section-title">匹配理由</view>
    <view class="reason-list">
      <view class="reason-item" wx:for="{{trial.reasons}}" wx:key="*this">
        <text class="reason-icon">✓</text>
        <text class="reason-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 研究介绍 -->
  <view class="description-section">
    <view class="section-title">研究介绍</view>
    <text class="description-text">{{trial.description}}</text>
  </view>

  <!-- 入组标准 -->
  <view class="criteria-section">
    <view class="section-title">入选标准</view>
    <view class="criteria-list">
      <view class="criteria-item inclusion" wx:for="{{trial.inclusion}}" wx:key="*this">
        <text class="criteria-icon">+</text>
        <text class="criteria-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 排除标准 -->
  <view class="criteria-section">
    <view class="section-title">排除标准</view>
    <view class="criteria-list">
      <view class="criteria-item exclusion" wx:for="{{trial.exclusion}}" wx:key="*this">
        <text class="criteria-icon">-</text>
        <text class="criteria-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="contact-section">
    <view class="section-title">联系方式</view>
    <view class="contact-info">
      <text class="contact-name">联系人：{{trial.contact.name}}</text>
      <text class="contact-phone" bindtap="callPhone">电话：{{trial.contact.phone}}</text>
      <text class="contact-email">邮箱：{{trial.contact.email}}</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <button class="btn btn-primary btn-block" bindtap="applyTrial">立即报名</button>
  </view>
</view>