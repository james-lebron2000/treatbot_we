/* matches/detail —— Plan §G token-swap polish
 * 「token 化但不重设计」：替换 Ant Design 蓝青绿配色为 design tokens
 * 删除 #1890ff/#36cfc9/#52c41a/#ff4d4f 等 Ant Design 调色板 */

.container {
  padding-bottom: 150rpx;
}

/* Trial header —— Landing 同款 .hero-shell radial 浅光（替代 Ant Design 蓝青绿渐变） */
.trial-header {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(ellipse 120% 80% at 20% 10%, var(--brand-soft) 0%, transparent 60%),
    radial-gradient(ellipse 80% 60% at 100% 100%, var(--mint-soft) 0%, transparent 50%),
    var(--bg);
  border-radius: 28rpx;
  padding: 32rpx 26rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid var(--line);
}

.match-score {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 100rpx;
  height: 100rpx;
  background: var(--brand);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
  z-index: 1;
}

.score-value {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}

.trial-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  line-height: var(--lh-tight);
  margin-bottom: 16rpx;
  padding-right: 116rpx;
  letter-spacing: -0.01em;
  position: relative;
  z-index: 1;
}

.trial-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.trial-tags .tag {
  background: var(--bg);
  color: var(--text-dim);
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--r-pill);
  font-weight: 600;
  border: 2rpx solid var(--line);
}

.tag-level {
  font-weight: 600;
}

.level-high {
  background: var(--mint-soft) !important;
  color: var(--mint-text) !important;
  border-color: transparent !important;
}

.level-mid {
  background: var(--amber-soft) !important;
  color: var(--amber-text) !important;
  border-color: transparent !important;
}

.level-low {
  background: var(--bg-soft) !important;
  color: var(--text-dim) !important;
  border-color: transparent !important;
}

.level-pending {
  background: var(--brand-soft) !important;
  color: var(--brand) !important;
  border-color: transparent !important;
}

.trial-meta {
  display: block;
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: var(--lh-normal);
  position: relative;
  z-index: 1;
}

.fallback-tip {
  background: var(--amber-soft);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  color: var(--amber-text);
  font-size: 26rpx;
  line-height: var(--lh-normal);
}

/* 决策 banner */
.decision-banner {
  border-radius: 18rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.decision-label {
  font-size: 24rpx;
  padding: 6rpx 14rpx;
  border-radius: var(--r-pill);
  background: rgba(255, 255, 255, 0.65);
  font-weight: 600;
}

.decision-text {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  font-weight: 600;
  line-height: var(--lh-normal);
}

.tone-good {
  background: var(--mint-soft);
  color: var(--mint-text);
}

.tone-normal {
  background: var(--brand-soft);
  color: var(--brand);
}

.tone-warn {
  background: var(--amber-soft);
  color: var(--amber-text);
}

.tone-risk {
  background: var(--red-soft);
  color: var(--red-text);
}

/* Section cards */
.explain-section,
.evidence-section,
.info-section,
.description-section,
.criteria-section,
.contact-section {
  background: var(--bg);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border: 2rpx solid var(--line);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--brand);
  letter-spacing: -0.01em;
}

.evidence-group {
  border-radius: 14rpx;
  padding: 14rpx;
  margin-bottom: 10rpx;
  background: var(--bg-soft);
}

.evidence-group:last-child {
  margin-bottom: 0;
}

.evidence-title {
  display: block;
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.evidence-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.evidence-dot {
  margin-top: 8rpx;
  font-size: 20rpx;
}

.evidence-dot.hit {
  color: var(--mint-text);
}

.evidence-dot.risk {
  color: var(--amber-text);
}

.evidence-dot.missing {
  color: var(--brand);
}

.evidence-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: var(--lh-relaxed);
}

.explain-column {
  border-radius: 14rpx;
  padding: 14rpx 16rpx;
  margin-bottom: 12rpx;
}

.explain-column:last-child {
  margin-bottom: 0;
}

.column-hit {
  background: var(--mint-soft);
}

.column-risk {
  background: var(--amber-soft);
}

.column-missing {
  background: var(--brand-soft);
}

.column-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8rpx;
}

.column-hit .column-title {
  color: var(--mint-text);
}

.column-risk .column-title {
  color: var(--amber-text);
}

.column-missing .column-title {
  color: var(--brand);
}

.column-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.column-icon {
  width: 26rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
}

.column-icon.hit {
  color: var(--mint-text);
}

.column-icon.risk {
  color: var(--amber-text);
}

.column-icon.missing {
  color: var(--brand);
}

.column-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: var(--lh-normal);
}

.column-empty {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: var(--lh-normal);
}

.column-empty.safe {
  color: var(--mint-text);
}

.supplement-btn {
  margin-top: 12rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: var(--r-pill);
  background: var(--brand);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.info-item {
  display: flex;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--text-dim);
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
  line-height: var(--lh-normal);
}

.description-text {
  font-size: 28rpx;
  color: var(--text-dim);
  line-height: var(--lh-relaxed);
}

.criteria-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.criteria-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
}

.criteria-item.inclusion {
  background: var(--mint-soft);
}

.criteria-item.exclusion {
  background: var(--red-soft);
}

.criteria-icon {
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
}

.criteria-item.inclusion .criteria-icon {
  background: var(--mint);
  color: #fff;
}

.criteria-item.exclusion .criteria-icon {
  background: var(--red);
  color: #fff;
}

.criteria-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
  line-height: var(--lh-normal);
}

.contact-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.contact-name,
.contact-phone,
.contact-email {
  font-size: 28rpx;
  color: var(--text);
}

.contact-phone {
  color: var(--brand);
  font-weight: 600;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: var(--bg);
  border-top: 2rpx solid var(--line);
}

.btn-block {
  width: 100%;
}
