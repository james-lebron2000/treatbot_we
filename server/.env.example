# =============================================================================
# 仅本地开发模板（local-dev only）
# =============================================================================
# 本文件**只**用于本地 `npm run dev` / `npm test` 环境。
#
# 生产环境的所有密钥来自 GitHub Actions Secrets，由 .github/workflows/deploy.yml
# 在 docker run 时通过 -e 注入容器；运行中容器既不会读 /opt/treatbot/server/.env，
# 也不会读这个文件。详见仓库根 README.md「配置与密钥来源」。
#
# 历史踩坑（2026-05-02）：生产 .env 里残留 OCR_PROVIDER=kimi，即便 CI 已经注入
# Doubao 凭证，docker run --env-file 把这条旧 KEY 带进容器，导致生产一直走 Kimi
# 路径（慢、贵、URL 模式 400）。修复方案：deploy 脚本通过 -e OCR_PROVIDER=auto
# 显式覆盖，并把生产 .env 视为已废弃（不要再手工编辑）。
# =============================================================================

# 服务配置
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
LOG_DIR=./logs

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=treatbot

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
# ⚠️ 生产必须使用强随机秘钥（≥32 字符，非示例值）。
# 生成方法：node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# 模块 server/utils/jwtSecret.js 会在启动时校验：
#   - NODE_ENV=production 未设置或命中弱值黑名单 → 直接抛错拒启
#   - 其他环境未设置 → 自动生成临时秘钥（仅本次进程有效）
JWT_SECRET=
JWT_EXPIRES_IN=1800
JWT_REFRESH_EXPIRES_IN=604800

# 微信小程序配置
WEAPP_APPID=your_weapp_appid
WEAPP_SECRET=your_weapp_secret
# 微信 session_key 缓存时长（秒）
WEAPP_SESSION_TTL=7200

# H5 登录（建议仅联调环境开启）
# ⚠️ H5_LOGIN_FIXED_CODE 是万能验证码后门，仅 dev / e2e-mock 环境用。
# 生产 deploy.yml **绝对不能注入此变量**。代码侧 PRD-2026Q4 T0-7 followup 后已经
# fail-closed：未设置或空串都不会接受任何固定码；只有显式配置才生效。
# 历史踩坑（2026-05）：inseq.top 生产环境因模块顶层 const 冻结 + 默认 '000000'
# 双重失误，留下「000000 万能登录」后门，详见 docs/key-rotation-log.md。
H5_LOGIN_ENABLED=false
H5_LOGIN_FIXED_CODE=

# 管理后台独立登录（/treatbot/admin/login）
# ADMIN_LOGIN_KEY_HASH 只存 key 的 SHA-256 verifier，不存明文 key。
# 生成方法：
# node -e "const c=require('crypto');const k=c.randomBytes(32).toString('base64url');console.log({key:k,hash:'sha256:'+c.createHash('sha256').update(k).digest('hex')})"
#
# PRD-2026Q3 T1-6：单账号 ENV（下方）= 兼容旧部署，自动 role=super。
# 多账号 / 多角色推荐用 ADMIN_ACCOUNTS_JSON：
#   ADMIN_ACCOUNTS_JSON='[
#     {"username":"alice","keyHash":"sha256:...","role":"super","canReveal":true},
#     {"username":"bob",  "keyHash":"sha256:...","role":"ops"},
#     {"username":"carol","keyHash":"sha256:...","role":"cro_liaison"}
#   ]'
# role 枚举：super / ops / cro_liaison（详见 docs/MANUAL-OPS-2026Q3.md）
ADMIN_LOGIN_USERNAME=
ADMIN_LOGIN_KEY_HASH=
ADMIN_LOGIN_TOKEN_TTL=3600
ADMIN_LOGIN_CAN_REVEAL=false
ADMIN_LOGIN_ROLE=super
# ADMIN_ACCOUNTS_JSON=

# 腾讯云 COS 配置
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your_bucket_name
COS_REGION=ap-shanghai

# 腾讯云 OCR 配置
OCR_SECRET_ID=your_ocr_secret_id
OCR_SECRET_KEY=your_ocr_secret_key
OCR_REGION=ap-shanghai

# OCR 提供方: auto | doubao | kimi | tencent | rule
# auto 模式优先使用 Doubao/ARK，缺失则降级到 Kimi → Tencent → 规则。
OCR_PROVIDER=auto
# Plan §Phase 1.1：OCR 队列并发默认 4（原 2）。回退灰度时把 .env.production 显式改回 2。
# 升至 4 之前需确认 Doubao 配额 ≥ LLM_DOUBAO_CONCURRENCY；token bucket 不会撞封顶。
OCR_QUEUE_CONCURRENCY=4
OCR_PDF_VISION_MAX_PAGES=3
OCR_PDF_VISION_DPI=150

# Plan §Phase 1.1：LLM provider 进程内并发 token bucket。
# 灰度回退：把对应 provider 调到 1 即等价单线程串行。
LLM_DOUBAO_CONCURRENCY=3
LLM_KIMI_CONCURRENCY=2

# Plan §Phase 1.2：OCR 结果缓存。
# 改 prompt 时务必 bump 版本号（v1 → v2）让旧缓存自然失效；不需要手动 flush Redis。
PROMPT_VERSION=v1
# 命中 key：ocr:${PROMPT_VERSION}:${file_hash}，TTL 30 天（2592000s）。
OCR_CACHE_TTL_SECONDS=2592000

# Plan §Phase 2.4：腾讯云 CDN 加速 Doubao 拉图。留空 = 不启用（自动回落到原 COS 签名 URL）。
# 备案完成后填入 CDN 加速域名（如 ocr-cdn.example.com），代码会替换签名 URL 的 host。
# 边缘缓存策略必须设置：Cache-Control: private, max-age=0（防止病历图被 CDN 边缘缓存触合规）。
COS_CDN_DOMAIN=

# inclusion-parser 脚本（server/scripts/parseInclusion.js）的可选 OpenAI 后端 —— 仅离线脚本用。
# 三选一：ARK_API_KEY / OPENAI_API_KEY / KIMI_API_KEY，按优先级回退。
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_MS=30000

# Kimi OCR 配置（Doubao 不可用时的 fallback）
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5
KIMI_VISION_MODEL=moonshot-v1-128k-vision-preview
KIMI_TIMEOUT_MS=45000

# Doubao / 火山方舟 Ark（OpenAI 兼容协议；生产 OCR 推荐主路径）
# 控制台：https://console.volcengine.com/ark
# 视觉模型推荐：doubao-seed-1-6-vision-250815（Ark 必须带版本日期后缀的具体模型 ID；
#                短名 doubao-seed-1.6-vision 会返回 InvalidEndpointOrModel.NotFound）
# 备选：doubao-1-5-vision-pro-32k-250115
# 大型扫描 PDF + 多页 vision 调用需要 90s+，timeout 建议 ≥ 180000ms
ARK_API_KEY=your_volcengine_ark_api_key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_VISION_MODEL=doubao-seed-1-6-vision-250815
ARK_TIMEOUT_MS=180000

# OCR 队列外层兜底 timeout。真实链路可能包含 PDF/vision OCR + 二次结构化；
# 这里是 worker 防僵尸保护，不是客户端等待上限。
OCR_JOB_TIMEOUT_MS=900000
# 二次“流式结构化”只影响增量字段 UX，失败会使用 OCR 主链路已抽取结果兜底。
OCR_STRUCTURED_STREAM_TIMEOUT_MS=45000
# 解析状态轮询单独按用户限流，避免占用全局 IP 限流桶。
PARSE_STATUS_RATE_LIMIT_MAX=3600

# markitdown 文档转 Markdown（Microsoft markitdown CLI）
MARKITDOWN_TIMEOUT_MS=30000

# 对外访问域名（本地存储模式在非开发环境必须为 HTTPS）
PUBLIC_BASE_URL=https://api.treatbot.example.com

# CORS 配置
ALLOWED_ORIGINS=https://servicewechat.com

# Q3-红线 §A.3：Sentry 配置（DSN 留空则关闭上报，dev/CI 不会报错）
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.05

# ============================================================================
# Admin 后台 RBAC（middleware/adminAuth.js + utils/adminCredential.js）
# ============================================================================
# 两套机制二选一：
#   方式 A —— 简单白名单（早期路径）：以下三条任一命中即视为 admin
#     ADMIN_USER_IDS=user_xxx,user_yyy
#     ADMIN_OPENIDS=h5_138xxxx,wx_oyyyy
#     ADMIN_PHONES=13800001111,13900002222
#   方式 B —— 结构化账户表（推荐，PRD-2026Q3 T1-6 之后的主路径）：
#     ADMIN_ACCOUNTS_JSON='[{"id":"admin_a","email":"a@x.com","passwordHash":"sha256:...","role":"reviewer","canReveal":false}]'
# 注意：两种方式可以共存；任一命中都生效。生产环境 **请勿** 把 phone 直接写进
# ADMIN_PHONES（明文落盘风险），优先用 ADMIN_ACCOUNTS_JSON + 哈希口令。
ADMIN_USER_IDS=
ADMIN_OPENIDS=
ADMIN_PHONES=
ADMIN_ACCOUNTS_JSON=

# ⚠️  ADMIN_MFA_BYPASS — 临时旁路，禁用后台 PHI 字段（手机号/身份证/诊断/分期/治疗）
# 的二步验证；启用后 admin 可直接 reveal 明文。仅在 MFA 真集成（邮箱 OTP / TOTP）
# 上线前用作过渡。controllers/admin.js:1381 / :1507 同口径检查。
# 生产强烈建议保持 false；启用务必同步更新告警 + IP 白名单。
ADMIN_MFA_BYPASS=false

# ============================================================================
# /metrics 端点访问控制（middleware/metrics.js + app.js:127-133）
# ============================================================================
# 默认仅放行 RFC1918 内网 + 127.0.0.1（生产由 Prometheus 边车抓取）。
# 本地调试 / 容器外抓指标时可临时打开 METRICS_ALLOW_ALL=true。
METRICS_ALLOW_ALL=false

# PRD-2026Q4 T0-11：metrics pipeline 心跳间隔（毫秒）。低于 60s 会被告警规则误判。
METRICS_HEARTBEAT_INTERVAL_MS=60000

# ============================================================================
# OCR 安全 + 可靠性
# ============================================================================
# OCR_IMAGE_HOST_ALLOWLIST：services/ocr.js:138 SSRF 防御白名单（host 后缀，逗号分隔）。
# 默认放行腾讯云 COS（.myqcloud.com）；要支持自建 CDN 时显式追加。
OCR_IMAGE_HOST_ALLOWLIST=

# 大型扫描 PDF 拆页渲染超时（毫秒）。poppler pdftoppm 单页渲染上限。
OCR_PDF_RENDER_TIMEOUT_MS=20000

# 文本模型（非视觉路径）。inclusion-parser / 结构化抽取走纯文本时使用。
ARK_TEXT_MODEL=doubao-seed-1-6-flash-250828

# ============================================================================
# 验证码 / SMS 防滥用（services/captcha.js + services/sms.js）
# ============================================================================
# 腾讯云 Captcha — send-code 接口前置图形验证码；两个一起留空 → 关闭 captcha 校验
# （仅依赖 rate-limit 兜底）。生产强烈建议配置。
TENCENT_CAPTCHA_APP_ID=
TENCENT_CAPTCHA_SECRET_KEY=

# SMS 服务商；当前支持 'tencent' / 'aliyun' / 'fake'（默认走 services/sms.js 内的判定）
SMS_PROVIDER=

# ============================================================================
# 后台定时任务开关 + 调度（jobs/*.js）
# ============================================================================
# trialCrawler：每日抓 ClinicalTrials.gov，刷新现网 trials.status / phase / locations。
# trialFreshness：扫描 last_verified_at 过期的 trial 标记 status=closed。
# 默认关闭以避免未配 ARK_API_KEY 时启动报错；生产 deploy 显式开启。
ENABLE_TRIAL_CRAWLER_CRON=false
TRIAL_CRAWLER_CRON=0 3 * * *
TRIAL_CRAWLER_MAX_PER_RUN=200
ENABLE_TRIAL_FRESHNESS_CRON=false
TRIAL_FRESHNESS_CRON=0 4 * * *

# ============================================================================
# 容量与运维参数
# ============================================================================
# 单次批量上传病历最多多少份（前端 + 后端两端校验）
BATCH_UPLOAD_MAX=10
# OCR / 解析 worker 并发；超过会在 Bull 排队
PARSE_CONCURRENCY=4
# 备份脚本 scripts/backup.sh 用
BACKUP_DIR=./backups
BACKUP_KEEP_DAYS=14

# ============================================================================
# 迁移流程
# ============================================================================
# MIGRATE_SKIP_SYNC=true：跳过 sequelize.sync()，仅跑 ensureX（CI / 灰度环境用）。
# 生产首次跑请保持 false 让 sync 兜底建表。
MIGRATE_SKIP_SYNC=false

# COS 主账户 AppID（部分签名场景需要；不等于 COS_SECRET_ID）
COS_APPID=
