# =============================================================================
# 仅本地开发模板（local-dev only）
# =============================================================================
# 本文件**只**用于本地 `npm run dev` / `npm test` 环境。
#
# 生产环境的所有密钥来自 GitHub Actions Secrets，由 .github/workflows/deploy.yml
# 在 docker run 时通过 -e 注入容器；运行中容器既不会读 /opt/treatbot/server/.env，
# 也不会读这个文件。详见仓库根 README.md「配置与密钥来源」。
#
# 历史踩坑（2026-05-02）：生产 .env 里残留 OCR_PROVIDER=kimi，即便 CI 已经注入
# Doubao 凭证，docker run --env-file 把这条旧 KEY 带进容器，导致生产一直走 Kimi
# 路径（慢、贵、URL 模式 400）。修复方案：deploy 脚本通过 -e OCR_PROVIDER=auto
# 显式覆盖，并把生产 .env 视为已废弃（不要再手工编辑）。
# =============================================================================

# 服务配置
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
LOG_DIR=./logs

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=treatbot

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
# ⚠️ 生产必须使用强随机秘钥（≥32 字符，非示例值）。
# 生成方法：node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# 模块 server/utils/jwtSecret.js 会在启动时校验：
#   - NODE_ENV=production 未设置或命中弱值黑名单 → 直接抛错拒启
#   - 其他环境未设置 → 自动生成临时秘钥（仅本次进程有效）
JWT_SECRET=
JWT_EXPIRES_IN=1800
JWT_REFRESH_EXPIRES_IN=604800

# 微信小程序配置
WEAPP_APPID=your_weapp_appid
WEAPP_SECRET=your_weapp_secret
# 微信 session_key 缓存时长（秒）
WEAPP_SESSION_TTL=7200

# H5 登录（建议仅联调环境开启）
H5_LOGIN_ENABLED=false
H5_LOGIN_FIXED_CODE=000000

# 管理后台独立登录（/treatbot/admin/login）
# ADMIN_LOGIN_KEY_HASH 只存 key 的 SHA-256 verifier，不存明文 key。
# 生成方法：
# node -e "const c=require('crypto');const k=c.randomBytes(32).toString('base64url');console.log({key:k,hash:'sha256:'+c.createHash('sha256').update(k).digest('hex')})"
ADMIN_LOGIN_USERNAME=
ADMIN_LOGIN_KEY_HASH=
ADMIN_LOGIN_TOKEN_TTL=3600
ADMIN_LOGIN_CAN_REVEAL=false

# 腾讯云 COS 配置
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your_bucket_name
COS_REGION=ap-shanghai

# 腾讯云 OCR 配置
OCR_SECRET_ID=your_ocr_secret_id
OCR_SECRET_KEY=your_ocr_secret_key
OCR_REGION=ap-shanghai

# OCR 提供方: auto | doubao | kimi | tencent | rule
# auto 模式优先使用 Doubao/ARK，缺失则降级到 Kimi → Tencent → 规则。
OCR_PROVIDER=auto
OCR_QUEUE_CONCURRENCY=2
OCR_PDF_VISION_MAX_PAGES=3
OCR_PDF_VISION_DPI=150

# inclusion-parser 脚本（server/scripts/parseInclusion.js）的可选 OpenAI 后端 —— 仅离线脚本用。
# 三选一：ARK_API_KEY / OPENAI_API_KEY / KIMI_API_KEY，按优先级回退。
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Kimi OCR 配置（Doubao 不可用时的 fallback）
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5
KIMI_VISION_MODEL=moonshot-v1-128k-vision-preview
KIMI_TIMEOUT_MS=45000

# Doubao / 火山方舟 Ark（OpenAI 兼容协议；生产 OCR 推荐主路径）
# 控制台：https://console.volcengine.com/ark
# 视觉模型推荐：doubao-seed-1-6-vision-250815（Ark 必须带版本日期后缀的具体模型 ID；
#                短名 doubao-seed-1.6-vision 会返回 InvalidEndpointOrModel.NotFound）
# 备选：doubao-1-5-vision-pro-32k-250115
# 大型扫描 PDF + 多页 vision 调用需要 90s+，timeout 建议 ≥ 180000ms
ARK_API_KEY=your_volcengine_ark_api_key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_VISION_MODEL=doubao-seed-1-6-vision-250815
ARK_TIMEOUT_MS=180000

# markitdown 文档转 Markdown（Microsoft markitdown CLI）
MARKITDOWN_TIMEOUT_MS=30000

# 对外访问域名（本地存储模式在非开发环境必须为 HTTPS）
PUBLIC_BASE_URL=https://api.treatbot.example.com

# CORS 配置
ALLOWED_ORIGINS=https://servicewechat.com

# Q3-红线 §A.3：Sentry 配置（DSN 留空则关闭上报，dev/CI 不会报错）
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.05
