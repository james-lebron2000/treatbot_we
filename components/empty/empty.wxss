/** components/empty/empty.wxss
 * Q3 视觉对齐 §C.3：Landing 同款空状态 —— 删 Ant Design 青绿渐变；
 * 文字层次 var(--text-dim) / var(--text-muted)；CTA 走 ghost 风格。 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 48rpx;       /* --s-12 / --s-6 */
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;       /* --s-3 */
  opacity: 0.6;
}

.empty-title {
  font-size: 34rpx;           /* --fs-subtitle */
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;       /* --s-2 */
}

.empty-desc {
  font-size: 28rpx;           /* --fs-callout */
  color: var(--text-dim);
  margin-bottom: 48rpx;       /* --s-6 */
  text-align: center;
  line-height: 1.5;
}

.empty-btn {
  padding: 20rpx 56rpx;
  background: var(--bg);
  color: var(--brand);
  border: 2rpx solid var(--brand-soft);
  border-radius: 999rpx;
  font-size: 30rpx;           /* --fs-body */
  font-weight: 600;
  transition: background 150ms ease, transform 100ms cubic-bezier(0.4, 0, 0.2, 1);
}

.empty-btn:active {
  transform: scale(0.98);
  background: var(--brand-soft);
  border-color: var(--brand);
}
