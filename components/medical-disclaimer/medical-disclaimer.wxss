/* PRD-2026Q3 §UI-Audit-R1 §P0-3：医学免责声明样式
   设计原则（与 design-system 对齐）：
   - default：作为列表底部的"信息块"，非关键路径，文字 caption 字号、灰底、低视觉权重
   - compact：单行 inline，pill 状外观，用在每张卡的末尾
   - inline：极小字、灰色、括号包裹，贴在"我们的看法"等判断标签后
   不引入新阴影/渐变，全部用 token */

.disclaimer {
  width: 100%;
  box-sizing: border-box;
}

/* === default：4 行完整版 === */
.disclaimer-default {
  background: var(--bg-soft);
  border: 2rpx solid var(--line);
  border-radius: var(--r-md);
  padding: 24rpx 28rpx;
  margin: 24rpx 0;
}

.disclaimer-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.disclaimer-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-dim);
  line-height: 1.4;
}

.disclaimer-line {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 6rpx;
}

.disclaimer-bullet {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.6;
  flex-shrink: 0;
  width: 16rpx;
}

.disclaimer-text {
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.6;
  flex: 1;
}

/* === compact：单行简版 === */
.disclaimer-compact {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: var(--bg-soft);
  border-radius: var(--r-pill);
  margin: 16rpx 0;
}

.disclaimer-compact-text {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.4;
}

/* === inline：极小字注解 === */
.disclaimer-inline {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 400;
  margin-left: 8rpx;
}
