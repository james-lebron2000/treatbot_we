<!-- PRD-2026Q3 §UI-Audit-R1 §P0-3：医学免责声明（标准化、可复用） -->
<view class="disclaimer disclaimer-{{variant}}">
  <view wx:if="{{variant === 'default'}}" class="disclaimer-default">
    <view class="disclaimer-head">
      <icon name="shield-check" color="text-dim" size="32" strokeWidth="2" />
      <text class="disclaimer-title">关于这份匹配结果</text>
    </view>
    <view class="disclaimer-line">
      <text class="disclaimer-bullet">·</text>
      <text class="disclaimer-text">本平台只做病历与新药入组条件的匹配，不构成医学诊断或治疗建议。</text>
    </view>
    <view class="disclaimer-line">
      <text class="disclaimer-bullet">·</text>
      <text class="disclaimer-text">「免费用药」= 加入临床研究 · 您不用付药钱，但需配合研究方案与随访。</text>
    </view>
    <view class="disclaimer-line">
      <text class="disclaimer-bullet">·</text>
      <text class="disclaimer-text">是否真的入组、是否真的用药，由研究医生筛查 + 您和主治医生一起决定。</text>
    </view>
    <view class="disclaimer-line">
      <text class="disclaimer-bullet">·</text>
      <text class="disclaimer-text">参与临床研究可能有不良反应，研究医生会在签知情同意书时详细告知。</text>
    </view>
  </view>

  <view wx:elif="{{variant === 'compact'}}" class="disclaimer-compact">
    <icon name="shield-check" color="text-muted" size="24" strokeWidth="2" />
    <text class="disclaimer-compact-text">匹配建议 · 不构成医学诊断 · 最终用药请听主治医生</text>
  </view>

  <text wx:elif="{{variant === 'inline'}}" class="disclaimer-inline">
    （匹配建议 · 不构成医学诊断）
  </text>
</view>
