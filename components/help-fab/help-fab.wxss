/* PRD-2026Q3 §U5：求助 FAB —— 用 rpx 适配各种屏幕宽度
 * Q3 视觉对齐 §C.5（Plan web-treatbot-cozy-gizmo V2）：
 *   - 主色统一为 var(--brand)（原 #1F5AC7 与 brand 仅差 2 度，但视觉破碎）
 *   - 文本/分隔/底色全部走 token，与 Landing 卡片同形态 */
.help-fab-root {
  position: fixed;
  right: 24rpx;
  bottom: 140rpx; /* 让出 tab-bar */
  z-index: 1100;
}

.help-fab-btn {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: var(--brand);
  color: #fff;
  box-shadow: 0 8rpx 12rpx rgba(15, 23, 42, 0.05), 0 20rpx 40rpx rgba(15, 23, 42, 0.06);
  transition: transform 100ms cubic-bezier(0.4, 0, 0.2, 1), background 150ms ease;
}

.help-fab-btn:active {
  transform: scale(0.96);
  background: var(--brand-hover);
}

.help-fab-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
}

.help-fab-label {
  color: #fff;
  font-size: 28rpx;           /* --fs-callout */
  font-weight: 600;
}

.help-sheet {
  position: absolute;
  right: 0;
  bottom: 100rpx;
  width: 520rpx;
  background: var(--bg);
  border-radius: 32rpx;       /* --r-lg */
  border: 2rpx solid var(--line);
  box-shadow: 0 8rpx 12rpx rgba(15, 23, 42, 0.05), 0 20rpx 40rpx rgba(15, 23, 42, 0.06);
  overflow: hidden;
}

.help-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 12rpx;
}

.help-sheet-title {
  color: var(--text);
  font-size: 34rpx;           /* --fs-subtitle */
  font-weight: 600;
}

.help-sheet-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--bg-soft);
  color: var(--text-dim);
  font-size: 36rpx;
  line-height: 48rpx;
  text-align: center;
}

.help-sheet-list {
  padding: 0 12rpx 12rpx;
}

.help-sheet-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 20rpx 16rpx;
  border-radius: 24rpx;       /* --r-md */
}

.help-sheet-item:active {
  background: var(--bg-soft);
}

.help-sheet-item-title {
  color: var(--text);
  font-size: 30rpx;           /* --fs-body */
  font-weight: 600;
}

.help-sheet-item-sub {
  color: var(--text-dim);
  font-size: 26rpx;
  line-height: 1.5;
}

.help-sheet-footer {
  padding: 16rpx 28rpx 24rpx;
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 26rpx;
}

.help-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.5);
  z-index: 1300;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.help-modal-card {
  width: 100%;
  max-width: 620rpx;
  background: var(--bg);
  border-radius: 32rpx;       /* --r-lg */
  padding: 36rpx 32rpx 28rpx;
  box-shadow: 0 8rpx 12rpx rgba(15, 23, 42, 0.05), 0 20rpx 40rpx rgba(15, 23, 42, 0.06);
}

.help-modal-text {
  display: block;
  color: var(--text);
  font-size: 32rpx;
  line-height: 1.55;
  white-space: pre-line;
  margin-bottom: 24rpx;
}

.help-modal-ok {
  text-align: center;
  padding: 22rpx 0;
  background: var(--brand);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 24rpx;       /* --r-md */
  transition: transform 100ms cubic-bezier(0.4, 0, 0.2, 1), background 150ms ease;
}

.help-modal-ok:active {
  transform: scale(0.98);
  background: var(--brand-hover);
}
