/* PRD-2026Q3 §U5：求助 FAB —— 用 rpx 适配各种屏幕宽度 */
.help-fab-root {
  position: fixed;
  right: 24rpx;
  bottom: 140rpx; /* 让出 tab-bar */
  z-index: 1100;
}

.help-fab-btn {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: #1F5AC7;
  color: #fff;
  box-shadow: 0 12rpx 28rpx rgba(31, 90, 199, 0.32);
}

.help-fab-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.22);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
}

.help-fab-label {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

.help-sheet {
  position: absolute;
  right: 0;
  bottom: 100rpx;
  width: 520rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 24rpx 56rpx rgba(15, 23, 42, 0.18);
  overflow: hidden;
}

.help-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 12rpx;
}

.help-sheet-title {
  color: #0F172A;
  font-size: 38rpx;
  font-weight: 600;
}

.help-sheet-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F1F5F9;
  color: #1e293b;
  font-size: 40rpx;
  line-height: 48rpx;
  text-align: center;
}

.help-sheet-list {
  padding: 0 12rpx 12rpx;
}

.help-sheet-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
}

.help-sheet-item:active {
  background: #F8FAFC;
}

.help-sheet-item-title {
  color: #0F172A;
  font-size: 36rpx;
  font-weight: 600;
}

.help-sheet-item-sub {
  color: #1e293b;
  font-size: 32rpx;
  line-height: 1.45;
}

.help-sheet-footer {
  padding: 16rpx 28rpx 24rpx;
  background: #F0F6FF;
  color: #1F5AC7;
  font-size: 30rpx;
}

.help-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.5);
  z-index: 1300;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.help-modal-card {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx 28rpx;
  box-shadow: 0 24rpx 56rpx rgba(15, 23, 42, 0.22);
}

.help-modal-text {
  display: block;
  color: #0F172A;
  font-size: 38rpx;
  line-height: 1.55;
  white-space: pre-line;
  margin-bottom: 24rpx;
}

.help-modal-ok {
  text-align: center;
  padding: 22rpx 0;
  background: #1F5AC7;
  color: #fff;
  font-size: 38rpx;
  font-weight: 600;
  border-radius: 16rpx;
}
