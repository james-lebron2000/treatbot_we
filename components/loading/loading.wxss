/** components/loading/loading.wxss
 * Q3 视觉对齐 §C.4：删 Ant Design 青绿渐变 → 三个 brand 实色小圆 + bounce。 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx;             /* --s-4 */
}

.loading-container.fullscreen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.92);
  z-index: 9999;
}

.loading-animation {
  display: flex;
  gap: 16rpx;                 /* --s-2 */
  margin-bottom: 16rpx;
}

.loading-circle {
  width: 20rpx;
  height: 20rpx;
  background: var(--brand);
  border-radius: 50%;
  animation: loading-bounce 1.4s ease-in-out infinite both;
}

.loading-circle:nth-child(1) { animation-delay: -0.32s; }
.loading-circle:nth-child(2) { animation-delay: -0.16s; }

@keyframes loading-bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.loading-text {
  font-size: 28rpx;           /* --fs-callout */
  color: var(--text-dim);
}
